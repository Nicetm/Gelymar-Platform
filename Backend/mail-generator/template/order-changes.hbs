<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>{{subject}}</title>
</head>
<body style="font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;color:#333;max-width:600px;margin:0 auto;padding:20px">

  <div style="text-align:center;margin-bottom:20px">
    <img src="{{logoUrl}}" alt="Gelymar Logo" style="max-width:200px;height:auto">
  </div>

  <div style="background:#163F6F;padding:20px;border-radius:8px 8px 0 0;text-align:center">
    <h1 style="color:white;margin:0;font-size:24px">{{title}}</h1>
  </div>

  <div style="background:#f8fafc;padding:30px;border-radius:0 0 8px 8px;border:1px solid #e2e8f0">
    <p style="font-size:16px;line-height:1.6;margin-bottom:20px">
      Hola <strong style="color:#163F6F">{{adminName}}</strong>,
    </p>

    <p style="font-size:14px;line-height:1.6;margin-bottom:20px">
      Se detectaron cambios en <strong>{{totalOrders}}</strong> orden(es). A continuación el detalle:
    </p>

    {{#each orders}}
    <div style="background:white;padding:16px;border-radius:6px;border-left:4px solid #163F6F;margin:16px 0">
      <p style="font-size:14px;font-weight:bold;color:#163F6F;margin:0 0 10px 0">
        📦 PC: {{this.pc}} {{#if this.factura}}| Factura: {{this.factura}}{{else}}| Sin factura{{/if}}
      </p>
      <table style="width:100%;border-collapse:collapse;font-size:13px">
        <thead>
          <tr style="background:#f1f5f9">
            <th style="text-align:left;padding:6px 8px;border-bottom:1px solid #e2e8f0">Campo</th>
            <th style="text-align:left;padding:6px 8px;border-bottom:1px solid #e2e8f0">Anterior</th>
            <th style="text-align:left;padding:6px 8px;border-bottom:1px solid #e2e8f0">Nuevo</th>
          </tr>
        </thead>
        <tbody>
          {{#each this.changes}}
          <tr>
            <td style="padding:5px 8px;border-bottom:1px solid #f1f5f9;color:#475569">{{this.label}}</td>
            <td style="padding:5px 8px;border-bottom:1px solid #f1f5f9;color:#dc2626">{{this.oldValue}}</td>
            <td style="padding:5px 8px;border-bottom:1px solid #f1f5f9;color:#16a34a">{{this.newValue}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/each}}

    {{#if portalUrl}}
    <div style="text-align:center;margin:30px 0">
      <a href="{{portalUrl}}" style="background:#163F6F;color:#fff;text-decoration:none;padding:12px 18px;border-radius:6px;display:inline-block">
        Ir al portal
      </a>
    </div>
    {{/if}}

    <div style="border-top:2px solid #e2e8f0;padding-top:20px">
      <p style="font-size:16px;line-height:1.6;margin-bottom:5px">
        <strong style="color:#163F6F">Saludos</strong>
      </p>
      <p style="font-size:18px;font-weight:bold;color:#F4940C;margin:5px 0">
        Gelymar
      </p>
    </div>

    <div style="border-top:1px solid #e2e8f0;padding-top:15px;margin-top:20px;text-align:center">
      <p style="font-size:12px;color:#94a3b8;margin:0;font-style:italic">
        Este es un correo automático. No respondas directamente a este mensaje.
      </p>
    </div>
  </div>
</body>
</html>
