---
// src/components/AuthGuard.astro
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
---
<script is:inline define:vars={{ apiBase }}>
  document.addEventListener('DOMContentLoaded', async () => {
    const token = localStorage.getItem('token');

    if (!token) {
      window.location.href = '/authentication/sign-in';
      return;
    }

    try {
      // Verificar token localmente
      const [, payloadBase64] = token.split('.');
      if (!payloadBase64) {
        localStorage.removeItem('token');
        window.location.href = '/authentication/sign-in';
        return;
      }

      const payload = JSON.parse(atob(payloadBase64));

      // Solo verificar que tenga los campos básicos
      if (!payload.email || !payload.id) {
        localStorage.removeItem('token');
        window.location.href = '/authentication/sign-in';
        return;
      }

    } catch (err) {
      localStorage.removeItem('token');
      window.location.href = '/authentication/sign-in';
    }
  });
</script>
