---
// src/components/AuthGuard.astro
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const { role } = Astro.props;
---

<script
  type="module"
  define:vars={{ apiBase, requiredRole: role }}
>
  import { initAuthGuard } from '/js/auth-guard.js';

  initAuthGuard({ requiredRole });
</script>
