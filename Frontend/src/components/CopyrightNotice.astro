---
import { getServerLang, loadTranslations } from '../lib/i18n.js';

const lang = getServerLang(Astro.cookies);
const t: any = await loadTranslations(lang, 'footer');
const year = new Date().getFullYear();
---
<p class="my-10 text-sm text-center text-gray-500 dark:text-gray-400">
  <span set:html={t.copyright?.replace('{year}', year) || `© 1991–${year} Gelymar SA. All rights reserved.`}></span>
  <br />
  <span class="text-xs">
    <span set:html={t.built_by || 'Built with <span class="text-red-500">❤️</span> by the <a href="https://softkey.cl" target="_blank" class="hover:underline text-[#00538C] dark:text-[#F6B234] font-semibold">Softkey</a> team'} />
  </span>
</p>