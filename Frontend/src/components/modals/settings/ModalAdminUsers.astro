---
interface AdminSettingsTranslations {
  admins_title?: string;
  admins_subtitle?: string;
  add_admin?: string;
  cancel?: string;
  close?: string;
  save?: string;
  email?: string;
  full_name?: string;
  phone?: string;
  agent?: string;
  actions?: string;
  reset_password?: string;
  confirm_reset?: string;
  confirm_delete?: string;
  admins_help_title?: string;
  admins_help_add?: string;
  admins_help_fields?: string;
  admins_help_agent?: string;
  admins_help_actions?: string;
  admins_help_password?: string;
}

interface Props {
  adminSettings: AdminSettingsTranslations;
}

const { adminSettings } = Astro.props as Props;
---

<div id="adminUsersModal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-black/80 hidden justify-center items-center z-50">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-6 w-full max-w-3xl mx-4 relative max-h-[90vh] overflow-y-auto shadow-2xl">
    <div class="absolute top-3 right-3 flex items-center gap-2">
      <button id="adminUsersHelpBtn" type="button" class="text-blue-600 hover:text-blue-800 dark:text-blue-300 dark:hover:text-blue-200" aria-label={adminSettings.admins_help_title ?? 'Ayuda'}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.227 9a3 3 0 115.546 1c-.612.62-1.273 1.06-1.273 2M12 17h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
        </svg>
      </button>
      <button id="closeAdminUsersModal" class="text-gray-400 hover:text-red-500 transition dark:text-gray-300 dark:hover:text-red-400">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
        <span>AD</span>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">{adminSettings.admins_title ?? 'Administrators'}</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400">{adminSettings.admins_subtitle ?? 'Manage admin users'}</p>
      </div>
    </div>

    <div id="adminUsersFormContainer" class="border-b border-gray-200 dark:border-gray-700 pb-4 mb-6"></div>

    <div id="adminUsersTableContainer" class="mb-6"></div>

    <div class="flex justify-between items-center pt-4 border-t border-gray-200 dark:border-gray-700">
      <button id="addAdminUserBtn" type="button"
        class="text-xs flex items-center gap-2 text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300 font-medium transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        {adminSettings.add_admin ?? 'Add admin'}
      </button>
      <div class="flex gap-3">
        <button id="cancelAdminUsersBtn"
          class="text-xs px-4 py-2 bg-gray-300 dark:bg-gray-800 text-gray-700 dark:text-gray-100 rounded-md hover:bg-gray-400 dark:hover:bg-gray-700 transition font-medium">
          {adminSettings.cancel ?? 'Cancel'}
        </button>
        <button id="saveAdminUsersBtn"
          class="text-xs px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-md font-medium transition">
          {adminSettings.save ?? 'Save'}
        </button>
      </div>
    </div>
  </div>
</div>

<div id="adminUsersHelpModal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-black/80 hidden justify-center items-center z-50">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-6 w-full max-w-md mx-4 relative shadow-2xl">
    <button id="closeAdminUsersHelpModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-blue-500 transition dark:text-gray-300 dark:hover:text-blue-400">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <h3 class="text-lg font-bold mb-3">{adminSettings.admins_help_title ?? 'Ayuda'}</h3>
    <div class="my-3 border-t border-gray-200 dark:border-gray-700"></div>
    <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
      <li>{adminSettings.admins_help_add ?? 'Usa "Agregar admin" para crear nuevos usuarios.'}</li>
      <li>{adminSettings.admins_help_fields ?? 'RUT y email son obligatorios. Nombre y teléfono son opcionales.'}</li>
      <li>{adminSettings.admins_help_agent ?? 'Agente habilita el chat para este administrador.'}</li>
      <li>{adminSettings.admins_help_actions ?? 'Edita con el lápiz y confirma con el check verde o cancela con la X roja.'}</li>
      <li>{adminSettings.admins_help_password ?? 'El ícono de reset genera una contraseña temporal.'}</li>
    </ul>
    <div class="my-4 border-t border-gray-200 dark:border-gray-700"></div>
    <div class="flex justify-end">
      <button id="closeAdminUsersHelpModalFooterBtn" class="px-4 py-2 bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-white rounded-md text-sm">
        {adminSettings.close ?? adminSettings.cancel ?? 'Cerrar'}
      </button>
    </div>
  </div>
</div>

<template id="adminUsersFormTableTemplate">
  <table class="w-full text-xs border border-gray-200 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-800">
    <thead>
      <tr class="bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
        <th class="p-2 text-left">RUT</th>
        <th class="p-2 text-left">{adminSettings.email ?? 'Email'}</th>
        <th class="p-2 text-left">{adminSettings.full_name ?? 'Full name'}</th>
        <th class="p-2 text-left">{adminSettings.phone ?? 'Phone'}</th>
        <th class="p-2 text-left">{adminSettings.agent ?? 'Agent Chat'}</th>
        <th class="p-2 text-center">{adminSettings.actions ?? 'Actions'}</th>
      </tr>
    </thead>
    <tbody id="adminUsersFormTableBody"></tbody>
  </table>
</template>

<template id="adminUsersExistingTableTemplate">
  <table class="w-full text-xs border border-gray-200 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-800">
    <thead>
      <tr class="bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
        <th class="p-2 text-left">RUT</th>
        <th class="p-2 text-left">{adminSettings.email ?? 'Email'}</th>
        <th class="p-2 text-left">{adminSettings.full_name ?? 'Full name'}</th>
        <th class="p-2 text-left">{adminSettings.phone ?? 'Phone'}</th>
        <th class="p-2 text-left">{adminSettings.agent ?? 'Agent Chat'}</th>
        <th class="p-2 text-center">{adminSettings.actions ?? 'Actions'}</th>
      </tr>
    </thead>
    <tbody id="adminUsersExistingTableBody"></tbody>
  </table>
</template>
