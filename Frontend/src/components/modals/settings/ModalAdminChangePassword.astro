---
interface AdminSettingsTranslations {
  change_password_title?: string;
  current_password_label?: string;
  new_password_label?: string;
  confirm_password_label?: string;
  current_password_placeholder?: string;
  new_password_placeholder?: string;
  confirm_password_placeholder?: string;
  change_password_button?: string;
  cancel?: string;
  password_rule_min?: string;
  password_rule_upper?: string;
  password_rule_lower?: string;
  password_rule_number?: string;
}

interface Props {
  adminSettings: AdminSettingsTranslations;
}

const { adminSettings } = Astro.props as Props;
---

<div id="adminChangePasswordModal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-black/80 hidden justify-center items-center z-50">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-6 w-full max-w-md mx-4 relative shadow-2xl">
    <button id="closeAdminChangePasswordModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-rose-500 transition dark:text-gray-300 dark:hover:text-rose-400">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
        <span>CP</span>
      </div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">{adminSettings.change_password_title}</h2>
    </div>

    <form id="adminChangePasswordForm" class="space-y-4">
      <input type="text" name="username" autocomplete="username" style="display: none;" tabindex="-1" aria-hidden="true" />

      <div>
        <label for="adminCurrentPassword" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">
          {adminSettings.current_password_label}
        </label>
        <input
          type="password"
          id="adminCurrentPassword"
          name="currentPassword"
          required
          autocomplete="current-password"
          class="w-full text-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
          placeholder={adminSettings.current_password_placeholder}
        >
      </div>

      <div>
        <label for="adminNewPassword" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">
          {adminSettings.new_password_label}
        </label>
        <input
          type="password"
          id="adminNewPassword"
          name="newPassword"
          required
          minlength="8"
          autocomplete="new-password"
          class="w-full text-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
          placeholder={adminSettings.new_password_placeholder}
        >
        <ul id="adminPasswordRules" class="mt-3 text-xs space-y-1 text-gray-600 dark:text-gray-400">
          <li data-rule="length" class="flex items-center gap-2">
            <span class="rule-icon text-rose-500 dark:text-rose-400">✗</span>
            <span>{adminSettings.password_rule_min}</span>
          </li>
          <li data-rule="upper" class="flex items-center gap-2">
            <span class="rule-icon text-rose-500 dark:text-rose-400">✗</span>
            <span>{adminSettings.password_rule_upper}</span>
          </li>
          <li data-rule="lower" class="flex items-center gap-2">
            <span class="rule-icon text-rose-500 dark:text-rose-400">✗</span>
            <span>{adminSettings.password_rule_lower}</span>
          </li>
          <li data-rule="number" class="flex items-center gap-2">
            <span class="rule-icon text-rose-500 dark:text-rose-400">✗</span>
            <span>{adminSettings.password_rule_number}</span>
          </li>
        </ul>
      </div>

      <div>
        <label for="adminConfirmPassword" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">
          {adminSettings.confirm_password_label}
        </label>
        <input
          type="password"
          id="adminConfirmPassword"
          name="confirmPassword"
          required
          minlength="8"
          autocomplete="new-password"
          class="w-full text-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition"
          placeholder={adminSettings.confirm_password_placeholder}
        >
      </div>
    </form>

    <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-gray-200 dark:border-gray-700">
      <button id="cancelAdminChangePasswordBtn" type="button"
        class="text-xs px-4 py-2 bg-gray-300 dark:bg-gray-800 text-gray-700 dark:text-gray-100 rounded-md hover:bg-gray-400 dark:hover:bg-gray-700 transition font-medium">
        {adminSettings.cancel}
      </button>
      <button id="saveAdminPasswordBtn" type="button"
        class="text-xs px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-md font-medium transition flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        {adminSettings.change_password_button}
      </button>
    </div>
  </div>
</div>
