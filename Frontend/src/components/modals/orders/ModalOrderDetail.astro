---
interface Props {
  orders: Record<string, any>;
}

const { orders = {} } = Astro.props as Props;

const text = (value: string | undefined, fallback: string) =>
  typeof value === 'string' && value.trim().length > 0 ? value : fallback;
---

<div id="orderDetailModal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-black/80 hidden z-50 flex justify-center items-center">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-6 w-full max-w-2xl mx-4 relative max-h-[90vh] overflow-y-auto shadow-2xl">
    <button id="closeOrderDetailModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition dark:text-gray-300 dark:hover:text-red-400">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
        <span id="orderDetailInitials">OD</span>
      </div>
      <div>
        <h2 id="orderDetailTitle" class="text-xl font-bold text-gray-900 dark:text-gray-100"></h2>
        <p id="orderDetailSubtitle" class="text-sm text-gray-600 dark:text-gray-400">
          {text(orders?.orderDetails, 'Order details')}
        </p>
      </div>
    </div>

    <div class="overflow-hidden rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-100 dark:bg-gray-800 sticky top-0 z-10">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">
              {text(orders?.orderDetails, 'Order details')}
            </th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300"></th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-xs">
          <tr>
            <td class="px-6 py-4 text-gray-600 dark:text-gray-400 font-semibold">{text(orders?.pcNumber, 'PC Number')}</td>
            <td id="orderDetailPc" class="px-6 py-4 text-gray-900 dark:text-gray-100">-</td>
          </tr>
          <tr>
            <td class="px-6 py-4 text-gray-600 dark:text-gray-400 font-semibold">{text(orders?.ocNumber, 'OC Number')}</td>
            <td id="orderDetailOc" class="px-6 py-4 text-gray-900 dark:text-gray-100">-</td>
          </tr>
          <tr>
            <td class="px-6 py-4 text-gray-600 dark:text-gray-400 font-semibold">{text(orders?.certificados, 'Certificates')}</td>
            <td id="orderDetailCertificados" class="px-6 py-4 text-gray-900 dark:text-gray-100">-</td>
          </tr>
          <tr>
            <td class="px-6 py-4 text-gray-600 dark:text-gray-400 font-semibold">{text(orders?.direccionDestino, 'Destination address')}</td>
            <td id="orderDetailDireccionDestino" class="px-6 py-4 text-gray-900 dark:text-gray-100">-</td>
          </tr>
          <tr>
            <td class="px-6 py-4 text-gray-600 dark:text-gray-400 font-semibold">{text(orders?.puertoDestino, 'Destination port')}</td>
            <td id="orderDetailPuertoDestino" class="px-6 py-4 text-gray-900 dark:text-gray-100">-</td>
          </tr>
          <tr>
            <td class="px-6 py-4 text-gray-600 dark:text-gray-400 font-semibold">{text(orders?.observaciones, 'Observations')}</td>
            <td id="orderDetailObservaciones" class="px-6 py-4 text-gray-900 dark:text-gray-100">-</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

