---
interface Props {
  changePassword: {
    title: string;
    customerLabel: string;
    newPasswordLabel: string;
    confirmPasswordLabel: string;
    newPasswordPlaceholder: string;
    confirmPasswordPlaceholder: string;
    submit: string;
    blockUser?: string;
    unblockUser?: string;
    helpTitle?: string;
    helpStep1?: string;
    helpStep2?: string;
    helpStep3?: string;
    helpStep4?: string;
    rules?: {
      minLength?: string;
      upper?: string;
      lower?: string;
      number?: string;
    };
  };
  cancelLabel: string;
}

const {
  changePassword,
  cancelLabel,
} = Astro.props as Props;
---

<!-- Modal de Cambio de Contraseña -->
<div id="changePasswordModal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-black/80 hidden justify-center items-center z-50">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-6 w-full max-w-md mx-4 relative shadow-2xl">
    <!-- Botones de cerrar y ayuda -->
    <div class="absolute top-3 right-3 flex items-center gap-2">
      <button id="changePasswordHelpBtn" type="button" class="text-blue-600 hover:text-blue-800 dark:text-blue-300 dark:hover:text-blue-200" aria-label="Ayuda">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.227 9a3 3 0 115.546 1c-.612.62-1.273 1.06-1.273 2M12 17h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
        </svg>
      </button>
      <button id="closeChangePasswordModalBtn" class="text-gray-400 hover:text-blue-500 transition dark:text-gray-300 dark:hover:text-blue-400">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <!-- Título -->
    <div class="flex items-center gap-3 mb-6">
      <div class="p-2 bg-orange-100 dark:bg-orange-900/30 rounded-lg">
        <svg class="w-6 h-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
        </svg>
      </div>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">{changePassword.title}</h2>
    </div>

    <!-- Información del cliente -->
    <div class="mb-6 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
      <p class="text-sm text-gray-600 font-bold dark:text-gray-400 mb-1">{changePassword.customerLabel}:
        <span id="changePasswordCustomerName" class="font-medium text-gray-900 dark:text-white">-</span>
      </p> 
    </div>

    <!-- Formulario -->
    <form id="changePasswordForm" class="space-y-4">
      <!-- Hidden username field for accessibility -->
      <input type="text" name="username" autocomplete="username" style="display: none;" tabindex="-1" aria-hidden="true" />
      <div>
        <label for="newPassword" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">
          {changePassword.newPasswordLabel}
        </label>
        <input 
          type="password" 
          id="newPassword" 
          name="newPassword"
          required
          minlength="6"
          autocomplete="new-password"
          class="w-full text-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition"
          placeholder={changePassword.newPasswordPlaceholder}
        >
      </div>

      <ul id="changePasswordRules" class="mt-3 text-xs space-y-1 text-gray-600 dark:text-gray-400">
        <li data-rule="length" class="flex items-center gap-2">
          <span class="rule-icon text-rose-500 dark:text-rose-400">✗</span>
          <span>{changePassword.rules?.minLength}</span>
        </li>
        <li data-rule="upper" class="flex items-center gap-2">
          <span class="rule-icon text-rose-500 dark:text-rose-400">✗</span>
          <span>{changePassword.rules?.upper}</span>
        </li>
        <li data-rule="lower" class="flex items-center gap-2">
          <span class="rule-icon text-rose-500 dark:text-rose-400">✗</span>
          <span>{changePassword.rules?.lower}</span>
        </li>
        <li data-rule="number" class="flex items-center gap-2">
          <span class="rule-icon text-rose-500 dark:text-rose-400">✗</span>
          <span>{changePassword.rules?.number}</span>
        </li>
      </ul>
      
      <div>
        <label for="confirmPassword" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">
          {changePassword.confirmPasswordLabel}
        </label>
        <input 
          type="password" 
          id="confirmPassword" 
          name="confirmPassword"
          required
          minlength="6"
          autocomplete="new-password"
          class="w-full text-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 transition"
          placeholder={changePassword.confirmPasswordPlaceholder}
        >
      </div>
    </form>

    <!-- Botones -->
    <div class="flex justify-between gap-3 mt-6 pt-4 border-t border-gray-200 dark:border-gray-700">
      <button id="toggleBlockBtn" type="button" data-blocked="0" data-rut=""
        class="text-xs px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white rounded-md font-medium transition flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <span id="toggleBlockBtnText">{changePassword.blockUser || 'Bloquear'}</span>
      </button>
      
      <div class="flex gap-3">
        <button id="cancelChangePasswordBtn" type="button"
          class="text-xs px-4 py-2 bg-gray-300 dark:bg-gray-800 text-gray-700 dark:text-gray-100 rounded-md hover:bg-gray-400 dark:hover:bg-gray-700 transition font-medium">
          {cancelLabel}
        </button>
        <button id="savePasswordBtn" type="button"
          class="text-xs px-4 py-2 bg-orange-600 hover:bg-orange-700 text-white rounded-md font-medium transition flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          {changePassword.submit}
        </button>
      </div>
    </div>
  </div>
</div>


<!-- Modal de Ayuda -->
<div id="changePasswordHelpModal" class="fixed inset-0 hidden justify-center items-center z-50 bg-black/50 flex backdrop-blur-sm">
  <div class="bg-white/95 dark:bg-gray-800/95 text-gray-900 dark:text-gray-100 rounded-2xl p-6 w-full max-w-md relative shadow-2xl ring-1 ring-gray-200 dark:ring-white/10">
    <button id="closeChangePasswordHelpModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition text-xs">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <h3 class="text-lg font-bold mb-3">{changePassword.helpTitle || 'Ayuda - Cambio de Contraseña'}</h3>
    <div class="my-3 border-t border-gray-200 dark:border-gray-700"></div>
    <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
      <li>{changePassword.helpStep1 || 'La contraseña debe tener al menos 8 caracteres.'}</li>
      <li>{changePassword.helpStep2 || 'Debe incluir al menos una letra mayúscula, una minúscula y un número.'}</li>
      <li>{changePassword.helpStep3 || 'El botón "Bloquear" permite bloquear el acceso del usuario al sistema.'}</li>
      <li>{changePassword.helpStep4 || 'Un usuario bloqueado no podrá iniciar sesión hasta que sea desbloqueado.'}</li>
    </ul>
    <div class="my-4 border-t border-gray-200 dark:border-gray-700"></div>
    <div class="flex justify-end">
      <button id="closeChangePasswordHelpModalFooterBtn" class="px-4 py-2 bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-white rounded-md text-sm">
        {cancelLabel || 'Cerrar'}
      </button>
    </div>
  </div>
</div>
