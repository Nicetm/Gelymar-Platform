---
import { loadTranslations, getServerLang } from '../lib/i18n.js';

export interface Props {
  unreadCount?: number;
  roleId?: number | null;
  notificationSettings?: {
    orders?: {
      enabled?: boolean;
      config?: Record<string, unknown> | null;
    };
    users?: {
      enabled?: boolean;
      config?: Record<string, unknown> | null;
    };
  };
}

const {
  unreadCount = 0,
  roleId = null,
  notificationSettings = {}
} = Astro.props as Props;

const apiBase = import.meta.env.PUBLIC_API_URL || import.meta.env.SERVER_API_URL;
const apiPublic = import.meta.env.PUBLIC_API_URL;

const lang = getServerLang(Astro.cookies);
let notificationStrings: Record<string, string> = {};

try {
  const loaded = await loadTranslations(lang, 'notifications');
  if (loaded && typeof loaded === 'object') {
    notificationStrings = loaded as Record<string, string>;
  }
} catch {
  notificationStrings = {};
}

const labels = {
  tooltip: notificationStrings.tooltip ?? 'Notificaciones',
  title: notificationStrings.title ?? 'Notificaciones',
  markAll: notificationStrings.mark_all ?? 'Marcar como leídos',
  empty: notificationStrings.empty ?? 'No hay notificaciones',
  viewAll: notificationStrings.view_all ?? 'Ver todas las notificaciones'
};
---

<!-- Campanita de notificaciones -->
<div id="notification-bell-wrapper" class="relative">
  <button
    id="notification-bell"
    class="relative p-2 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500"
    aria-label={labels.tooltip}
  >
    <!-- Icono de campanita -->
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <!-- cuerpo -->
      <path d="M12 4c-3.3 0-6 2.7-6 6v3c0 .9-.34 1.7-.95 2.32L4 17h16l-.95-1.68c-.61-.62-.95-1.43-.95-2.32V10c0-3.3-2.7-6-6-6z"/>
      <!-- badajo/sonido -->
      <path d="M10 20a2 2 0 0 0 4 0"/>
    </svg>
    
    <!-- Badge de notificaciones no leídas (se actualiza dinámicamente) -->
    <span id="notification-badge" class="absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center animate-pulse hidden">
      0
    </span>
    
    <!-- Animación de ping cuando hay notificaciones -->
    <span id="notification-ping" class="absolute -top-1 -right-1 bg-red-400 rounded-full w-5 h-5 animate-ping opacity-75 hidden"></span>
  </button>
  
  <!-- Dropdown de notificaciones -->
  <div
    id="notification-dropdown"
    class="absolute right-0 mt-2 w-80 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 z-50 hidden"
  >
    <!-- Header del dropdown -->
    <div class="flex items-center justify-between p-3 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-base font-semibold text-gray-900 dark:text-white">{labels.title}</h3>
      <button
        id="mark-all-read"
        class:list={{
          'text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300': true,
          hidden: unreadCount === 0,
        }}
      >
        {labels.markAll}
      </button>
    </div>
    
    <!-- Lista de notificaciones -->
    <div id="notification-list" class="max-h-96 overflow-y-auto">
      <!-- Las notificaciones se cargarán dinámicamente aquí -->
      <div class="p-4 text-center text-gray-500 dark:text-gray-400">
        <svg class="w-8 h-8 mx-auto mb-2 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <!-- cuerpo -->
          <path d="M12 4c-3.3 0-6 2.7-6 6v3c0 .9-.34 1.7-.95 2.32L4 17h16l-.95-1.68c-.61-.62-.95-1.43-.95-2.32V10c0-3.3-2.7-6-6-6z"/>
          <!-- badajo/sonido -->
          <path d="M10 20a2 2 0 0 0 4 0"/>
        </svg>
        <p>{labels.empty}</p>
      </div>
    </div>
    
    <!-- Footer del dropdown -->
    <div class="p-2 border-t border-gray-200 dark:border-gray-700">
      <a
        href="/admin/messaging"
        class="block text-center text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300"
      >
        {labels.viewAll}
      </a>
    </div>
  </div>
</div>



<script
  type="module"
  define:vars={{ apiPublic, apiBase, unreadCount, roleId, notificationSettings, lang, notificationStrings }}
>
  import { initNotificationBell } from '/js/notification-bell.js';
  initNotificationBell({
    apiBase,
    apiPublic,
    initialUnread: unreadCount || 0,
    roleId,
    notificationSettings,
    lang,
    translations: notificationStrings
  });
</script>
