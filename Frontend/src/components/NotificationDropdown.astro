---
const user = {
  name: "Bonnie Green",
  email: "bonnie.green@example.com",
  avatar: "https://i.pravatar.cc/150?img=12"
};
---
<div class="relative">
  <!-- Botón Notificaciones -->
  <button
    id="notification-toggle"
    type="button"
    data-dropdown-toggle="notification-dropdown"
    class="p-2 text-gray-500 rounded-full shadow-sm transition hover:scale-105 hover:bg-gray-100 dark:text-gray-400 dark:hover:text-white dark:hover:bg-gray-700 focus:outline-none"
  >
    <span class="sr-only">View notifications</span>
    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
      <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z" />
    </svg>
  </button>

  <!-- Dropdown -->
  <div
    id="notification-dropdown"
    class="absolute right-0 top-12 z-50 hidden w-96 max-w-sm bg-white border border-gray-200 rounded-2xl shadow-2xl dark:bg-gray-800 dark:border-gray-700 transition-all duration-300 ring-1 ring-slate-100 dark:ring-white/10"
  >
    <!-- Encabezado -->
    <div class="px-6 pt-5 pb-4 text-base font-semibold text-gray-700 dark:text-gray-100 border-b border-gray-100 dark:border-gray-700">
      Notifications
    </div>

    <!-- Lista de notificaciones -->
    <div class="max-h-80 overflow-y-auto divide-y divide-gray-100 dark:divide-gray-700">
      <a href="#" class="flex items-start gap-4 px-6 py-5 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
        <div class="relative">
          <img
            class="w-12 h-12 rounded-full object-cover border-2 border-white dark:border-gray-600 shadow"
            src={user.avatar}
            alt="User avatar"
          />
          <span class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-[#F6B234] text-[#002E50] text-[10px] flex items-center justify-center rounded-full font-bold shadow-sm">!</span>
        </div>
        <div class="flex-1">
          <p class="text-sm font-semibold text-[#002E50] dark:text-white">
            {user.name}
          </p>
          <p class="text-sm text-gray-700 dark:text-gray-200">
            “Hey, what’s up? All set for the presentation?”
          </p>
          <span class="text-xs text-gray-500 dark:text-gray-400 mt-1 block">Just now</span>
        </div>
      </a>
    </div>

    <!-- Footer -->
    <a
      href="#"
      class="block text-center py-4 text-sm font-medium text-[#00538C] dark:text-[#F6B234] bg-gray-50 dark:bg-gray-800 rounded-b-2xl hover:underline transition"
    >
      View all notifications
    </a>
  </div>
</div>