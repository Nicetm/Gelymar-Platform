---
import { loadTranslations, getServerLang } from '../lib/i18n.js';

// Modal de chat para comunicación cliente-admin
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const apiPublic = import.meta.env.PUBLIC_API_URL;
const lang = getServerLang(Astro.cookies);

let t: any = {};
try {
  t = {
      messages: await loadTranslations(lang, 'messages'),
      comond: await loadTranslations(lang, 'comond')
    };
} catch (error) {
  console.warn('Error cargando traducciones:', error);
  t = {};
}
  
---

<!-- Modal de chat -->
<div id="chat-modal" class="fixed inset-0 z-50 hidden">
  <!-- Backdrop -->
  <div id="chat-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  
  <!-- Modal content -->
  <div class="absolute bottom-6 right-6 w-96 h-[500px] bg-white dark:bg-gray-800 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 flex flex-col">
    
    <!-- Header del chat -->
    <div class="flex items-center justify-between p-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-700 rounded-t-2xl">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <div>
          <h3 id="chat-admin-name" class="font-semibold text-sm text-gray-900 dark:text-white">{t.messages?.chat?.select_agent || "Seleccionar Agente"}</h3>
          <p id="chat-admin-status" class="text-xs text-gray-500 dark:text-gray-400 flex items-center gap-1">
            <span id="chat-admin-status-dot" class="inline-block w-2 h-2 rounded-full bg-gray-400"></span>
            <span id="chat-admin-status-text">{t.messages?.chat?.choose_agent || "Elige un agente para iniciar la conversación"}</span>
          </p>
        </div>
      </div>
      
      <!-- Botón cerrar -->
      <button id="close-chat-btn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    
    <!-- Pantalla de selección de administradores -->
    <div id="admin-selection" class="flex-1 p-4 overflow-y-auto">
      <div id="admin-list" class="space-y-2">
        <div class="text-center text-gray-500 dark:text-gray-400">
          <p>{t.chat?.loading_agents || "Cargando agentes..."}</p>
        </div>
      </div>
      
      <!-- Mensaje de protección de datos -->
      <div class="mt-8 p-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
        <div class="flex items-start gap-2">
          <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <div>
            <p class="text-xs text-blue-700 dark:text-blue-300 font-medium mb-1">{t.messages?.chat?.data_protection || "Protección de Datos"}</p>
            <p class="text-xs text-blue-600 dark:text-blue-400">{t.messages?.chat?.data_protection_message || "Todos los mensajes con nuestros agentes están encriptados para garantizar tu privacidad y seguridad."}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Área de mensajes -->
    <div id="chat-messages" class="flex-1 p-4 overflow-y-auto space-y-3 hidden">
      <div class="text-center text-gray-500 dark:text-gray-400">
        <p>Loading chat history...</p>
      </div>
      <!-- Los mensajes se cargarán dinámicamente aquí -->
    </div>


    <!-- Área de escritura -->
    <div id="chat-input-area" class="p-4 border-t border-gray-200 dark:border-gray-700 hidden">
      <div class="flex gap-2">
        <input 
          id="chat-input" 
          type="text" 
          placeholder={t.messages?.chat?.write_message || "Write your message..."}
          class="flex-1 px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
        <button 
          id="emoji-btn"
          type="button"
          class="px-3 py-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 transition-colors"
          title="Add emoji"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </button>
        <button 
          id="send-message-btn"
          class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          disabled
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>


<script
  type="module"
  define:vars={{ apiPublic, apiBase, lang, t }}
>
  import { initChatModal } from '/js/chat-modal.js';

  initChatModal({
    apiBase,
    apiPublic,
    lang,
    translations: t,
  });
</script>


<style>
  /* Scrollbar personalizado para el área de mensajes */
  #chat-messages::-webkit-scrollbar {
    width: 4px;
  }
  
  #chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }
  
  #chat-messages::-webkit-scrollbar-thumb {
    background: #d1d5db;
    border-radius: 2px;
  }
  
  #chat-messages::-webkit-scrollbar-thumb:hover {
    background: #9ca3af;
  }
  
  /* Animación de entrada del modal */
  #chat-modal:not(.hidden) {
    animation: slideIn 0.3s ease-out;
  }
  
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
