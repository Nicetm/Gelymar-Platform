---
import { loadTranslations } from '../lib/i18n.js';

import { PUBLIC_LANG, PUBLIC_API_URL, FILE_SERVER_URL } from '../app/constants.ts';

const lang = PUBLIC_LANG;
const t: any = {
  usermenu: await loadTranslations(lang, 'usermenu'),
};

const apiBase = PUBLIC_API_URL;       
const fileServer = FILE_SERVER_URL; 

// Token se manejará en el cliente para evitar problemas de conexión desde Docker

/** @type {import('../types/entities.js').Users | null} */
let user = null;


if (!user) {
  user = { full_name: 'User', email: 'user@example.com', role: 'guest', avatar: '' };
}

const avatarUrl = `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.full_name)}&backgroundColor=4b5563&fontColor=ffffff`;
---

<div class="relative flex items-center ml-3">
  <!-- Botón para abrir el dropdown -->
  <button
    id="user-toggle"
    type="button"
    data-dropdown-toggle="user-dropdown"
    class="flex items-center gap-2 px-2 py-2 rounded-lg transition hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none group"
  >
    <span class="sr-only">{t.usermenu.open_menu}</span>
    <img
      id="userAvatar"
      class="w-8 h-8 rounded-full border border-gray-300 dark:border-gray-600"
      src={avatarUrl}
      alt="user photo"
    />
    <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>

  <!-- Dropdown -->
  <div
    id="user-dropdown"
    class="absolute right-0 top-full mt-2 z-50 hidden w-64 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg transition-all duration-200"
  >
    <!-- Header con info del usuario -->
    <div class="px-4 py-3 border-b border-gray-100 dark:border-gray-700">
      <p id="userFullName" class="text-sm font-medium text-gray-900 dark:text-white">
        {user.full_name}
      </p>
      <p id="userEmail" class="text-sm text-gray-500 dark:text-gray-400 truncate">
        {user.email}
      </p>
      <span id="userRole" class="inline-block mt-1 px-2 py-0.5 text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded">
        {user.role}
      </span>
    </div>

    <!-- Botón de logout -->
    <div class="py-1">
      <button
        id="logoutButton"
        class="w-full text-left px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors duration-150 flex items-center gap-2"
      >
        <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
        </svg>
        <span>{t.usermenu.sign_out}</span>
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ apiBase, fileServer, lang }}>
  const API_BASE = apiBase;
  const FILE_SERVER = fileServer;
  const LANG = lang;


  /* ---------- Logout ---------- */
  document.getElementById('logoutButton')?.addEventListener('click', () => {
    try {
      // Logout local sin llamada al servidor
      localStorage.removeItem('token');
      localStorage.removeItem('userRole');
      localStorage.removeItem('userEmail');
      document.cookie = 'token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
      window.location.href = '/authentication/sign-in';
    } catch (err) {
      console.error('Error logging out:', err);
      // Fallback: redirigir directamente
      window.location.href = '/authentication/sign-in';
    }
  });

  /* ---------- Hidratación en cliente ---------- */
  document.addEventListener('DOMContentLoaded', async () => {
    const nameEl  = document.querySelector('#userFullName');
    const roleEl  = document.querySelector('#userRole');
    const emailEl = document.querySelector('#userEmail');
    /** @type {HTMLImageElement|null} */
    const avatarEl = document.querySelector('#userAvatar');

    if (!nameEl || !emailEl || !avatarEl) return;

    // Busca token en localStorage con distintos nombres
    let clientToken =
      localStorage.getItem('token') ||
      localStorage.getItem('accessToken') ||
      localStorage.getItem('jwt') ||
      null;

    // Si no está en localStorage, intenta leer cookies accesibles por JS
    if (!clientToken) {
      const match = document.cookie.match(/(?:^|; )(?:token|accessToken|jwt)=([^;]+)/);
      clientToken = match ? decodeURIComponent(match[1]) : null;
    }
    if (!clientToken) return;

    try {
      const res = await fetch(`${API_BASE}/api/auth/me`, {
        headers: clientToken ? { Authorization: `Bearer ${clientToken}` } : undefined
      });
      if (!res.ok) return;

      const u = await res.json();

      const fullName = u.full_name ?? 'User';
      const roleNameClient =
        u.role ??
        (u.role_id === 1 ? 'Admin'
         : u.role_id === 2 ? 'Client'
         : 'Guest');
      const email = u.email ?? '';

      // Actualizar elementos del dropdown
      nameEl.textContent = fullName;
      roleEl.textContent = roleNameClient;
      emailEl.textContent = email;

      // Actualizar avatar
      if (u.avatar_path) {
        const avatarUrl = `${FILE_SERVER}/${u.avatar_path}`;
        avatarEl.src = avatarUrl;
      } else if (u.full_name) {
        const fallbackUrl = `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(u.full_name)}&backgroundColor=4b5563&fontColor=ffffff`;
        avatarEl.src = fallbackUrl;
      }
    } catch (err) {
      console.error('Client-side user fetch failed:', err);
    }
  });


</script>
