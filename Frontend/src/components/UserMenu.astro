---
const user = {
  name: "Test User",
  email: "test.user@example.com",
  avatar: "https://i.pravatar.cc/150?img=12"
};
---
<div class="relative flex items-center ml-3">
  <!-- Botón -->
  <button
    id="user-toggle"
    type="button"
    data-dropdown-toggle="user-dropdown"
    class="flex text-sm rounded-full transition-all duration-200 ease-in-out hover:ring-2 hover:ring-[#F6B234] hover:scale-105 focus:outline-none"
  >
    <span class="sr-only">Open user menu</span>
    <img
      class="w-8 h-8 rounded-full border-2 border-gray-200 dark:border-gray-600"
      src={user.avatar}
      alt="user photo"
    />
  </button>

  <!-- Dropdown con estilo similar a notificaciones -->
  <div
    id="user-dropdown"
    class="absolute right-0 top-full mt-3 z-50 hidden w-64 max-w-sm bg-white border border-gray-200 rounded-2xl shadow-2xl dark:bg-gray-800 dark:border-gray-700 transition-all duration-300 ring-1 ring-slate-100 dark:ring-white/10"
  >
    <!-- Encabezado -->
    <div class="px-6 pt-5 pb-4 border-b border-gray-100 dark:border-gray-700">
      <p class="text-sm font-semibold text-gray-700 dark:text-white">{user.name}</p>
      <p class="text-sm text-gray-500 truncate dark:text-[#F6B234]">{user.email}</p>
    </div>

    <!-- Opciones -->
    <ul class="py-2 divide-y divide-gray-100 dark:divide-gray-700">
      <li>
        <a
          href="#"
          class="block px-6 py-3 text-sm text-gray-700 hover:bg-gray-50 dark:text-white dark:hover:bg-gray-700 transition"
        >
          Profile
        </a>
      </li>
      <li>
        <button
          type="button"
					id="logoutButton"
          class="w-full text-left px-6 py-3 text-sm text-red-600 hover:bg-red-50 dark:text-red-400 dark:hover:bg-gray-700 dark:hover:text-white transition"
        >
          Sign out
        </button>
      </li>
    </ul>
  </div>
</div>

<script>
  const logoutButton = document.getElementById('logoutButton');

  if (logoutButton) {
    logoutButton.addEventListener('click', async () => {
      try {
        await fetch('/api/auth/logout', {
          method: 'POST',
          credentials: 'include'
        });

        localStorage.removeItem('token');
        document.cookie = "token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";

        window.location.href = '/authentication/sign-in';
      } catch (error) {
        console.error('Error logging out:', error);
      }
    });
  }
</script>
