    transition: transform 0.2s ease, width 0.2s ease, bottom 0.2s ease, right 0.2s ease;
  }

  #admin-chat-panel.chat-minimized {
    width: 320px;
    height: auto;
    right: 1.5rem;
    left: auto;
    bottom: 1rem;
    transform: none;
    cursor: pointer;
    border-radius: 1rem;
  }

  #admin-chat-panel.chat-minimized #admin-chat-messages,
  #admin-chat-panel.chat-minimized .p-4.border-t {
    display: none;
  }

  #admin-chat-panel.chat-minimized #admin-chat-header {
    border-bottom: none;
    border-radius: 1rem;
  }

  /* Scrollbar personalizado para el área de mensajes */
  #admin-chat-messages::-webkit-scrollbar {
    width: 4px;
  }
  
  #admin-chat-messages::-webkit-scrollbar-track {
    background: transparent;
  }
  
  #admin-chat-messages::-webkit-scrollbar-thumb {
    background: #d1d5db;
    border-radius: 2px;
  }
  
  #admin-chat-messages::-webkit-scrollbar-thumb:hover {
    background: #9ca3af;
  }
</style>
