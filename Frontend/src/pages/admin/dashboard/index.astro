---
import LayoutSidebar from '../../../app/LayoutSidebarAdmin.astro'
import DashBoard from '../../../modules/DashBoard.astro';
import AuthGuard from '../../../components/AuthGuard.astro';

// Validación de rol en el servidor
import { validateRole } from '../../../lib/auth.js';
const redirect = await validateRole(Astro, 'admin');
if (redirect) return redirect;
---

<LayoutSidebar>
  <!-- 🔐 Protección de ruta (sólo admins) -->
  <AuthGuard role="admin" />
	<DashBoard />
</LayoutSidebar>
