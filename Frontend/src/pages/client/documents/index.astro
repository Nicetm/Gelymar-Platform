---
import LayoutSidebarClient from '../../../app/LayoutSidebarClient.astro';
import AuthGuard from '../../../components/AuthGuard.astro';
import OrdersGrid from '../../../modules/client/OrderGrid.astro';
import DocumentStats from '../../../modules/client/DocumentStats.astro';
import DocumentsSection from '../../../modules/client/DocumentsSection.astro';
import EmailModal from '../../../modules/client/EmailModal.astro';

// Validación de rol en el servidor
import { validateRole } from '../../../lib/auth.js';
const redirect = await validateRole(Astro, 'client');
if (redirect) return redirect;

// Configuración de API
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const token = Astro.cookies.get('token')?.value;

let orders = [];

try {
  // Obtener órdenes del cliente desde la API
  const response = await fetch(`${apiBase}/api/orders/client/dashboard`, {
    headers: { 
      'Content-Type': 'application/json',
      ...(token && { Authorization: `Bearer ${token}` })
    }
  });

  if (response.ok) {
    orders = await response.json();
  }
} catch (error) {
  orders = [];
}
---

<LayoutSidebarClient title="Documents - Client Panel">
  <AuthGuard role="client" />
  
  <div class="min-h-screen pt-5">
    <!-- Header -->
    <section class="bg-white dark:bg-gray-800 shadow-sm border-b border-gray-200 dark:border-gray-700">
      <div class="px-6 py-6 text-center">
        <div class="inline-flex items-center justify-center w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-full mb-3">
          <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Document Center</h1>
        <p class="text-base text-gray-600 dark:text-gray-400">
          Access and manage your shared documents
        </p>
      </div>
    </section>

    <!-- Contenido principal -->
    <div class="px-6 py-8 space-y-8">
      <!-- Loading state -->
      <div id="loading-state" class="text-center py-12">
        <div class="inline-flex items-center justify-center w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-full mb-4">
          <svg class="w-6 h-6 text-blue-600 dark:text-blue-400 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Cargando órdenes...</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Obteniendo información de la base de datos</p>
      </div>
      
      <!-- Selector de órdenes -->
      <div id="orders-section" class="hidden">
        <OrdersGrid {orders} />
      </div>

      <!-- Estadísticas + lista de documentos -->
      <DocumentStats />
      <DocumentsSection />
    </div>
  </div>

  <!-- Modal de reporte -->
  <EmailModal />

  <!-- Configuración para JavaScript -->
  <script define:vars={{ apiBase }}>
    window.apiBase = apiBase || 'http://localhost:3000';
  </script>

  <!-- Lógica -->
  <script type="module" src="/js/document-center.js"></script>
</LayoutSidebarClient>