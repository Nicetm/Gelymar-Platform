---
/* EmailModal.astro */
---

<div
  id="email-modal"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm h-full w-full hidden z-[9999999] transition-all duration-200 ease-out flex items-center justify-center p-2 sm:p-4"
>
  <div
    class="relative mx-auto p-0 border-0 w-full max-w-6xl transform transition-all duration-300 ease-out scale-95 opacity-0 translate-y-4"
  >
    <div
      class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl border border-gray-200 dark:border-gray-700 overflow-hidden max-h-[90vh] overflow-y-auto"
    >
      <!-- Header con gradiente -->
      <div
        class="bg-gradient-to-r from-blue-600 to-blue-700 dark:from-blue-700 dark:to-blue-800 px-4 sm:px-6 lg:px-10 py-4 lg:py-6"
      >
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <div class="p-3 bg-white/20 rounded-lg">
              <svg
                class="w-7 h-7 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                />
              </svg>
            </div>
            <div>
              <h3 class="text-2xl font-semibold text-white">
                Report Document Issue
              </h3>
              <p class="text-blue-100 text-sm mt-1">
                Notify about problems or specific details found
              </p>
            </div>
          </div>
          <button
            id="close-email-modal"
            class="text-white/80 hover:text-white transition-colors duration-200 p-3 rounded-lg hover:bg-white/10"
          >
            <svg
              class="w-7 h-7"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"
              />
            </svg>
          </button>
        </div>
      </div>

      <!-- Contenido del modal en layout horizontal -->
      <div class="p-4 sm:p-6 lg:p-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-8">
          <!-- Columna izquierda - Documento y problema -->
          <div class="space-y-6">
            <!-- Sección del documento -->
            <div
              class="bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-700 dark:to-gray-800 p-6 rounded-lg border border-gray-200 dark:border-gray-600"
            >
              <div class="flex items-center space-x-3 mb-4">
                <div class="p-2 bg-blue-100 dark:bg-blue-900/30 rounded-lg">
                  <svg
                    class="w-5 h-5 text-blue-600 dark:text-blue-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                    />
                  </svg>
                </div>
                <h4 class="text-lg font-semibold text-gray-900 dark:text-white">
                  Document in Question
                </h4>
              </div>
              <div id="document-details" class="space-y-3">
                <!-- Los detalles del documento se insertarán aquí -->
              </div>
            </div>

            <!-- Sección del problema -->
            <div class="space-y-6">
              <div id="issue-type-section">
                <label
                  class="block text-base font-medium text-gray-700 dark:text-gray-300 mb-3"
                  >Issue Type: <span class="text-red-500">*</span></label
                >
                <div class="grid grid-cols-2 gap-3">
                  <label
                    class="flex items-center p-4 border border-gray-200 dark:border-gray-600 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                  >
                    <input
                      type="radio"
                      name="issue-type"
                      value="error"
                      class="mr-3 text-blue-600 focus:ring-blue-500"
                      checked
                    />
                    <div>
                      <div class="font-medium text-gray-900 dark:text-white">
                        Error Found
                      </div>
                      <div class="text-sm text-gray-500 dark:text-gray-400">
                        Incorrect information or data
                      </div>
                    </div>
                  </label>
                  <label
                    class="flex items-center p-4 border border-gray-200 dark:border-gray-600 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                  >
                    <input
                      type="radio"
                      name="issue-type"
                      value="missing"
                      class="mr-3 text-blue-600 focus:ring-blue-500"
                    />
                    <div>
                      <div class="font-medium text-gray-900 dark:text-white">
                        Missing Information
                      </div>
                      <div class="text-sm text-gray-500 dark:text-gray-400">
                        Required data not present
                      </div>
                    </div>
                  </label>
                  <label
                    class="flex items-center p-4 border border-gray-200 dark:border-gray-600 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                  >
                    <input
                      type="radio"
                      name="issue-type"
                      value="format"
                      class="mr-3 text-blue-600 focus:ring-blue-500"
                    />
                    <div>
                      <div class="font-medium text-gray-900 dark:text-white">
                        Format Issue
                      </div>
                      <div class="text-sm text-gray-500 dark:text-gray-400">
                        Layout or presentation problem
                      </div>
                    </div>
                  </label>
                  <label
                    class="flex items-center p-4 border border-gray-200 dark:border-gray-600 rounded-lg cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                  >
                    <input
                      type="radio"
                      name="issue-type"
                      value="other"
                      class="mr-3 text-blue-600 focus:ring-blue-500"
                    />
                    <div>
                      <div class="font-medium text-gray-900 dark:text-white">
                        Other
                      </div>
                      <div class="text-sm text-gray-500 dark:text-gray-400">
                        Different concern
                      </div>
                    </div>
                  </label>
                </div>
              </div>

              <div id="priority-section">
                <label
                  class="block text-base font-medium text-gray-700 dark:text-gray-300 mb-3"
                  >Priority Level: <span class="text-red-500">*</span></label
                >
                <div class="flex space-x-3">
                  <label class="flex items-center">
                    <input
                      type="radio"
                      name="priority"
                      value="low"
                      class="mr-2 text-green-600 focus:ring-green-500"
                    />
                    <span
                      class="text-sm font-medium text-gray-700 dark:text-gray-300"
                      >Low</span
                    >
                  </label>
                  <label class="flex items-center">
                    <input
                      type="radio"
                      name="priority"
                      value="medium"
                      class="mr-2 text-yellow-600 focus:ring-yellow-500"
                      checked
                    />
                    <span
                      class="text-sm font-medium text-gray-700 dark:text-gray-300"
                      >Medium</span
                    >
                  </label>
                  <label class="flex items-center">
                    <input
                      type="radio"
                      name="priority"
                      value="high"
                      class="mr-2 text-red-600 focus:ring-red-500"
                    />
                    <span
                      class="text-sm font-medium text-gray-700 dark:text-gray-300"
                      >High</span
                    >
                  </label>
                </div>
              </div>

              <div>
                <label
                  class="block text-base font-medium text-gray-700 dark:text-gray-300 mb-3"
                  >Detailed Description: <span class="text-red-500">*</span></label
                >
                <div class="relative">
                  <textarea
                    id="issue-description"
                    rows="8"
                    class="w-full px-4 py-3 text-base border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:focus:ring-blue-400 dark:focus:border-blue-400 transition-all duration-200 resize-none"
                    placeholder="Describe the specific issue or concern you found in this document..."
                    required
                  ></textarea>
                </div>
                <div class="mt-2 text-xs text-gray-500 dark:text-gray-400">
                  <p>
                    <strong>Template:</strong> Feel free to modify this text or
                    write your own description.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Columna derecha - Contacto y archivos -->
          <div class="space-y-6">
            <!-- Información de contacto -->
            <div
              class="bg-gradient-to-r from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/20 p-6 rounded-lg border border-blue-200 dark:border-blue-700"
            >
              <div class="flex items-center space-x-3 mb-4">
                <div class="p-2 bg-blue-100 dark:bg-blue-900/30 rounded-lg">
                  <svg
                    class="w-5 h-5 text-blue-600 dark:text-blue-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    />
                  </svg>
                </div>
                <h4
                  class="text-lg font-semibold text-gray-900 dark:text-white"
                >
                  Contact Information
                </h4>
              </div>

              <div class="space-y-4">
                <div>
                  <label
                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                    >Your Name: <span class="text-red-500">*</span></label
                  >
                  <input
                    type="text"
                    id="contact-name"
                    class="w-full px-4 py-3 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:focus:ring-blue-400 dark:focus:border-blue-400 transition-all duration-200"
                    placeholder="Your full name"
                    required
                  />
                </div>

                <div>
                  <label
                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                    >Your Email: <span class="text-red-500">*</span></label
                  >
                  <input
                    type="email"
                    id="contact-email"
                    class="w-full px-4 py-3 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:focus:ring-blue-400 dark:focus:border-blue-400 transition-all duration-200"
                    placeholder="your.email@company.com"
                    required
                  />
                </div>

                <div>
                  <label
                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                    >Phone (Optional):</label
                  >
                  <input
                    type="tel"
                    id="contact-phone"
                    class="w-full px-4 py-3 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:focus:ring-blue-400 dark:focus:border-blue-400 transition-all duration-200"
                    placeholder="+1 (555) 123-4567"
                  />
                </div>
              </div>
            </div>

            <!-- Archivos adicionales -->
            <div
              class="bg-gradient-to-r from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20 p-6 rounded-lg border border-green-200 dark:border-green-700"
            >
              <div class="flex items-center space-x-3 mb-4">
                <div class="p-2 bg-green-100 dark:bg-green-900/30 rounded-lg">
                  <svg
                    class="w-5 h-5 text-green-600 dark:text-green-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                    />
                  </svg>
                </div>
                <h4
                  class="text-lg font-semibold text-gray-900 dark:text-white"
                >
                  Additional Files
                </h4>
              </div>

              <!-- Tabs -->
              <div class="mb-4">
                <div class="flex space-x-1 bg-gray-100 dark:bg-gray-700 rounded-lg p-1">
                  <button
                    type="button"
                    id="upload-tab"
                    class="flex-1 px-3 py-2 text-sm font-medium rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white shadow-sm transition-all duration-200"
                  >
                    Upload New Files
                  </button>
                  <button
                    type="button"
                    id="select-tab"
                    class="flex-1 px-3 py-2 text-sm font-medium rounded-md text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-all duration-200"
                  >
                    Select Existing Files
                  </button>
                </div>
              </div>

              <!-- Upload panel -->
              <div
                id="upload-panel"
                class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-4 text-center hover:border-blue-400 dark:hover:border-blue-500 transition-colors duration-200"
              >
                <div class="space-y-3">
                  <div class="flex justify-center">
                    <svg
                      class="w-8 h-8 text-gray-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
                      />
                    </svg>
                  </div>
                  <div>
                    <p
                      class="text-xs font-medium text-gray-700 dark:text-gray-300"
                    >
                      Drop files here or click to upload
                    </p>
                    <p
                      class="text-xs text-gray-500 dark:text-gray-400 mt-1"
                    >
                      PDF, DOC, JPG, PNG up to 10MB each
                    </p>
                  </div>
                  <input
                    type="file"
                    id="file-upload"
                    multiple
                    accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                    class="hidden"
                  />
                  <button
                    type="button"
                    id="upload-btn"
                    class="px-3 py-1 text-xs font-medium text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-700 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors duration-200"
                  >
                    Choose Files
                  </button>
                </div>
              </div>

              <!-- Select existing panel -->
              <div id="select-panel" class="hidden">
                <div class="space-y-3">
                  <div class="flex space-x-2">
                    <input
                      type="text"
                      id="file-search"
                      placeholder="Search files..."
                      class="flex-1 px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:focus:ring-blue-400 dark:focus:border-blue-400"
                    />
                    <select
                      id="file-category-filter"
                      class="px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:focus:ring-blue-400 dark:focus:border-blue-400"
                    >
                      <option value="">All</option>
                      <option value="Billing">Billing</option>
                      <option value="Contracts">Contracts</option>
                      <option value="Certificates">Certificates</option>
                      <option value="Manuals">Manuals</option>
                      <option value="Reports">Reports</option>
                      <option value="Policies">Policies</option>
                      <option value="Marketing">Marketing</option>
                      <option value="Training">Training</option>
                    </select>
                  </div>

                  <div
                    class="max-h-40 overflow-y-auto border border-gray-200 dark:border-gray-600 rounded-lg"
                  >
                    <div
                      id="available-files-list"
                      class="divide-y divide-gray-200 dark:divide-gray-600"
                    >
                      <!-- Los archivos disponibles se mostrarán aquí -->
                    </div>
                  </div>
                </div>
              </div>

              <!-- Selected files -->
              <div id="selected-files" class="mt-3 space-y-2 hidden">
                <h5
                  class="text-xs font-medium text-gray-700 dark:text-gray-300"
                >
                  Selected Files:
                </h5>
                <div id="files-list" class="space-y-2">
                  <!-- archivos seleccionados -->
                </div>
              </div>
            </div>

            <!-- Report Summary -->
            <div
              class="bg-gradient-to-r from-amber-50 to-amber-100 dark:from-amber-900/20 dark:to-amber-800/20 p-4 rounded-lg border border-amber-200 dark:border-amber-700"
            >
              <div class="flex items-center space-x-2 mb-3">
                <div class="p-1 bg-amber-100 dark:bg-amber-900/30 rounded-lg">
                  <svg
                    class="w-4 h-4 text-amber-600 dark:text-amber-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"
                    />
                  </svg>
                </div>
                <h4
                  class="text-sm font-semibold text-gray-900 dark:text-white"
                >
                  Report Summary
                </h4>
              </div>

              <div class="space-y-2 text-xs text-gray-600 dark:text-gray-400">
                <div class="flex items-center space-x-2">
                  <div class="w-1.5 h-1.5 bg-blue-500 rounded-full"></div>
                  <span>Document will be automatically attached</span>
                </div>
                <div class="flex items-center space-x-2">
                  <div class="w-1.5 h-1.5 bg-green-500 rounded-full"></div>
                  <span>Issue details will be formatted professionally</span>
                </div>
                <div class="flex items-center space-x-2">
                  <div class="w-1.5 h-1.5 bg-amber-500 rounded-full"></div>
                  <span>Response expected within 24-48 hours</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer -->
      <div
        class="px-4 sm:px-6 lg:px-10 py-6 lg:py-8 bg-gray-50 dark:bg-gray-700/50 border-t border-gray-200 dark:border-gray-600"
      >
        <div class="flex justify-between items-center">
          <div class="text-sm text-gray-500 dark:text-gray-400">
            <span class="font-medium">Note:</span> This report will be sent to
            the document administrator
          </div>
          <div class="flex space-x-4">
            <button
              id="cancel-email"
              class="px-8 py-3 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 hover:border-gray-400 dark:hover:border-gray-500 transition-all duration-200 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800"
            >
              Cancel
            </button>
            <button
              id="send-email"
              class="px-8 py-3 text-sm font-medium text-white bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 border border-transparent rounded-lg transition-all duration-200 focus:ring-2 focus:ring-red-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800 transform hover:scale-105 active:scale-95"
            >
              <div class="flex items-center space-x-2">
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"
                  />
                </svg>
                <span>Submit Report</span>
              </div>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>