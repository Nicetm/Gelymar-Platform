---
import LayoutSidebarClient from '../../../../app/LayoutSidebarClient.astro';
import AuthGuard from '../../../../components/AuthGuard.astro';

// Obtener el ID del documento desde los parámetros
const { id } = Astro.params;
---

<LayoutSidebarClient title="Document Details - Client Panel">
  <AuthGuard role="client" />
  
  <div class="min-h-screen pt-5">
    <!-- Header -->
    <section>
      <div class="px-6 py-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <div class="inline-flex items-center justify-center w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-full">
              <svg class="w-6 h-6 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Document Details</h1>
              <p class="text-base text-gray-600 dark:text-gray-400">Document ID: {id}</p>
            </div>
          </div>
          <a href="/client/documents" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">
            ← Back to Documents
          </a>
        </div>
      </div>
    </section>

    <!-- Contenido principal -->
    <div class="px-6 py-8">
      <div class="text-center py-12">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Document Details</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Details for document {id}</p>
      </div>
    </div>
  </div>
</LayoutSidebarClient>
