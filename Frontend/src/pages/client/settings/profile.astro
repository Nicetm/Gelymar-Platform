---
import LayoutSidebarClient from '../../../app/LayoutSidebarClient.astro';
import AuthGuard from '../../../components/AuthGuard.astro';

// Validación de rol en el servidor
import { validateRole } from '../../../lib/auth.js';
const redirect = await validateRole(Astro, 'client');
if (redirect) return redirect;
---

<LayoutSidebarClient title="Profile Settings - Client Panel">
  <AuthGuard role="client" />
  
  <div class="min-h-screen pt-5">
    <!-- Header -->
    <section>
      <div class="px-6 py-6 text-center">
        <div class="inline-flex items-center justify-center w-12 h-12 bg-indigo-100 dark:bg-indigo-900/30 rounded-full mb-3">
          <svg class="w-6 h-6 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Profile Settings</h1>
        <p class="text-base text-gray-600 dark:text-gray-400">
          Manage your profile information
        </p>
      </div>
    </section>

    <!-- Contenido principal -->
    <div class="px-6 py-8">
      <div class="text-center py-12">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Profile Settings</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">This section will allow you to manage your profile</p>
      </div>
    </div>
  </div>
</LayoutSidebarClient>
