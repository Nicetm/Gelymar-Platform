---
import LayoutSidebarClient from '../../../app/LayoutSidebarClient.astro';
import AuthGuard from '../../../components/AuthGuard.astro';

// Validación de rol en el servidor
import { validateRole } from '../../../lib/auth.js';
const redirect = await validateRole(Astro, 'client');
if (redirect) return redirect;
---

<LayoutSidebarClient title="Security Settings - Client Panel">
  <AuthGuard role="client" />
  
  <div class="min-h-screen pt-5">
    <!-- Header -->
    <section>
      <div class="px-6 py-6 text-center">
        <div class="inline-flex items-center justify-center w-12 h-12 bg-red-100 dark:bg-red-900/30 rounded-full mb-3">
          <svg class="w-6 h-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Security Settings</h1>
        <p class="text-base text-gray-600 dark:text-gray-400">
          Manage your account security
        </p>
      </div>
    </section>

    <!-- Contenido principal -->
    <div class="px-6 py-8">
      <div class="text-center py-12">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Security Settings</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">This section will allow you to manage your security settings</p>
      </div>
    </div>
  </div>
</LayoutSidebarClient>
