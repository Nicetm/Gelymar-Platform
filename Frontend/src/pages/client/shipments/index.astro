---
import LayoutSidebarClient from '../../../app/LayoutSidebarClient.astro';
import AuthGuard from '../../../components/AuthGuard.astro';

// Validación de rol en el servidor
import { validateRole } from '../../../lib/auth.js';
const redirect = await validateRole(Astro, 'client');
if (redirect) return redirect;
---

<LayoutSidebarClient title="Shipments - Client Panel">
  <AuthGuard role="client" />
  
  <div class="min-h-screen pt-5">
    <!-- Header -->
    <section class="bg-white dark:bg-gray-800 shadow-sm border-b border-gray-200 dark:border-gray-700">
      <div class="px-6 py-6 text-center">
        <div class="inline-flex items-center justify-center w-12 h-12 bg-purple-100 dark:bg-purple-900/30 rounded-full mb-3">
          <svg class="w-6 h-6 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Shipments</h1>
        <p class="text-base text-gray-600 dark:text-gray-400">
          Track your shipments and cargo
        </p>
      </div>
    </section>

    <!-- Contenido principal -->
    <div class="px-6 py-8">
      <div class="text-center py-12">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Shipments Management</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">This section will display your shipments</p>
      </div>
    </div>
  </div>
</LayoutSidebarClient>
