---
import LayoutSidebarClient from '../../../../app/LayoutSidebarClient.astro';
import AuthGuard from '../../../../components/AuthGuard.astro';

// Validación de rol en el servidor
import { validateRole } from '../../../../lib/auth.js';
const redirect = await validateRole(Astro, 'client');
if (redirect) return redirect;

// Obtener el ID de la orden desde los parámetros
const { id } = Astro.params;
---

<LayoutSidebarClient title="Order Details - Client Panel">
  <AuthGuard role="client" />
  
  <div class="min-h-screen pt-5">
    <!-- Header -->
    <section class="bg-white dark:bg-gray-800 shadow-sm border-b border-gray-200 dark:border-gray-700">
      <div class="px-6 py-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <div class="inline-flex items-center justify-center w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-full">
              <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Order Details</h1>
              <p class="text-base text-gray-600 dark:text-gray-400">Order ID: {id}</p>
            </div>
          </div>
          <a href="/client/orders" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">
            ← Back to Orders
          </a>
        </div>
      </div>
    </section>

    <!-- Contenido principal -->
    <div class="px-6 py-8">
      <div class="text-center py-12">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Order Details</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">Details for order {id}</p>
      </div>
    </div>
  </div>
</LayoutSidebarClient>
