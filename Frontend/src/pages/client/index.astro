---
// layout y logo
import LayoutSidebar from '../../app/LayoutSidebarClient.astro';
import AuthGuard from '../../components/AuthGuard.astro';

// Validación de rol en el servidor
import { validateRole } from '../../lib/auth.js';
const redirect = await validateRole(Astro, 'client');
if (redirect) return redirect;
---

<LayoutSidebar>
  <!-- 🔐 Protección de ruta (sólo clientes) -->
  <AuthGuard role="client" />

  <section class="relative min-h-screen w-full bg-transparent flex justify-center items-center pt-[10vh] pb-[6vh] font-sans z-10">
    <!-- Fondo solo para el panel principal -->
    <div class="absolute inset-0 w-full h-full z-0">
      <img src="/images/banner.jpg" alt="Banner" class="w-full h-full object-cover brightness-75 pt-5" />
      <div class="absolute inset-0 bg-slate-600 bg-opacity-10"></div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const userEmail = localStorage.getItem('userEmail');
      if (userEmail) {
        const welcomeEl = document.getElementById('welcome-client');
        if (welcomeEl) {
          welcomeEl.textContent = `Welcome, ${userEmail}`;
        }
      }
    });
  </script>

  <style>
    @keyframes fade-in-up {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .animate-fade-in-up {
      animation: fade-in-up 0.8s ease-out both;
    }
  </style>
</LayoutSidebar>
