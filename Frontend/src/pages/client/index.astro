---
// layout y logo
import LayoutSidebar from '../../app/LayoutSidebarClient.astro';
import AuthGuard from '../../components/AuthGuard.astro';

// Validación de rol en el servidor
import { validateRole } from '../../lib/auth.js';
const redirect = await validateRole(Astro, 'client');
if (redirect) return redirect;
---

<LayoutSidebar>
  <!-- 🔐 Protección de ruta (sólo clientes) -->
  <AuthGuard role="client" />

  <section class="relative min-h-screen w-full bg-transparent flex justify-center items-center pt-[10vh] pb-[6vh] font-sans z-10">
    <!-- Fondo solo para el panel principal -->
    <div class="absolute inset-0 w-full h-full z-0">
      <img src="/images/banner.jpg" alt="Banner" class="w-full h-full object-cover brightness-75 pt-5" />
      <div class="absolute inset-0 bg-slate-600 bg-opacity-10"></div>
    </div>
    <!-- Panel de contenido -->
    <div class="relative z-10 w-full max-w-6xl bg-white/90 dark:bg-gray-800/95 rounded-[1.5rem] shadow-[0_8px_30px_rgba(0,0,0,0.12)] border border-[#CED4DA] dark:border-gray-700 ring-1 ring-white/40 dark:ring-white/10 px-4 sm:px-6 md:px-10 py-10 md:py-14 animate-fade-in-up">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <!-- Left: Logo + Marca -->
        <div class="flex flex-col items-start gap-4 text-left pl-4 border-l-4 border-[#F6B234]">
          <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-white dark:bg-[#dcdcdc] shadow-md hover:shadow-xl duration-300 transform">
            <img src="/assets/gelymar.svg" alt="Gelymar Logo" class="h-[4.5rem] w-auto drop-shadow-lg" />
            <div class="relative -ml-0">
              <span class="text-[2.6rem] font-extrabold text-[#002E50] dark:text-[#002E50] leading-none">
                Gelymar
              </span>
            </div>
          </div>

          <h1 id="welcome-client" class="text-3xl md:text-4xl font-extrabold text-[#002E50] dark:text-white mt-1">
            Client Document Portal
          </h1>

          <p class="text-base sm:text-lg text-gray-700 dark:text-gray-300 max-w-md">
            Access all your export order documents securely and organized.
          </p>
        </div>

        <!-- Right: Descripción -->
        <div class="text-left">
          <p class="text-lg text-gray-900 dark:text-gray-300 mb-4">
            Export Order Documents
          </p>
          <p class="text-base text-gray-900 dark:text-gray-300 mb-6 leading-relaxed">
            Welcome to your personalized document portal. Here you can access all documents related to your export orders managed by <strong>Gelymar</strong>. Our platform provides secure and organized access to all documentation of your operations.
          </p>

          <ul class="text-gray-900 dark:text-gray-200 mb-8 space-y-3 list-disc list-inside">
            <li><strong>Order Reception</strong> - Confirmation and reception documents for your orders.</li>
            <li><strong>Shipping Notices</strong> - Notifications and shipping documents for your goods.</li>
            <li><strong>Export Documents</strong> - Certificates, invoices and customs documentation.</li>
            <li><strong>Certificates of Origin</strong> - Official documentation of goods origin.</li>
            <li><strong>Tracking Reports</strong> - Updated status of your shipments and orders.</li>
          </ul>

          <div class="flex gap-4 flex-wrap">
            <a href="/client/documents" class="bg-[#00538C] hover:bg-[#003F6B] text-white font-semibold px-6 py-3 rounded-xl shadow-lg transition duration-300">
              View Documents
            </a>
            <a href="/client/info/support" class="border border-[#00538C] text-[#00538C] dark:text-[#F6B234] hover:bg-blue-50 dark:hover:bg-slate-800 px-6 py-3 rounded-xl transition duration-300">
              Contact Support
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const userEmail = localStorage.getItem('userEmail');
      if (userEmail) {
        const welcomeEl = document.getElementById('welcome-client');
        if (welcomeEl) {
          welcomeEl.textContent = `Welcome, ${userEmail}`;
        }
      }
    });
  </script>

  <style>
    @keyframes fade-in-up {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .animate-fade-in-up {
      animation: fade-in-up 0.8s ease-out both;
    }
  </style>
</LayoutSidebar>
