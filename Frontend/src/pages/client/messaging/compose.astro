---
import LayoutSidebarClient from '../../../app/LayoutSidebarClient.astro';
import AuthGuard from '../../../components/AuthGuard.astro';
---

<LayoutSidebarClient title="Compose Message - Client Panel">
  <AuthGuard role="client" />
  
  <div class="min-h-screen pt-5">
    <!-- Header -->
    <section>
      <div class="px-6 py-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <div class="inline-flex items-center justify-center w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-full">
              <svg class="w-6 h-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Compose Message</h1>
              <p class="text-base text-gray-600 dark:text-gray-400">Send a new message</p>
            </div>
          </div>
          <a href="/client/messaging" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300">
            ← Back to Messages
          </a>
        </div>
      </div>
    </section>

    <!-- Contenido principal -->
    <div class="px-6 py-8">
      <div class="text-center py-12">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Compose Message</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">This section will allow you to compose messages</p>
      </div>
    </div>
  </div>
</LayoutSidebarClient>
