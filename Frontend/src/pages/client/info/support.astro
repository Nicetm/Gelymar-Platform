---
import LayoutSidebar from '../../../app/LayoutSidebarClient.astro';
---

<style>
  .card-hover {
    transition: all 0.3s ease-in-out;
  }

  .card-hover:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
  }

  .icon-pulse {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }
</style>

<LayoutSidebar>
  <section class="relative min-h-screen bg-gray-50 dark:bg-gray-900 font-sans">
    <!-- Main content -->
    <div class="relative z-10 flex flex-col justify-center items-center min-h-screen px-6 py-16">
      <!-- Header Section -->
      <div class="text-center mb-16">
        <!-- Logo and Brand -->
        <div class="flex items-center justify-center gap-6 mb-12">
          <img src="/gelymar.svg" alt="Gelymar Logo" class="w-20 h-20" />
          <div>
            <h1 class="text-5xl font-bold text-gray-900 dark:text-white">
              Gelymar Support
            </h1>
            <p class="text-lg text-gray-600 dark:text-gray-400">Professional Export Solutions</p>
          </div>
        </div>
        
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
          Need help with your export documents or have questions about your orders? 
          Our dedicated support team is here to assist you with all your export needs.
        </p>
      </div>

      <!-- Support Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl w-full mb-16">
        <!-- FAQ Card -->
        <div class="group card-hover bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700 shadow-lg">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-blue-900 rounded-lg flex items-center justify-center icon-pulse">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Frequently Asked Questions</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 mb-4 text-sm">
            Find answers to common questions about document access, export procedures, and platform usage.
          </p>
          <a href="/client/info/faqs" class="inline-flex items-center gap-2 text-blue-900 dark:text-blue-400 font-medium hover:text-blue-800 dark:hover:text-blue-300 transition-colors text-sm group">
            View FAQs
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <!-- Contact Card -->
        <div class="group card-hover bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700 shadow-lg">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-blue-900 rounded-lg flex items-center justify-center icon-pulse">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Direct Contact</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 mb-4 text-sm">
            Contact our export specialists for assistance and support.
          </p>
          <a href="mailto:support@gelymar.com" class="inline-flex items-center gap-2 text-blue-900 dark:text-blue-400 font-medium hover:text-blue-800 dark:hover:text-blue-300 transition-colors text-sm group">
            support@gelymar.com
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <!-- Documents Card -->
        <div class="group card-hover bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700 shadow-lg">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-blue-900 rounded-lg flex items-center justify-center icon-pulse">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Document Assistance</h3>
          </div>
          <p class="text-gray-600 dark:text-gray-300 mb-4 text-sm">
            Access your export documents and find the information you need.
          </p>
          <a href="/client/documents" class="inline-flex items-center gap-2 text-blue-900 dark:text-blue-400 font-medium hover:text-blue-800 dark:hover:text-blue-300 transition-colors text-sm group">
            Access Documents
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Contact Information Section -->
      <div class="w-full max-w-4xl">
        <div class="bg-white dark:bg-gray-800 rounded-lg p-8 border border-gray-200 dark:border-gray-700 shadow-lg">
          <div class="text-center mb-8">
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Contact Information</h3>
            <p class="text-gray-600 dark:text-gray-300 text-sm">Contact information for export operations support</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Phone -->
            <div class="text-center group">
              <div class="w-12 h-12 bg-gradient-to-br from-yellow-600 to-yellow-700 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300 shadow-lg icon-pulse">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-1 text-sm">Phone</h4>
              <p class="text-gray-600 dark:text-gray-400 text-sm">+56 2 2345 6789</p>
            </div>

            <!-- Email -->
            <div class="text-center group">
              <div class="w-12 h-12 bg-gradient-to-br from-yellow-600 to-yellow-700 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300 shadow-lg icon-pulse">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-1 text-sm">Email</h4>
              <p class="text-gray-600 dark:text-gray-400 text-sm">support@gelymar.com</p>
            </div>

            <!-- Hours -->
            <div class="text-center group">
              <div class="w-12 h-12 bg-gradient-to-br from-yellow-600 to-yellow-700 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300 shadow-lg icon-pulse">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-1 text-sm">Hours</h4>
              <p class="text-gray-600 dark:text-gray-400 text-sm">Mon-Fri 8:00 AM - 6:00 PM (CLT)</p>
            </div>

            <!-- Response -->
            <div class="text-center group">
              <div class="w-12 h-12 bg-gradient-to-br from-yellow-600 to-yellow-700 rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-300 shadow-lg icon-pulse">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
              </div>
              <h4 class="font-medium text-gray-900 dark:text-white mb-1 text-sm">Response</h4>
              <p class="text-gray-600 dark:text-gray-400 text-sm">Within 24 hours</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</LayoutSidebar>