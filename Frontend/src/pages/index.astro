---
// Validar rol del usuario y redirigir según corresponda
const token = Astro.cookies.get('token')?.value;

if (token) {
  try {
    const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
    const response = await fetch(`${apiBase}/api/auth/me`, {
      headers: { Authorization: `Bearer ${token}` }
    });
    
    if (response.ok) {
      const user = await response.json();
      const userRole = user.role || (user.role_id === 1 ? 'admin' : 'client');
      
      // User authenticated in index
      
      // Redirigir según el rol del usuario usando función centralizada
      if (userRole === 'admin') {
        return Astro.redirect('/admin');
      } else if (userRole === 'client') {
        return Astro.redirect('/client');
      }
    }
  } catch (error) {
    // Error validando rol en index
  }
}

// Si no hay token o hay error, redirigir al login
return Astro.redirect('/authentication/sign-in');
---

<html>
  <head>
    <meta http-equiv="refresh" content="0; URL='/authentication/sign-in'" />
  </head>
  <body></body>
</html>
