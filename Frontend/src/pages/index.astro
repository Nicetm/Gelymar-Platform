---
// layout y logo
import LayoutSidebar from '../app/LayoutSidebar.astro';
import GelymarLogo from '../assets/gelymar.svg';
---

<LayoutSidebar>
  	<section class="relative min-h-[85vh] w-full overflow-hidden text-center bg-transparent flex flex-col justify-center pt-[14vh] pb-[6vh] font-sans">

		<div class="absolute inset-0 z-0 transform -translate-y-56">
		<img
			src="/images/2.jpg"
			alt="Fondo marítimo"
			class="w-full h-full object-cover brightness-75"
		/>
		<div class="absolute inset-0 bg-slate-600 bg-opacity-10"></div>
		</div>

		<!-- 🌊 OLA 1 - Fondo más lejano (animación fuerte) -->
		<div class="absolute inset-x-0 bottom-0 z-0 pointer-events-none">
		<svg class="w-full h-[24rem]" viewBox="0 0 1440 320" preserveAspectRatio="none">
			<defs>
			<linearGradient id="waveGradient1" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0%" stop-color="#4B6D89" stop-opacity="0.9" />
			</linearGradient>
			</defs>
			<path fill="url(#waveGradient1)">
			<animate attributeName="d" dur="10s" repeatCount="indefinite"
				values="
				M0,60L80,70C160,90,320,100,480,90C640,80,800,70,960,80C1120,90,1280,95,1360,90L1440,85V320H0Z;
				M0,30L80,40C160,60,320,75,480,70C640,65,800,85,960,90C1120,95,1280,80,1360,60L1440,50V320H0Z;
				M0,60L80,70C160,90,320,100,480,90C640,80,800,70,960,80C1120,90,1280,95,1360,90L1440,85V320H0Z
				"
			/>
			</path>
		</svg>
		</div>

		<!-- 🌊 OLA 2 - Frontal más clara (más baja y suave) -->
		<div class="absolute inset-x-0 bottom-0 z-20 pointer-events-none">
		<svg class="w-full h-[26rem]" viewBox="0 0 1440 320" preserveAspectRatio="none">
			<defs>
			<linearGradient id="waveGradient2" x1="0" y1="0" x2="0" y2="1">
				<stop offset="0%" stop-color="#4B6D89" stop-opacity="0.9" />
				<stop offset="100%" stop-color="#4B6D89" stop-opacity="0.4" />
			</linearGradient>
			</defs>
			<path
			fill="url(#waveGradient2)"
			d="M0,100 C200,120 600,130 900,120 C1200,110 1400,100 1440,95 V320 H0 Z"
			style="filter: blur(4px);"
			/>
		</svg>
		</div>

		<!-- 🌊 OLA 3 - Línea base para cerrar fondo -->
		<div class="absolute inset-x-0 bottom-0 z-20 pointer-events-none">
