---
import { inferUserRole } from '../lib/roles.ts';

const token = Astro.cookies.get('token')?.value;

if (token) {
  try {
    const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
    const response = await fetch(`${apiBase}/api/auth/me`, {
      headers: { Authorization: `Bearer ${token}` }
    });

    if (response.ok) {
      const user = await response.json();
      const userRole = inferUserRole(user);

      // Redirigir segun el rol del usuario usando funcion centralizada
      if (userRole === 'admin') {
        return Astro.redirect('/admin');
      } else if (userRole === 'seller') {
        return Astro.redirect((() => {
          const rawUrl = import.meta.env.PUBLIC_SELLER_APP_URL || '/seller';
          try {
            const parsedUrl = new URL(rawUrl, 'http://localhost');
            return parsedUrl.pathname || '/seller';
          } catch {
            return rawUrl.startsWith('/') ? rawUrl : '/seller';
          }
        })());
      } else if (userRole === 'client') {
        return Astro.redirect('/client');
      }
    }
  } catch (error) {
    // Error validando rol en index
  }
}

// Si no hay token o hay error, redirigir al login
return Astro.redirect('/authentication/sign-in');
---

<html>
  <head>
    <meta http-equiv="refresh" content="0; URL='/authentication/sign-in'" />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap');
    </style>
  </head>
  <body class="font-sans"></body>
</html>
