  class="fixed top-0 left-0 z-20 flex-col flex-shrink-0 hidden w-56 h-full pt-20 font-normal lg:flex transition-width bg-white border-r border-gray-200 dark:bg-gray-800 dark:border-gray-700 -px-2"
  aria-label="Sidebar"
>
  <!-- Scrollable content -->
  <div
    class="flex-1 px-3 overflow-y-auto scrollbar scrollbar-w-2 scrollbar-thumb-rounded-md scrollbar-thumb-slate-200 scrollbar-track-gray-400 dark:scrollbar-thumb-slate-900 dark:scrollbar-track-gray-800"
  >
    <!-- Admin Panel -->
    <div class="mt-4 mb-6 mx-2">
      <div class="bg-gray-50 dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
        <div class="flex items-center justify-center gap-2 mb-2">
          <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Admin Panel</span>
        </div>
        <div class="text-center">
          <div class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{user?.full_name || 'Admin'}</div>
          <div class="flex items-center justify-center gap-2 mb-1">
            <span class="text-xs font-medium text-blue-700 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/30 px-2 py-1 rounded-full border border-blue-200 dark:border-blue-800">{userRole}</span>
          </div>
          <span class="text-xs text-gray-500 dark:text-gray-400">Active Session</span>
