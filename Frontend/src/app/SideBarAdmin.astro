---
import { loadTranslations, getServerLang } from '../lib/i18n.js';

const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const clientApiBase = import.meta.env.PUBLIC_API_URL; // Para JavaScript del cliente
const fileServer = import.meta.env.PUBLIC_FILE_SERVER_URL;
const lang       = getServerLang(Astro.cookies);   // idioma dinámico

const t: any = {
  sidebar        : await loadTranslations(lang, 'sidebar'),
  admin_settings : await loadTranslations(lang, 'admin_settings'),
};

// ── Datos del usuario autenticado ───────────────────────────────────────────────
const token =
  Astro.cookies.get('token')?.value ??
  Astro.cookies.get('accessToken')?.value ??
  Astro.cookies.get('jwt')?.value ??
  null;

/** @type {import('../types/entities.js').Users | null} */
let user = null;

try {
  // En SSR (Node), 'credentials' no es soportado por los tipos de fetch, y las cookies httpOnly
  // no se envían automáticamente. Solo usamos el header Authorization si tenemos token.
  if (token) {
    const data = await fetch(`${apiBase}/api/auth/me`, {
      headers: { Authorization: `Bearer ${token}` }
    }).then(r => (r.ok ? r.json() : null));
    user = Array.isArray(data) ? data[0] ?? null : data;
    if (user && !user.role && user.role_id !== undefined) {
      user.role = user.role_id === 1 ? 'admin'
                : user.role_id === 2 ? 'client'
                : String(user.role_id);
    }
  }
} catch (err) {
  console.error('Error fetching user (SSR):', err);
}

if (!user) {
  user = { full_name: 'Admin', email: 'admin@example.com', role: 'admin', avatar: '' };
}

// Convertir role a nombre capitalizado para mostrar
const userRole = user.role === 'admin' ? 'Admin' 
               : user.role === 'client' ? 'Client' 
               : user.role === 'guest' ? 'Guest'
               : 'User';

// ── Avatares por defecto ───────────────────────────────────────────────────────
const avatarUrl = user.avatar
  ? (user.avatar.startsWith('http') ? user.avatar : `${fileServer}/${user.avatar}`)
  // Fallback: avatar con iniciales (modo claro)
  : `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.full_name)}&backgroundColor=4b5563&fontColor=ffffff`;

let avatarLightSrc = avatarUrl;
let avatarDarkSrc  = user.avatar 
  ? avatarUrl 
  : `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.full_name)}&backgroundColor=1e293b&fontColor=ffffff`;
---

<style is:global>
  /* Fondo sólido y sombra */
  #sidebar {
    @apply bg-white dark:bg-gray-800 border-r border-gray-300 dark:border-gray-700 shadow-2xl transition-all duration-500;
  }
  /* Hover animado y barra de acento */
  .sidebar-link {
    @apply flex items-center gap-2 p-2 px-4 text-base rounded-lg border-transparent transition-all duration-200 ease-out relative;
    @apply text-black hover:bg-gray-300 dark:text-gray-200 dark:hover:bg-gray-700;
    overflow: hidden;
  }

  .sidebar-link.active::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: #6b7280;
    border-radius: 0;
    transition: background 0.3s;
  }
  .sidebar-link i {
    @apply w-6 h-6 text-gray-700 dark:text-gray-400 transition-colors duration-200;
  }

  .sidebar-link.active {
    @apply bg-gray-100 border-gray-400 text-gray-800 dark:bg-gray-700 dark:border-gray-500 dark:text-gray-200;
    box-shadow: 0 2px 8px 0 rgba(107, 114, 128, 0.2);
  }

  /* Estilos para el contenedor del ícono cuando está activo */
  .sidebar-link.active .icon-container {
    @apply bg-gray-300 dark:bg-gray-600 shadow-md;
  }

  /* Estilos para el texto cuando está activo */
  .sidebar-link.active .nav-text {
    @apply text-gray-800 dark:text-gray-200 font-semibold;
  }

  /* Estilos para el ícono cuando está activo */
  .sidebar-link.active .icon-container i {
    @apply text-gray-700 dark:text-gray-300;
  }

  /* Estilos específicos para el botón de soporte cuando está activo */
  .support-link.active {
    transform: scale(1.05);
  }
  
  .support-link.active > div {
    @apply bg-gradient-to-br from-green-100 to-blue-100 dark:from-green-800/40 dark:to-blue-800/40;
    @apply border-green-300 dark:border-green-600;
    @apply ring-2 ring-green-400/50 dark:ring-green-500/50;
    @apply shadow-lg;
  }
  
  .support-link.active span:last-child {
    @apply text-green-800 dark:text-green-200 font-semibold;
  }
  
  /* Transición suave para el sidebar */
  #sidebar, .sidebar-link, .sidebar-link i {
    transition: all 0.3s cubic-bezier(.4,0,.2,1);
  }

  /* Animación para el dropdown de idioma */
  #language-dropdown {
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.2s ease-out;
  }
  
  #language-dropdown:not(.hidden) {
    opacity: 1;
    transform: translateY(0);
  }
  
  /* Rotar chevron cuando dropdown está abierto */
  button[data-dropdown-toggle="language-dropdown"][aria-expanded="true"] i[data-lucide="chevron-up"] {
    transform: rotate(180deg);
  }
</style>
---

<!-- Carga Lucide diferido y renderiza íconos al terminar -->
<script src="https://unpkg.com/lucide@latest" defer onload="window.lucide?.createIcons?.()"></script>

<aside
  id="sidebar"
  class="fixed top-0 left-0 z-20 flex-col flex-shrink-0 hidden w-56 h-full pt-20 font-normal lg:flex transition-width bg-white border-r border-gray-200 dark:bg-gray-800 dark:border-gray-700 -px-2"
  aria-label="Sidebar"
  data-api-base={apiBase}
  data-file-server={fileServer}
>
  <!-- Scrollable content -->
  <div
    class="flex-1 px-3 overflow-y-auto scrollbar scrollbar-w-2 scrollbar-thumb-rounded-md scrollbar-thumb-slate-200 scrollbar-track-gray-400 dark:scrollbar-thumb-slate-900 dark:scrollbar-track-gray-800"
  >
    <!-- Admin Panel -->
    <div class="mt-4 mb-6 mx-2">
      <div class="bg-gray-50 dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
        <div class="flex items-center justify-center gap-2 mb-2">
          <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
          <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Admin Panel</span>
        </div>
        <div class="text-center">
          <div class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{user?.full_name || 'Admin'}</div>
          <div class="flex items-center justify-center gap-2 mb-1">
            <span class="text-xs font-medium text-blue-700 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/30 px-2 py-1 rounded-full border border-blue-200 dark:border-blue-800">{userRole}</span>
          </div>
          <span class="text-xs text-gray-500 dark:text-gray-400">Active Session</span>
        </div>
      </div>
    </div>
    
    <!-- Divider -->
    <hr class="my-4 border-gray-300 dark:border-gray-600" />
    
    <div class="space-y-3">
      <!-- dashboard -->
      <a
        href="/admin/dashboard"
        class="sidebar-link group flex items-center gap-3 p-3 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 border-transparent hover:border-gray-400 dark:hover:border-gray-500"
      >
        <div class="icon-container w-8 h-8 bg-gray-200 dark:bg-gray-600 rounded-lg flex items-center justify-center shadow-sm group-hover:shadow-md transition-all duration-200">
          <i data-lucide="layout-dashboard" class="w-4 h-4 text-gray-600 dark:text-gray-300"></i>
        </div>
        <span class="nav-text font-medium text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors duration-200">
          {t.sidebar.dashboard}
        </span>
      </a>

      <!-- clients -->
      <a
        href="/admin/clients"
        class="sidebar-link group flex items-center gap-3 p-3 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 border-transparent hover:border-gray-400 dark:hover:border-gray-500"
      >
        <div class="icon-container w-8 h-8 bg-gray-200 dark:bg-gray-600 rounded-lg flex items-center justify-center shadow-sm group-hover:shadow-md transition-all duration-200">
          <i data-lucide="briefcase" class="w-4 h-4 text-gray-600 dark:text-gray-300"></i>
        </div>
        <span class="nav-text font-medium text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors duration-200">
          {t.sidebar.customers}
        </span>
      </a>

      <!-- orders -->
      <a
        href="/admin/orders"
        class="sidebar-link group flex items-center gap-3 p-3 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 border-transparent hover:border-gray-400 dark:hover:border-gray-500"
      >
        <div class="icon-container w-8 h-8 bg-gray-200 dark:bg-gray-600 rounded-lg flex items-center justify-center shadow-sm group-hover:shadow-md transition-all duration-200">
          <i data-lucide="file-text" class="w-4 h-4 text-gray-600 dark:text-gray-300"></i>
        </div>
        <span class="nav-text font-medium text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors duration-200">
          {t.sidebar.orders}
        </span>
      </a>

      <!-- messaging -->
      <a
        href="/admin/messaging"
        class="sidebar-link group flex items-center gap-3 p-3 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 border-transparent hover:border-gray-400 dark:hover:border-gray-500"
      >
        <div class="icon-container w-8 h-8 bg-gray-200 dark:bg-gray-600 rounded-lg flex items-center justify-center shadow-sm group-hover:shadow-md transition-all duration-200">
          <i data-lucide="message-circle" class="w-4 h-4 text-gray-600 dark:text-gray-300"></i>
        </div>
        <span class="nav-text font-medium text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors duration-200">
          {t.sidebar.messaging}
        </span>
      </a>

      <!-- shipments -->
      <a
        href="/admin/shipments"
        class="sidebar-link group flex items-center gap-3 p-3 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-all duration-200 border-transparent hover:border-gray-400 dark:hover:border-gray-500"
      >
        <div class="icon-container w-8 h-8 bg-gray-200 dark:bg-gray-600 rounded-lg flex items-center justify-center shadow-sm group-hover:shadow-md transition-all duration-200">
          <i data-lucide="ship" class="w-4 h-4 text-gray-600 dark:text-gray-300"></i>
        </div>
        <span class="nav-text font-medium text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors duration-200">
          {t.sidebar.shipments}
        </span>
      </a>
    </div>
  </div>

  <!-- Footer: settings + language -->
  <div
    class="absolute bottom-0 left-0 w-full p-3 bg-white border-t border-gray-200 flex gap-2 dark:bg-gray-800 dark:border-gray-700"
  >
    <!-- Botón de configuración que abre modal -->
    <a
      href="#"
      id="openAdminSettings"
      class="flex-1 bg-gray-50 dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-2 hover:shadow-md hover:scale-[1.02] transition-all duration-200 group"
    >
      <div class="flex items-center justify-center gap-1">
        <div class="w-5 h-5 bg-gray-200 dark:bg-gray-600 rounded-lg flex items-center justify-center group-hover:bg-gray-300 dark:group-hover:bg-gray-500 transition-colors duration-200">
          <i data-lucide="user-cog" class="w-3 h-3 text-gray-600 dark:text-gray-300"></i>
        </div>
        <span class="text-xs font-medium text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white transition-colors duration-200">Settings</span>
      </div>
    </a>

    <!-- Idioma -->
    <div class="relative flex-1">
      <button
        type="button"
        data-dropdown-toggle="language-dropdown"
        class="w-full bg-gray-50 dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-2 hover:shadow-md hover:scale-[1.02] transition-all duration-200"
        id="currentLangBtn"
      >
        <div class="flex items-center justify-center gap-1">
          <img id="currentLangFlag" src="https://flagcdn.com/w20/us.png" alt="US Flag" class="w-4 h-3 rounded-sm">
          <span id="currentLangText" class="text-xs font-medium text-gray-700 dark:text-gray-300">EN</span>
          <i data-lucide="chevron-up" class="w-3 h-3 text-gray-500 transform transition-transform duration-200"></i>
        </div>
      </button>
      <div
        id="language-dropdown"
        class="absolute bottom-14 left-0 right-0 z-50 hidden bg-gray-50 dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 transition-all duration-200 ease-out"
      >
        <div class="flex p-2 gap-1">
          <a
            href="#"
            data-lang="en"
            class="language-option flex-1 flex items-center justify-center gap-1 px-2 py-2 text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white rounded-lg transition-all duration-200"
          >
            <img src="https://flagcdn.com/w20/us.png" alt="US Flag" class="w-4 h-3 rounded-sm"> EN
          </a>
          <a
            href="#"
            data-lang="es"
            class="language-option flex-1 flex items-center justify-center gap-1 px-2 py-2 text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white rounded-lg transition-all duration-200"
          >
            <img src="https://flagcdn.com/w20/cl.png" alt="Chile Flag" class="w-4 h-3 rounded-sm"> ES
          </a>
        </div>
      </div>
    </div>
  </div>
</aside>

<!-- MODAL DE CONFIGURACIÓN DE ADMINISTRADOR -->
<div
  id="adminSettingsModal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 flex backdrop-blur-sm opacity-0 transition-opacity duration-500"
>
  <div
    class="modal-card bg-white/95 dark:bg-gray-800/95 rounded-2xl p-8 w-full max-w-lg relative shadow-2xl ring-1 ring-gray-200 dark:ring-white/10 transform opacity-0 scale-90 translate-y-6 transition-all duration-500 ease-[cubic-bezier(.22,1,.36,1)]"
  >
    <button
      id="closeAdminSettings"
      class="absolute top-4 right-4 text-gray-500 hover:text-red-600 transition"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="flex items-center gap-3 mb-6">
      <i data-lucide="shield-check" class="w-6 h-6 text-blue-600"></i>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{t.admin_settings.title}</h2>
    </div>

    <form id="adminSettingsForm" class="space-y-5">
      <!-- Foto / Avatar -->
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 relative">
          <!-- Modo claro -->
          <img id="adminAvatarLight" class="w-16 h-16 rounded-full object-contain dark:hidden"
               src={avatarLightSrc} alt="Avatar administrador">
          <!-- Modo oscuro -->
          <img id="adminAvatarDark"  class="w-16 h-16 rounded-full object-contain hidden dark:inline"
               src={avatarDarkSrc}  alt="Avatar administrador">
        </div>

        <label class="cursor-pointer px-3 py-2 text-sm bg-gray-100 border border-gray-300 rounded-lg hover:bg-gray-200 transition dark:bg-gray-700 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-gray-600">
          <input id="adminAvatarInput" type="file" accept="image/*" class="hidden" />
          {t.admin_settings.change_photo}
        </label>
      </div>

      <!-- Nombre -->
      <div>
        <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">
          <i data-lucide="user" class="w-4 h-4 inline mr-1.5"></i>
          {t.admin_settings.full_name}
        </label>
        <input
          id="adminNameInput"
          type="text"
          placeholder={t.admin_settings.placeholder_full_name}
          class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white dark:border-gray-600"
          value={user?.full_name ?? ''}
        />
      </div>

      <!-- Email (solo lectura) -->
      <div>
        <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">
          <i data-lucide="mail" class="w-4 h-4 inline mr-1.5"></i>
          {t.admin_settings.corporate_email}
        </label>
        <input
          id="adminEmailInput"
          type="email"
          readonly
          class="w-full p-3 border bg-gray-100 text-gray-500 rounded-lg cursor-not-allowed dark:bg-gray-700 dark:text-gray-400 dark:border-gray-600"
          value={user?.email ?? ''}
        />
        <p class="text-xs text-gray-500 mt-1">{t.admin_settings.email_cannot_be_changed}</p>
      </div>

      <!-- Teléfono -->
      <div>
        <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">
          <i data-lucide="phone" class="w-4 h-4 inline mr-1.5"></i>
          {t.admin_settings.contact_phone}
        </label>
        <input
          id="adminPhoneInput"
          type="tel"
          placeholder="+56 9 1234 5678"
          class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white dark:border-gray-600"
          value={user?.phone ?? ''}
        />
      </div>

      <!-- Botones -->
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" id="cancelAdminEdit"
          class="px-4 py-2 bg-gray-200/70 rounded-lg hover:bg-gray-300 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600">
          {t.admin_settings.cancel}
        </button>
        <button type="submit" id="saveAdminChanges"
          class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center gap-2">
          <i data-lucide="save" class="w-4 h-4"></i> {t.admin_settings.save_changes}
        </button>
      </div>
    </form>
  </div>
</div>
<!-- Backdrop móvil -->
<div
  class="fixed inset-0 z-10 hidden bg-gray-900/50 dark:bg-gray-900/90"
  id="sidebarBackdrop"
></div>

<!-- SCRIPTS -->
<script type="module" define:vars={{ apiBase, clientApiBase, fileServer, t, token, lang }}>
  import { initSidebarAdmin } from '/js/sidebar-admin.js';
  
  // Inicializar el sidebar admin con la configuración
  initSidebarAdmin({ apiBase, clientApiBase, fileServer, t, token, lang });
</script>
