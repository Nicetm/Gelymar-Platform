<!-- MODAL DE CONFIGURACIÓN DE ADMINISTRADOR -->
<div
  id="adminSettingsModal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 flex backdrop-blur-sm opacity-0 transition-opacity duration-500"
>
  <div
    class="modal-card bg-white/95 dark:bg-gray-800/95 rounded-2xl p-8 w-full max-w-lg relative shadow-2xl ring-1 ring-gray-200 dark:ring-white/10 transform opacity-0 scale-90 translate-y-6 transition-all duration-500 ease-[cubic-bezier(.22,1,.36,1)]"
  >
    <button
      id="closeAdminSettings"
      class="absolute top-4 right-4 text-gray-500 hover:text-red-600 transition"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="flex items-center gap-3 mb-6">
      <i data-lucide="shield-check" class="w-6 h-6 text-blue-600"></i>
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{t.admin_settings.title}</h2>
    </div>

    <form id="adminSettingsForm" class="space-y-5">
      <!-- Foto / Avatar -->
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 relative">
          <!-- Modo claro -->
          <img id="adminAvatarLight" class="w-16 h-16 rounded-full object-contain dark:hidden"
               src={avatarLightSrc} alt="Avatar administrador">
          <!-- Modo oscuro -->
          <img id="adminAvatarDark"  class="w-16 h-16 rounded-full object-contain hidden dark:inline"
               src={avatarDarkSrc}  alt="Avatar administrador">
        </div>

        <label class="cursor-pointer px-3 py-2 text-sm bg-gray-100 border border-gray-300 rounded-lg hover:bg-gray-200 transition dark:bg-gray-700 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-gray-600">
          <input id="adminAvatarInput" type="file" accept="image/*" class="hidden" />
          {t.admin_settings.change_photo}
        </label>
      </div>

      <!-- Nombre -->
      <div>
        <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">
          <i data-lucide="user" class="w-4 h-4 inline mr-1.5"></i>
          {t.admin_settings.full_name}
        </label>
        <input
          id="adminNameInput"
          type="text"
          placeholder={t.admin_settings.placeholder_full_name}
          class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white dark:border-gray-600"
          value={user?.full_name ?? ''}
        />
      </div>

      <!-- Email (solo lectura) -->
      <div>
        <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">
          <i data-lucide="mail" class="w-4 h-4 inline mr-1.5"></i>
          {t.admin_settings.corporate_email}
        </label>
        <input
          id="adminEmailInput"
          type="email"
          readonly
          class="w-full p-3 border bg-gray-100 text-gray-500 rounded-lg cursor-not-allowed dark:bg-gray-700 dark:text-gray-400 dark:border-gray-600"
          value={user?.email ?? ''}
        />
        <p class="text-xs text-gray-500 mt-1">{t.admin_settings.email_cannot_be_changed}</p>
      </div>

      <!-- Teléfono -->
      <div>
        <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">
          <i data-lucide="phone" class="w-4 h-4 inline mr-1.5"></i>
          {t.admin_settings.contact_phone}
        </label>
        <input
          id="adminPhoneInput"
          type="tel"
          placeholder="+56 9 1234 5678"
          class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-700 dark:text-white dark:border-gray-600"
          value={user?.phone ?? ''}
        />
      </div>

      <!-- Botones -->
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" id="cancelAdminEdit"
          class="px-4 py-2 bg-gray-200/70 rounded-lg hover:bg-gray-300 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600">
          {t.admin_settings.cancel}
        </button>
        <button type="submit" id="saveAdminChanges"
          class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center gap-2">
          <i data-lucide="save" class="w-4 h-4"></i> {t.admin_settings.save_changes}
        </button>
      </div>
    </form>
  </div>
</div>
<!-- Backdrop móvil -->
<div
  class="fixed inset-0 z-10 hidden bg-gray-900/50 dark:bg-gray-900/90"
  id="sidebarBackdrop"
></div>

<!-- SCRIPTS -->
<script is:inline type="module">
/* ---------- helpers que usan las traducciones ---------- */
/* ---------- consts de entorno ---------- */
const API_BASE    = "{import.meta.env.PUBLIC_API_URL}";
const FILE_SERVER = "{import.meta.env.PUBLIC_FILE_SERVER_URL}";

async function loadAdminData () {
  // 1. Intenta recuperar un token desde localStorage o cookies accesibles
  let clientToken =
    localStorage.getItem("token")        ||
    localStorage.getItem("accessToken")  ||
    localStorage.getItem("jwt")          ||
    null;

  if (!clientToken) {
    const match = document.cookie.match(/(?:^|; )(?:token|accessToken|jwt)=([^;]+)/);
    clientToken = match ? decodeURIComponent(match[1]) : null;
  }

  // 2. Llama a la API.  Si no hay token, igualmente probamos con credenciales de cookie httpOnly
  try {
    const res = await fetch(`${API_BASE}/api/users`, {
      headers     : clientToken ? { Authorization: `Bearer ${clientToken}` } : undefined,
      credentials : "include"
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);

    const data = await res.json();
    const u = Array.isArray(data) ? (data[0] ?? {}) : data;

    // 3. Actualiza campos del formulario
    if (u.full_name)  document.getElementById("adminNameInput").value  = u.full_name;
    if (u.email)      document.getElementById("adminEmailInput").value = u.email;
    if (u.phone)      document.getElementById("adminPhoneInput").value = u.phone;

    // 4. Actualiza avatar con URL absoluta al file‑server o fallback de iniciales
    if (u.avatar) {
      const avatarUrl = u.avatar.startsWith("http") ? u.avatar : `${FILE_SERVER}/${u.avatar}`;
      document.getElementById("adminAvatarLight").src = avatarUrl;
      document.getElementById("adminAvatarDark").src  = avatarUrl;
    } else if (u.full_name) {
      const seed = encodeURIComponent(u.full_name);
      document.getElementById("adminAvatarLight").src =
        `https://api.dicebear.com/7.x/initials/svg?seed=${seed}&backgroundColor=4b5563&fontColor=ffffff`;
      document.getElementById("adminAvatarDark").src  =
        `https://api.dicebear.com/7.x/initials/svg?seed=${seed}&backgroundColor=1e293b&fontColor=ffffff`;
    }
  } catch (err) {
    console.error("No se pudo cargar el perfil del admin:", err);
    // Si algo falla, dejamos valores por defecto vacíos
  }
}

function validateForm () {
  const name  = document.getElementById("adminNameInput").value.trim();
  const phone = document.getElementById("adminPhoneInput").value.trim();
  if (!name || !phone) {
    alert(t.admin_settings.name_and_phone_required);
    return false;
  }
  return true;
}

/* ---------- script principal: corre cuando el DOM está listo ---------- */
document.addEventListener("DOMContentLoaded", () => {

  /* ---------- lógica de íconos y submenu ---------- */
  const path            = window.location.pathname;
  // ---- highlight active page in sidebar ----
  document.querySelectorAll("#sidebar a[href]").forEach(link => {
    const href = link.getAttribute("href");
    if (href && (path === href || path.startsWith(href + "/"))) {
      link.classList.add("active");
      
      // Special styling for support link when active
      if (href === "/admin/info/support") {
        // Los estilos activos del soporte se manejan con CSS usando .support-link.active
        // No necesitamos JavaScript adicional aquí
      }
    }
  });
  const usersSubmenu    = document.getElementById("users-submenu");
  const nestedUserPaths = ["/admin/users", "/admin/roles"];
  if (usersSubmenu && nestedUserPaths.some(p => path === p || path.startsWith(p + "/"))) {
    usersSubmenu.classList.remove("hidden");
  }

/* ---------- refs DOM ---------- */
const openBtn   = document.getElementById("openAdminSettings");
const closeBtn  = document.getElementById("closeAdminSettings");
const cancelBtn = document.getElementById("cancelAdminEdit");
const form      = document.getElementById("adminSettingsForm");
const modal     = document.getElementById("adminSettingsModal");

const avatarInput = document.getElementById("adminAvatarInput");
const avatarLight = document.getElementById("adminAvatarLight");
const avatarDark  = document.getElementById("adminAvatarDark");

const modalContent = modal.querySelector(".modal-card");

/* ---------- util modal ---------- */
const showModal = () => {
  modal.classList.remove("hidden");
  modal.classList.add("flex");
  // fade‑in backdrop
  modal.classList.remove("opacity-0");
  // Trigger animation on next frame
  requestAnimationFrame(() => {
    modalContent.classList.remove("opacity-0", "scale-90", "translate-y-6");
  });
};
const hideModal = () => {
  // fade‑out backdrop
  modal.classList.add("opacity-0");
  // Start exit animation
  modalContent.classList.add("opacity-0", "scale-90", "translate-y-6");
  modal.addEventListener(
    "transitionend",
    function handler() {
      modal.removeEventListener("transitionend", handler);
      modal.classList.remove("flex");
      modal.classList.add("hidden");
    },
    { once: true },
  );
};

  /* ---------- avatar preview ---------- */
  avatarInput?.addEventListener("change", () => {
    const file = avatarInput.files?.[0];
    if (!file) return;
    const url = URL.createObjectURL(file);
    avatarLight.src = url;
    avatarDark.src  = url;
  });

  /* ---------- eventos modal ---------- */
  openBtn?.addEventListener("click",  e => { e.preventDefault(); showModal(); });
  closeBtn?.addEventListener("click", hideModal);
  cancelBtn?.addEventListener("click", hideModal);
  modal?.addEventListener("click",    e => { if (e.target === modal) hideModal(); });

  /* ---------- envío de formulario ---------- */
  form?.addEventListener("submit", async e => {
    e.preventDefault();
    if (!validateForm()) return;

    const formData = new FormData(form);
    if (avatarInput?.files?.[0]) formData.set("avatar", avatarInput.files[0]);

    try {
      console.log("▶️ Payload a enviar", [...formData.entries()]);
      await new Promise(r => setTimeout(r, 800)); // simulación de API
      alert(t.admin_settings.data_updated_successfully);
      hideModal();
    } catch (err) {
      console.error(err);
      alert(t.admin_settings.error_saving_changes);
    }
  });

  /* ---------- toggles de submenús ---------- */
  document.querySelectorAll("[data-collapse-toggle]").forEach(btn => {
    const targetId = btn.getAttribute("data-collapse-toggle");
    const target   = targetId ? document.getElementById(targetId) : null;
    if (!target) return;

    btn.addEventListener("click", () => {
      target.classList.toggle("hidden");
      btn.querySelector("[data-lucide='chevron-down']")?.classList.toggle("rotate-180");
    });
  });

  /* ---------- cambio de idioma ---------- */
  // Función para actualizar el flag y texto del idioma actual
  function updateCurrentLangFlag() {
    const currentLang = localStorage.getItem('lang') || '{lang}';
    const flagElement = document.getElementById('currentLangFlag');
    const textElement = document.getElementById('currentLangText');
    const chevronElement = document.querySelector('#currentLangBtn i[data-lucide="chevron-up"]');
    
    if (flagElement) {
      flagElement.textContent = currentLang === 'es' ? '🇨🇱' : '🇺🇸';
    }
    if (textElement) {
      textElement.textContent = currentLang === 'es' ? 'ES' : 'EN';
    }
    
    // Animar chevron cuando cambia
    if (chevronElement) {
      chevronElement.style.transform = 'rotate(180deg)';
      setTimeout(() => {
        chevronElement.style.transform = 'rotate(0deg)';
      }, 200);
    }
  }

  // Actualizar flag al cargar
  updateCurrentLangFlag();

  document.querySelectorAll(".language-option").forEach(option => {
    option.addEventListener("click", (e) => {
      e.preventDefault();
      const lang = option.getAttribute("data-lang");
      if (lang) {
        // Importar y usar la función setLang
        import('/src/lib/i18n.js').then(({ setLang }) => {
          setLang(lang);
        }).catch(err => {
          console.error('Error al cambiar idioma:', err);
          // Fallback manual
          localStorage.setItem('lang', lang);
          document.cookie = `user-lang=${lang}; path=/; max-age=31536000`;
          window.location.reload();
        });
      }
    });
  });
});
</script>
