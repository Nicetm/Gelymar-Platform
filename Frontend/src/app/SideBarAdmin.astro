</aside>

<!-- Modal PDF Mail List -->
<div id="pdfMailListModal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-black/80 hidden flex justify-center items-center z-50">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-6 w-full max-w-2xl mx-4 relative max-h-[90vh] overflow-y-auto shadow-2xl">
    <!-- Botón de cerrar -->
    <button id="closePdfMailModal" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition dark:text-gray-300 dark:hover:text-red-400">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <!-- Header con logo y nombre -->
    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
        <span id="pdfMailInitials">ML</span>
      </div>
      <div>
        <h2 id="pdfMailClientName" class="text-xl font-bold text-gray-900 dark:text-gray-100">PDF Mail List</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400">{t.admin_settings.subtitle}</p>
      </div>
    </div>

    <!-- Formulario para agregar nuevos emails -->
    <div id="emailFormContainer" class="border-b border-gray-200 dark:border-gray-700 pb-4 mb-6">
      <!-- Aquí van las filas de nuevos emails -->
    </div>

    <!-- Tabla de emails existentes -->
    <div id="existingEmailsTable" class="mb-6">
      <!-- Aquí se inyectará la tabla por JS -->
    </div>

    <!-- Acciones -->
    <div class="flex justify-between items-center pt-4 border-t border-gray-200 dark:border-gray-700">
      <!-- Botón + email a la izquierda -->
      <button id="addEmailBtn" type="button"
        class="text-xs flex items-center gap-2 text-indigo-600 hover:text-indigo-800 dark:text-indigo-400 dark:hover:text-indigo-300 font-medium transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        {t.admin_settings.add_email}
      </button>
      <!-- Botones a la derecha -->
