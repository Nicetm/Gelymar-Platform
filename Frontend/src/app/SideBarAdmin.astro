              <g fill="none" stroke="white" stroke-linecap="round" stroke-width="1.8">
                <path d="M10 9h0"/><path d="M14 9h0"/><path d="M18 9h0"/>
                <path d="M12 12h0"/><path d="M16 12h0"/>
                <path d="M10 15h0"/><path d="M14 15h0"/><path d="M18 15h0"/>
