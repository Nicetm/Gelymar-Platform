---
---

<script src="https://unpkg.com/lucide@latest"></script>

<aside
  id="sidebar"
  class="fixed top-2 left-0 z-20 flex-col flex-shrink-0 hidden w-56 h-full pt-20 font-normal duration-75 lg:flex transition-width bg-white border-r border-gray-200 dark:bg-gray-800 dark:border-gray-700"
  aria-label="Sidebar"
>
  <!-- Scrollable content -->
  <div class="flex-1 px-3 overflow-y-auto scrollbar scrollbar-w-2 scrollbar-thumb-rounded-md scrollbar-thumb-slate-200 scrollbar-track-gray-400 dark:scrollbar-thumb-slate-900 dark:scrollbar-track-gray-800">
    <div class="mt-4 space-y-2">

      <!-- dashboard -->
      <a href="/admin/dashboard" class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700">
        <i data-lucide="layout-dashboard" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
        <span class="ml-3">Dashboard</span>
      </a>

      <!-- clients -->
      <a href="/admin/clients" class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700">
        <i data-lucide="briefcase" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
        <span class="ml-3">Customers</span>
      </a>

      <!-- documents -->
      <a href="/admin/documents" class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700">
        <i data-lucide="file-text" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
        <span class="ml-3">Documents</span>
      </a>

      <!-- messaging -->
      <a href="/admin/messaging" class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700">
        <i data-lucide="message-circle" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
        <span class="ml-3">Messaging</span>
      </a>

      <!-- shipments -->
	  <a href="/admin/shipments" class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700">
	  <i data-lucide="ship" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
	  <span class="ml-3">Shipments</span>
	  </a>

      <!-- users -->
      <button type="button" class="flex items-center w-full p-2 text-base text-gray-900 rounded-lg group hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700" data-collapse-toggle="users-submenu">
        <i data-lucide="users" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
        <span class="flex-1 ml-3 text-left">Users</span>
        <i data-lucide="chevron-down" class="w-4 h-4 ml-auto transition-transform group-hover:rotate-180"></i>
      </button>
      <ul id="users-submenu" class="hidden py-2 space-y-2 pl-7">
        <li>
          <a href="/admin/users" class="flex items-center gap-2 p-2 text-sm rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-gray-200">
            <i data-lucide="user" class="w-4 h-4 text-gray-400 dark:text-gray-300"></i>
            Users list
          </a>
        </li>
        <li>
          <a href="/admin/roles" class="flex items-center gap-2 p-2 text-sm rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-gray-200">
            <i data-lucide="shield" class="w-4 h-4 text-gray-400 dark:text-gray-300"></i>
            Roles
          </a>
        </li>
      </ul>

      <hr class="my-3 border-gray-300 dark:border-gray-600" />

      <!-- support -->
      <a href="info/support" class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700">
        <i data-lucide="help-circle" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
        <span class="ml-3">Support</span>
      </a>
    </div>
  </div>

  <!-- Footer: settings + language -->
  <div class="absolute bottom-0 left-0 w-full p-4 bg-white border-t border-gray-200 lg:flex justify-center gap-3 dark:bg-gray-800 dark:border-gray-700">
    <!-- Configuración -->
    <a href="/settings/" data-tooltip-target="tooltip-settings" class="inline-flex items-center justify-center w-10 h-10 text-gray-500 rounded-full shadow-md hover:text-gray-900 hover:bg-gray-100 dark:hover:bg-gray-700 dark:text-gray-400 dark:hover:text-white transition">
      <i data-lucide="settings" class="w-6 h-6"></i>
    </a>
    <div id="tooltip-settings" role="tooltip" class="absolute z-10 invisible px-3 py-2 text-sm font-medium text-white bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
      Settings page
      <div class="tooltip-arrow" data-popper-arrow></div>
    </div>

    <!-- Idioma con flecha abajo tipo cómic -->
    <div class="relative inline-block">
      <button type="button" data-dropdown-toggle="language-dropdown" class="inline-flex items-center justify-center w-10 h-10 text-xl rounded-full shadow-md text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-700 transition">
        🇺🇸
      </button>
      <div id="language-dropdown"
           class="absolute bottom-14 left-1/2 -translate-x-1/2 z-50 hidden w-52 rounded-xl shadow-2xl border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-600 transition-all duration-200 ease-out">
        
        <!-- Flecha tipo cómic apuntando hacia el botón -->
        <div class="absolute -bottom-1.5 left-1/2 -translate-x-1/2 w-3 h-3 bg-white rotate-45 border-b border-r border-gray-200 dark:bg-gray-800 dark:border-gray-600"></div>

        <ul class="py-2 text-sm text-gray-700 dark:text-gray-200">
          <li>
            <a href="#" class="flex items-center gap-2 px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 dark:hover:text-white rounded-md transition">
              🇺🇸 English (US)
            </a>
          </li>
          <li>
            <a href="#" class="flex items-center gap-2 px-4 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 dark:hover:text-white rounded-md transition">
              🇨🇱 Español (CL)
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</aside>

<!-- Backdrop móvil -->
<div class="fixed inset-0 z-10 hidden bg-gray-900/50 dark:bg-gray-900/90" id="sidebarBackdrop"></div>
<!-- Script -->
<script>
  declare global {
    interface Window {
      lucide?: { createIcons: () => void };
    }
  }

  const path = window.location.pathname;

  // Users submenu expansion logic
  const usersSubmenu = document.getElementById('users-submenu');
  const nestedUserPaths = ['/admin/users', '/admin/roles'];
  const isInUsersModule = nestedUserPaths.some((p) => path === p || path.startsWith(p + '/'));
  if (usersSubmenu && isInUsersModule) {
    usersSubmenu.classList.remove('hidden');
  }

  window.addEventListener("DOMContentLoaded", () => {
    if (window.lucide) {
      window.lucide.createIcons();
    }
  });

  document.querySelectorAll('[data-collapse-toggle]').forEach((btn) => {
    const targetId = btn.getAttribute('data-collapse-toggle');
    if (!targetId) return;
    const target = document.getElementById(targetId);
    if (!target) return;
    btn.addEventListener('click', () => {
      target.classList.toggle('hidden');
    });
  });

</script>
