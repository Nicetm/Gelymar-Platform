---
import { loadTranslations, getServerLang } from '../lib/i18n.js';
import { getApiBase, getPublicApiUrl, getFileServerUrl } from './constants.ts';
import { inferUserRole, resolveRoleLabel } from '../lib/roles.ts';

const apiBase = getApiBase();
const clientApiBase = getPublicApiUrl();
const fileServer = getFileServerUrl();
const lang = getServerLang(Astro.cookies);

const t: any = {
  sidebar: await loadTranslations(lang, 'sidebar'),
  admin_settings: await loadTranslations(lang, 'admin_settings'),
};

// ── Datos del usuario autenticado ───────────────────────────────────────────────
const token =
  Astro.cookies.get('token')?.value ??
  Astro.cookies.get('accessToken')?.value ??
  Astro.cookies.get('jwt')?.value ??
  null;

/** @type {import('../types/entities.js').Users | null} */
let user = null;

try {
  // En SSR (Node), 'credentials' no es soportado por los tipos de fetch, y las cookies httpOnly
  // no se envían automáticamente. Solo usamos el header Authorization si tenemos token.
  if (token) {
    const data = await fetch(`${apiBase}/api/auth/me`, {
      headers: { Authorization: `Bearer ${token}` }
    }).then(r => (r.ok ? r.json() : null));
    user = Array.isArray(data) ? data[0] ?? null : data;
    if (user) {
      const normalizedRole = inferUserRole(user);
      user.role = normalizedRole;
    }
  }
} catch (err) {
  console.error('Error fetching user (SSR):', err);
}

if (!user) {
  user = { full_name: 'Admin', email: 'admin@example.com', role: 'admin', avatar: '' };
}

if (user) {
  const normalizedRole = inferUserRole(user);
  user.role = normalizedRole;

  if (user.role_id === undefined || user.role_id === null) {
    if (normalizedRole === 'admin') {
      user.role_id = 1;
    } else if (normalizedRole === 'seller') {
      user.role_id = 3;
    } else if (normalizedRole === 'client') {
      user.role_id = 2;
    }
  }

  user.role_label = resolveRoleLabel(normalizedRole);
}

let sidebarMenuConfig = null;
try {
  if (token) {
    const menuResponse = await fetch(`${apiBase}/api/config/sidebar-menu`, {
      headers: { Authorization: `Bearer ${token}` }
    });
    if (menuResponse.ok) {
      sidebarMenuConfig = await menuResponse.json();
    }
  }
} catch (error) {
  console.warn('Error obteniendo configuración del menú lateral:', error);
}

const toRoleList = (roles: any): number[] => {
  if (!Array.isArray(roles)) return [];
  return roles
    .map((value: any) => Number(value))
    .filter((value: number) => Number.isFinite(value));
};

const menuConfigMap = (() => {
  if (!sidebarMenuConfig || Number(sidebarMenuConfig.enable) !== 1 || !Array.isArray(sidebarMenuConfig.menu)) {
    return null;
  }
  const map = new Map();
  sidebarMenuConfig.menu.forEach((entry: any) => {
    if (!entry || !entry.name) return;
    const key = String(entry.name).toLowerCase().trim();
    if (!key) return;
    map.set(key, toRoleList(entry.role_id || entry.roles || []));
  });
  return map;
})();

const MENU_KEY_ALIASES = {
  dashboard: ['dashboard'],
  clientes: ['clientes', 'clients'],
  vendedores: ['vendedores', 'sellers'],
  ordenes: ['ordenes', 'órdenes', 'orders'],
  messaging: ['messaging', 'mensajes', 'messages'],
  shipments: ['shipments', 'envios', 'envíos'],
};

const userRoleId = Number(user?.role_id ?? user?.roleId ?? null);
const hasValidRoleId = Number.isFinite(userRoleId);

const getConfigRolesForKey = (key: string): number[] | null => {
  if (!menuConfigMap) return null;
  const aliases = (MENU_KEY_ALIASES as Record<string, string[]>)[key] || [key];
  for (const alias of aliases) {
    const normalized = String(alias).toLowerCase();
    if (menuConfigMap.has(normalized)) {
      return menuConfigMap.get(normalized) || null;
    }
  }
  return null;
};

const isRoleAllowed = (roles: number[] | null): boolean => {
  if (!hasValidRoleId) return false;
  if (!roles || roles.length === 0) return true;
  return roles.includes(userRoleId);
};

const canShowMenu = (key: string, fallbackRoles: number[] = []): boolean => {
  const normalizedFallback = toRoleList(fallbackRoles);
  const fallbackAllowed =
    normalizedFallback.length === 0 ? hasValidRoleId : normalizedFallback.includes(userRoleId);

  if (!fallbackAllowed) {
    return false;
  }

  if (!menuConfigMap) {
    return fallbackAllowed;
  }

  const configRoles = getConfigRolesForKey(key);
  if (!configRoles) {
    return false;
  }

  return isRoleAllowed(configRoles);
};

const showClients = canShowMenu('clientes', [1, 3]);
const showSellers = canShowMenu('vendedores', [1]);
const showOrders = canShowMenu('ordenes', [1, 3]);

const activePath = Astro.url.pathname;

const links = [
  {
    href: '/admin/clients',
    icon: 'briefcase',
    label: t.sidebar.customers,
    show: showClients,
  },
  {
    href: '/admin/sellers',
    icon: 'users',
    label: t.sidebar.sellers,
    show: showSellers,
  },
  {
    href: '/admin/orders',
    icon: 'file-text',
    label: t.sidebar.orders,
    show: showOrders,
  },
].filter(link => link.show);

const avatarUrl = user?.avatar
  ? (user.avatar.startsWith('http') ? user.avatar : `${fileServer}/${user.avatar}`)
  : `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user?.full_name || 'Admin')}&backgroundColor=4b5563&fontColor=ffffff`;

let avatarLightSrc = avatarUrl;
let avatarDarkSrc = user?.avatar 
  ? avatarUrl 
  : `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user?.full_name || 'Admin')}&backgroundColor=1e293b&fontColor=ffffff`;
---


<!-- Carga Lucide diferido y renderiza íconos al terminar -->
<script src="https://unpkg.com/lucide@latest" defer onload="window.lucide?.createIcons?.()"></script>

<aside
