---
// navbar-cliente.astro
import NotificationDropdown from '../components/NotificationDropdown.astro';
import UserMenu from '../components/UserMenu.astro';
import ColorModeSwitcher from '../components/ColorModeSwitcher.astro';
import AppsDropdown from '../components/AppsDropdown.astro';
---

<nav class="fixed z-50 w-full bg-white border-b border-gray-200 dark:bg-gray-800 dark:border-gray-700">
  <div class="px-3 py-2 lg:px-5 lg:pl-3">
    <div class="flex items-center justify-between">
      <!-- Logo + Toggle -->
      <div class="flex items-center justify-start ml-6">
        <button
          id="toggleSidebarMobile"
          aria-expanded="true"
          aria-controls="sidebar"
          class="p-2 text-gray-600 rounded cursor-pointer lg:hidden hover:text-gray-900 hover:bg-gray-100 focus:bg-gray-100 dark:focus:bg-gray-700 focus:ring-2 focus:ring-gray-100 dark:focus:ring-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white"
        >
          <svg id="toggleSidebarMobileHamburger" class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path d="M3 5h14M3 10h14M3 15h14"/>
          </svg>
        </button>

        <!-- Logo (con animación hover) -->
        <a
          href="/"
          class="group -ml-5 inline-flex items-center gap-2 px-2 py-1 rounded-xl bg-white dark:bg-[#dcdcdc] shadow-md hover:shadow-lg transition-all duration-300 transform hover:scale-105"
        >
          <img
            src="/assets/gelymar.svg"
            alt="Logo"
            class="h-8 w-auto transition-transform duration-300 ease-in-out group-hover:scale-110"
          />
          <span class="text-lg font-extrabold text-[#002E50] dark:text-[#002E50] relative">
            Gelymar
            <span class="absolute left-0 -bottom-1 h-[2px] w-0 bg-[#002E50] dark:bg-[#002E50] transition-all duration-300 ease-in-out group-hover:w-full"></span>
          </span>
        </a>
      </div>

      <!-- Iconos -->
      <div class="flex items-center space-x-5 ml-3 mr-8">
        <NotificationDropdown />
        <AppsDropdown />
        <ColorModeSwitcher />
        <UserMenu />
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggles = document.querySelectorAll('[data-dropdown-toggle]');

    toggles.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();

        const targetId = btn.getAttribute('data-dropdown-toggle');
        if (!targetId) return;

        const dropdown = document.getElementById(targetId);
        if (!dropdown) return;

        document.querySelectorAll('[id$="-dropdown"]').forEach((el) => {
          if (el !== dropdown) {
            el.classList.add('hidden');
          }
        });

        dropdown.classList.toggle('hidden');
      });
    });

    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;

      const clickedDropdownToggle = target.closest('[data-dropdown-toggle]');
      const clickedDropdownPanel = target.closest('[id$="-dropdown"]');

      if (!clickedDropdownToggle && !clickedDropdownPanel) {
        document.querySelectorAll('[id$="-dropdown"]').forEach((el) =>
          el.classList.add('hidden')
        );
      }
    });
  });
</script>