---

---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gelymar Panel - Cambiar Contraseña</title>
  </head>

  <body class="font-sans bg-gray-100 dark:bg-gray-900 antialiased">
    <main
      class="relative w-full h-screen bg-cover bg-center bg-no-repeat flex items-center justify-center"
      style="background-image: url('/images/banner.jpg')"
    >
      <!-- Overlay -->
      <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm z-0"></div>

      <!-- Change Password Panel -->
      <div class="relative z-10 w-full max-w-xl mx-4 bg-gradient-to-br from-white/95 to-gray-50 dark:from-gray-800/95 dark:to-gray-700/90 backdrop-blur-md rounded-3xl shadow-3xl border border-gray-200 dark:border-gray-700 ring-1 ring-white/40 dark:ring-white/10 px-8 sm:px-10 py-12 animate-panel-pop">
        
        <!-- Header -->
        <div class="flex flex-col items-center text-center gap-6">
          <!-- Logo + Nombre animado -->
          <div class="flex items-center gap-2 px-6 py-4 rounded-xl bg-white dark:bg-gray-100 shadow-md transition-all duration-500 hover:scale-105 hover:shadow-xl animate-float-up">
            <img
              src="/assets/gelymar.svg"
              alt="Gelymar Logo"
              class="h-10 w-10 transition-transform duration-300 ease-in-out"
            />
            <span class="text-[2rem] font-bold text-[#002E50] tracking-tight leading-tight">
              Gelymar
            </span>
          </div>

          <!-- Título -->
          <div>
            <h1 class="text-2xl font-bold text-[#002E50]">Cambiar Contraseña</h1>
            <p class="mt-1 text-sm text-[#002E50]/80">
              Por favor, establece una nueva contraseña para tu cuenta.
            </p>
          </div>
        </div>

        <!-- Slot del formulario -->
        <div class="mt-10 space-y-4">
          <slot />
        </div>

        <!-- Lema -->
        <p class="mt-8 text-xs text-center text-[#002E50]/60 italic">
          Sustainable marine solutions since 1993.
        </p>
      </div>

      <style is:global>
        @keyframes panel-pop {
          0% { opacity: 0; transform: scale(0.95) translateY(20px); }
          100% { opacity: 1; transform: scale(1) translateY(0); }
        }

        @keyframes float-up {
          0% { opacity: 0; transform: translateY(10px) scale(0.98); }
          100% { opacity: 1; transform: translateY(0) scale(1); }
        }

        .animate-panel-pop {
          animation: panel-pop 0.7s ease-out both;
        }

        .animate-float-up {
          animation: float-up 0.6s ease-out both;
        }

        .shadow-3xl {
          box-shadow: 0 20px 45px rgba(0, 0, 0, 0.15);
        }
      </style>
    </main>
  </body>
</html> 