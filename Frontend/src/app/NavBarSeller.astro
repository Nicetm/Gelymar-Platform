---
import ColorModeSwitcher from '../components/ColorModeSwitcher.astro';
import UserMenu from '../components/UserMenu.astro';
---

<nav
  role="navigation"
  aria-label="Seller navigation"
  class="fixed z-50 w-full bg-white/80 dark:bg-gray-900/70 backdrop-blur-md border-b border-gray-200 dark:border-gray-700 ring-1 ring-white/10 dark:ring-gray-700 transition-colors"
>
  <div class="px-3 py-2 lg:px-5 lg:pl-3">
    <div class="flex items-center justify-between">
      <div class="flex items-center justify-start ml-4 lg:ml-6 px-1">
        <button
          id="toggleSidebarMobile"
          aria-label="Toggle sidebar"
          aria-expanded="false"
          class="p-2 xl:hidden relative z-20 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-primary-500 transition"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <a href="/seller/orders" class="ml-2 md:ml-0 inline-flex items-center gap-2">
          <img src="/assets/gelymar.svg" alt="Gelymar logo" class="h-9 w-auto" />
          <span class="text-xl font-bold tracking-tight text-[#002E50] dark:text-gray-100">
            Gelymar
          </span>
        </a>
      </div>

      <div class="flex items-center space-x-5 ml-3 pr-4 lg:pr-8">
        <ColorModeSwitcher />
        <UserMenu />
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  if (typeof window !== 'undefined') {
    const setupUserDropdown = () => {
      const toggleBtn = document.getElementById('user-toggle');
      const dropdown = document.getElementById('user-dropdown');
      if (!toggleBtn || !dropdown) return;

      const openDropdown = () => {
        dropdown.classList.remove('hidden');
        dropdown.style.display = 'block';
        toggleBtn.setAttribute('aria-expanded', 'true');
      };

      const closeDropdown = () => {
        dropdown.classList.add('hidden');
        dropdown.style.display = 'none';
        toggleBtn.setAttribute('aria-expanded', 'false');
      };

      toggleBtn.addEventListener('click', (event) => {
        event.preventDefault();
        const isHidden = dropdown.classList.contains('hidden');
        if (isHidden) {
          openDropdown();
        } else {
          closeDropdown();
        }
      });

      document.addEventListener('click', (event) => {
        if (!toggleBtn.contains(event.target) && !dropdown.contains(event.target)) {
          closeDropdown();
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupUserDropdown, { once: true });
    } else {
      setupUserDropdown();
    }
  }
</script>
