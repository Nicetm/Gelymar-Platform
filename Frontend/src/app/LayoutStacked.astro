---
import FooterSidebar from './FooterSidebar.astro';
import LayoutCommon from './LayoutCommon.astro';
import NavBarSidebar from './NavBarSidebarAdmin.astro';
import SideBar from './SideBarAdmin.astro';
---

<LayoutCommon>
  <!-- Navbar superior -->
  <NavBarSidebar />

  <!-- Contenedor principal con sidebar y contenido -->
  <main class="flex pt-4 bg-gray-50 dark:bg-gray-900 min-h-screen overflow-hidden">
    
    <!-- Sidebar lateral -->
    <SideBar />

    <!-- Contenido principal -->
    <section
      id="main-content"
      class="relative flex-1 h-full overflow-y-auto transition-all duration-300 lg:ml-56"
    >
      <div class="px-4 pt-6 2xl:px-8">
        <slot />
      </div>
      
      <!-- Footer -->
      <FooterSidebar />
    </section>
  </main>
</LayoutCommon>
