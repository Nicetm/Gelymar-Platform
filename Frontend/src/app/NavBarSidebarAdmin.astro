---
// navbar.astro
import NotificationDropdown from '../components/NotificationDropdown.astro';
import AppsDropdown from '../components/AppsDropdown.astro';
import ColorModeSwitcher from '../components/ColorModeSwitcher.astro';
import UserMenu from '../components/UserMenu.astro';
---

<nav class="fixed z-50 w-full bg-white border-b border-gray-200 dark:bg-gray-800 dark:border-gray-700">
  <div class="px-3 py-2 lg:px-5 lg:pl-3">
    <div class="flex items-center justify-between">
      <!-- Logo + Toggle -->
      <div class="flex items-center justify-start ml-6">
        <button id="toggleSidebarMobile" class="p-2 text-gray-600 rounded lg:hidden hover:bg-gray-100 dark:hover:bg-gray-700">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path d="M3 5h14M3 10h14M3 15h14"/>
          </svg>
        </button>
        <a
          href="/"
          class="-ml-5 inline-flex items-center gap-2 px-2 py-1 rounded-xl shadow-md bg-white dark:bg-gray-200 hover:shadow-lg hover:-translate-y-0.5 hover:scale-105 transition-transform duration-300 ease-out"
        >
          <img
            src="/assets/gelymar.svg"
            alt="Logo"
            class="h-8 w-auto transition-transform duration-300 ease-in-out group-hover:scale-110"
          />
          <span class="text-lg font-extrabold text-[#002E50] transition-colors duration-300">Gelymar</span>
        </a>
      </div>

      <!-- Iconos -->
      <div class="flex items-center space-x-5 ml-3 mr-8">
        <NotificationDropdown />
        <AppsDropdown />
        <ColorModeSwitcher />
        <UserMenu />
      </div>
    </div>
  </div>
</nav>

<!-- Script que maneja los dropdowns -->
<script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const toggles = document.querySelectorAll("[data-dropdown-toggle]");

    toggles.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();

        const targetId = btn.getAttribute("data-dropdown-toggle");
        if (!targetId) return;

        const dropdown = document.getElementById(targetId);
        if (!dropdown) return;

        // Oculta todos excepto el actual
        document.querySelectorAll("[id$='-dropdown']").forEach((el) => {
          if (el !== dropdown) el.classList.add("hidden");
        });

        // Alterna este
        dropdown.classList.toggle("hidden");
      });
    });

    // Cierra todos si haces clic afuera
    document.addEventListener("click", (e) => {
      const target = e.target;
      if (!(target instanceof Node)) return;

      const isInsideDropdown = [...document.querySelectorAll("[id$='-dropdown']")].some(el => el.contains(target));
      const isToggle = [...document.querySelectorAll("[data-dropdown-toggle]")].some(el => el.contains(target));

      if (!isInsideDropdown && !isToggle) {
        document.querySelectorAll("[id$='-dropdown']").forEach((el) => el.classList.add("hidden"));
      }
    });
  });
</script>