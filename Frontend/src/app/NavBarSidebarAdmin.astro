---
// navbar.astro
// import NotificationDropdown from '../components/NotificationDropdown.astro';
// import AppsDropdown from '../components/AppsDropdown.astro';
import ColorModeSwitcher from '../components/ColorModeSwitcher.astro';
import UserMenu from '../components/UserMenu.astro';
import NotificationBell from '../components/NotificationBell.astro';

// Obtener configuración del parámetro headerBusquedaClienteChat
let chatEnabled = true;
try {
  const response = await fetch(`${import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL}/api/config/headerBusquedaClienteChat`, {
    headers: {
      'Authorization': `Bearer ${Astro.cookies.get('token')?.value || ''}`
    }
  });
  if (response.ok) {
    const config = await response.json();
    chatEnabled = config.enable === 1;
  }
} catch (error) {
  console.warn('Error obteniendo configuración de chat:', error);
}
---

<nav
  role="navigation"
  aria-label="Main navigation"
  class="fixed z-50 w-full bg-white/80 dark:bg-gray-900/70 backdrop-blur-md border-b border-gray-200 dark:border-gray-700 ring-1 ring-white/10 dark:ring-gray-700 transition-colors motion-reduce:transition-none">
  <div class="px-3 py-2 lg:px-5 lg:pl-3">
    <div class="flex items-center justify-between">
      <!-- Logo + Toggle -->
      <div class="flex items-center justify-start ml-4 lg:ml-6 px-1">
        <button
          id="toggleSidebarMobile"
          aria-label="Toggle sidebar"
          aria-expanded="false"
          class="p-2 xl:hidden relative z-20 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-primary-500 transition"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <a
          href="/admin"
          class="ml-2 md:ml-0 inline-flex items-center gap-2"
        >
          <img
            src="/assets/gelymar.svg"
            alt="Gelymar logo"
            class="h-9 w-auto"
          >
          <span class="text-xl dark:text-xl font-extrabold tracking-tight text-[#002E50] dark:text-gray-100">
            Gelymar
          </span>
        </a>
      </div>

      <!-- Iconos -->
      <div class="flex items-center space-x-5 ml-3 pr-4 lg:pr-8">
        <!-- <NotificationDropdown /> -->
        <!-- <AppsDropdown /> -->
        <!-- Chat icon -->
        {chatEnabled && (
          <div class="relative">
            <button
              id="chat-icon"
              class="relative p-2 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500"
              aria-label="Chat"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </button>

          <!-- Chat dropdown -->
          <div
            id="chat-dropdown"
            class="absolute right-0 mt-2 w-80 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 z-50 hidden"
          >
            <!-- Header del dropdown -->
            <div class="flex items-center justify-between p-3 border-b border-gray-200 dark:border-gray-700">
              <h3 class="text-base font-semibold text-gray-900 dark:text-white">Clientes</h3>
            </div>
            
            <!-- Search -->
              <div class="p-3 border-b border-gray-200 dark:border-gray-700 space-y-2">
                <input
                  type="text"
                  id="chat-search"
                  placeholder="Buscar cliente..."
                  class="w-full px-3 py-2 text-xs border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500"
                />
              </div>

            <!-- Lista de clientes -->
            <div id="chat-client-list" class="max-h-96 overflow-y-auto">
              <!-- Los clientes se cargarán dinámicamente aquí -->
              <div id="chat-empty-state" class="p-4 text-center text-gray-500 dark:text-gray-400">
                <svg class="w-6 h-6 mx-auto mb-2 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                <p class="text-sm">No hay clientes</p>
              </div>
            </div>
            
            <!-- Footer del dropdown -->
            <div class="p-2 border-t border-gray-200 dark:border-gray-700">
              <a
                href="/admin/clients"
                class="block text-center text-xs text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300"
              >
                Ver todos los clientes
              </a>
            </div>
          </div>
        </div>
        )}
        <NotificationBell unreadCount={0} />
        <ColorModeSwitcher />
        <UserMenu />
      </div>
    </div>
  </div>
</nav>

<!-- Script que maneja los dropdowns -->
<script is:inline>
// @ts-nocheck
  window.addEventListener("DOMContentLoaded", () => {
    const toggles = document.querySelectorAll("[data-dropdown-toggle]");

    toggles.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();

        const targetId = btn.getAttribute("data-dropdown-toggle");
        if (!targetId) return;

        const dropdown = document.getElementById(targetId);
        if (!dropdown) return;

        // Oculta todos excepto el actual
        document.querySelectorAll("[id$='-dropdown']").forEach((el) => {
          if (el !== dropdown) el.classList.add("hidden");
        });

        // Alterna este
        dropdown.classList.toggle("hidden");
      });
    });

    // Manejo del dropdown de chat
    const chatIcon = document.getElementById('chat-icon');
    const chatDropdown = document.getElementById('chat-dropdown');
    const chatSearch = document.getElementById('chat-search');
    const chatClientList = document.getElementById('chat-client-list');
    const chatEmptyState = document.getElementById('chat-empty-state');
    
    let allClients = [];
    let filteredClients = [];

    // Cargar clientes
    async function loadClients() {
      try {
        const token = localStorage.getItem('token');
        const apiBase = window.apiBase || window.location.origin.replace(':4321', ':3000');
        
        if (!token) {
          console.error('No token found');
          return;
        }
        
        const response = await fetch(`${apiBase}/api/customers`, {
          headers: { Authorization: `Bearer ${token}` }
        });
        
        if (!response.ok) {
          console.error('HTTP error:', response.status, response.statusText);
          return;
        }
        
        const contentType = response.headers.get('content-type');
        if (!contentType || !contentType.includes('application/json')) {
          console.error('Response is not JSON:', contentType);
          return;
        }
        
        const data = await response.json();
        allClients = data || [];
        filteredClients = [...allClients];
        renderClients();
      } catch (error) {
        console.error('Error cargando clientes:', error);
      }
    }

    // Renderizar clientes
    function renderClients() {
      if (filteredClients.length === 0) {
        chatClientList.innerHTML = `
          <div id="chat-empty-state" class="p-4 text-center text-gray-500 dark:text-gray-400">
            <svg class="w-6 h-6 mx-auto mb-2 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            <p class="text-sm">No se encontraron clientes</p>
          </div>
        `;
        return;
      }
      
      const clientsHTML = filteredClients.map(client => `
        <div class="flex items-center justify-between p-3 hover:bg-gray-50 dark:hover:bg-gray-700">
          <div class="flex-1 flex items-center gap-2">
            <div class="w-2 h-2 rounded-full ${client.online === 1 ? 'bg-green-500' : 'bg-red-500'}"></div>
            <p class="text-xs font-medium text-gray-900 dark:text-white">${client.name.toLowerCase().replace(/\b\w/g, l => l.toUpperCase())}</p>
          </div>
          <button 
            class="ml-3 px-3 py-1 text-xs font-medium text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 bg-blue-50 hover:bg-blue-100 dark:bg-blue-900/30 dark:hover:bg-blue-900/50 rounded-md transition-colors"
            onclick="openChat('${client.id}', '${client.name}', ${client.online === 1})"
          >
            Chatear
          </button>
        </div>
      `).join('');
      
      chatClientList.innerHTML = clientsHTML;
    }

    // Filtrar clientes
    function filterClients(searchTerm) {
      filteredClients = allClients.filter(client => 
        client.name.toLowerCase().includes(searchTerm.toLowerCase())
      );
      renderClients();
    }

    // Función para abrir chat (global)
    window.openChat = function(customerId, customerName, isOnline = false) {
      // Cerrar el dropdown de clientes
      chatDropdown.classList.add('hidden');
      
      // Abrir el chat del admin con el cliente seleccionado
      if (window.openAdminChat) {
        window.openAdminChat(customerId, customerName, isOnline);
      }
    };

    if (chatIcon && chatDropdown) {
      chatIcon.addEventListener('click', function(e) {
        e.stopPropagation();
        chatDropdown.classList.toggle('hidden');
        
        // Cargar clientes cada vez que se abre el dropdown para obtener datos actualizados
        if (!chatDropdown.classList.contains('hidden')) {
          loadClients();
          // Limpiar el buscador
          if (chatSearch) {
            chatSearch.value = '';
            filteredClients = [...allClients];
            renderClients();
          }
        }
      });
    }

    // Buscar clientes
    if (chatSearch) {
      chatSearch.addEventListener('input', function(e) {
        filterClients(e.target.value);
      });
    }

    // Cierra todos si haces clic afuera
    document.addEventListener("click", (e) => {
      const { target } = e;
      if (!(target instanceof Node)) return;

      const isInsideDropdown = [...document.querySelectorAll("[id$='-dropdown']")].some(el => el.contains(target));
      const isToggle = [...document.querySelectorAll("[data-dropdown-toggle]")].some(el => el.contains(target));

      if (!isInsideDropdown && !isToggle) {
        document.querySelectorAll("[id$='-dropdown']").forEach((el) => el.classList.add("hidden"));
      }
    });
    // --- Navbar shadow on scroll ---
    const nav = document.querySelector('nav[aria-label="Main navigation"]');
    const toggleBtn = document.getElementById('toggleSidebarMobile');
    const sidebar   = document.getElementById('sidebar');         // aside element

    function handleScroll() {
      if (!nav) return;
      nav.classList.toggle('shadow-lg', window.scrollY > 0);
    }
    window.addEventListener('scroll', handleScroll);
    handleScroll();

    // --- aria-expanded sync for the hamburger ---
    toggleBtn?.addEventListener('click', () => {
      const expanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', (!expanded).toString());
      // toggle sidebar visibility on mobile
      if (sidebar) {
        sidebar.classList.toggle('-translate-x-full');
      }
    });
  });
</script>
