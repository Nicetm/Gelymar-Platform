---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset your password — Gelymar</title>
  </head>

  <body class="font-sans bg-gray-100 dark:bg-gray-900 antialiased">
    <main
      class="relative w-full min-h-screen bg-cover bg-center bg-no-repeat flex items-center justify-center px-4"
      style="background-image: url('/images/banner.jpg')"
    >
      <!-- Fondo oscuro con desenfoque -->
      <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm z-0"></div>

      <!-- Panel blanco -->
      <div class="relative z-10 w-full max-w-xl mx-auto bg-gradient-to-br from-white/95 to-gray-50 dark:from-gray-800/95 dark:to-gray-700/90 backdrop-blur-md rounded-3xl shadow-3xl border border-gray-200 dark:border-gray-700 ring-1 ring-white/40 dark:ring-white/10 px-8 sm:px-10 py-10 sm:py-12 animate-panel-pop space-y-8">
        
        <!-- Logo + marca -->
        <div class="flex flex-col items-center text-center gap-4">
          <div class="flex items-center gap-2 px-6 py-3 rounded-xl bg-white dark:bg-gray-100 shadow-md transition hover:scale-105 hover:shadow-xl animate-float-up">
            <img
              src="/assets/gelymar.svg"
              alt="Gelymar Logo"
              class="h-10 w-10"
            />
            <span class="text-[2rem] font-extrabold text-[#002E50] leading-none">
              Gelymar
            </span>
          </div>

          <!-- Encabezado -->
          <div>
            <h1 class="text-2xl font-bold text-[#002E50]">Reset your password</h1>
            <p class="mt-1 text-sm text-[#002E50]/80">
              Enter your email to receive reset instructions.
            </p>
          </div>
        </div>

        <!-- Formulario -->
        <div class="w-full">
          <slot />
        </div>

        <!-- Lema -->
        <p class="text-xs text-center text-[#002E50]/60 italic">
          Sustainable marine solutions since 1993.
        </p>
      </div>

      <!-- Footer global -->
      <footer class="absolute bottom-5 w-full text-center text-sm text-white px-4">
        <p>
          <a href="/info/terms-and-conditions" class="hover:underline">Terms and Conditions</a> ·
          <a href="/info/privacy-policy" class="hover:underline">Privacy Policy</a>
        </p>
        <p class="mt-1">
          © {new Date().getFullYear()} <strong class="text-[#F6B234]">Gelymar SA</strong>. All rights reserved.
        </p>
      </footer>

      <style is:global>
        @keyframes panel-pop {
          0% { opacity: 0; transform: scale(0.95) translateY(20px); }
          100% { opacity: 1; transform: scale(1) translateY(0); }
        }

        @keyframes float-up {
          0% { opacity: 0; transform: translateY(10px) scale(0.98); }
          100% { opacity: 1; transform: translateY(0) scale(1); }
        }

        .animate-panel-pop {
          animation: panel-pop 0.7s ease-out both;
        }

        .animate-float-up {
          animation: float-up 0.6s ease-out both;
        }

        .shadow-3xl {
          box-shadow: 0 20px 45px rgba(0, 0, 0, 0.15);
        }
      </style>
    </main>
  </body>
</html>