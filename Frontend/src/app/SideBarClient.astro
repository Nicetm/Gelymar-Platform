---
---

<script src="https://unpkg.com/lucide@latest"></script>

<aside
  id="sidebar"
  class="fixed top-0 left-0 z-20 flex-col flex-shrink-0 hidden w-56 h-full pt-6 font-normal duration-75 lg:flex transition-width bg-white border-r border-gray-200 dark:bg-gray-800 dark:border-gray-700"
  aria-label="Sidebar"
>
  <!-- Logo -->
  <div class="flex items-center justify-center mb-4 px-4">
    <img src="/assets/gelymar.svg" alt="Gelymar Logo" class="h-10 w-auto" />
  </div>

  <!-- Scrollable content -->
  <div class="flex-1 px-3 overflow-y-auto scrollbar scrollbar-w-2 scrollbar-thumb-rounded-md scrollbar-thumb-slate-200 scrollbar-track-gray-400 dark:scrollbar-thumb-slate-900 dark:scrollbar-track-gray-800">
    <div class="mt-4 space-y-2">
      <!-- Dashboard -->
      <a href="/client/dashboard" class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700">
        <i data-lucide="layout-dashboard" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
        <span class="ml-3">Dashboard</span>
      </a>

      <!-- Messaging -->
      <a href="/client/messaging" class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700">
        <i data-lucide="message-circle" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
        <span class="ml-3">Messaging</span>
      </a>

      <!-- Settings -->
      <a href="/client/settings" class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700">
        <i data-lucide="settings" class="w-6 h-6 text-gray-500 dark:text-gray-400"></i>
        <span class="ml-3">Settings</span>
      </a>
    </div>
  </div>
</aside>

<script>
  window.addEventListener("DOMContentLoaded", () => {
    if (window.lucide) window.lucide.createIcons();
  });
</script>
