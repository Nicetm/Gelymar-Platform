---
import pkg from '../../package.json' assert { type: 'json' };
import { url } from '../lib/data.js';
import { SITE_TITLE } from './constants.js';
import AuthGuard from '../components/AuthGuard.astro';

const { class: clazz } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{SITE_TITLE} — v{pkg.version}</title>
    <link rel="icon" type="image/svg+xml" href="/gelymar.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pkg.description} />
    <meta name="author" content="Sebastián Allende - Pablo Santibañez | Softkey" />
    <meta name="copyright" content="MIT" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="sitemap" type="application/xml" href={url('sitemap-index.xml')} />

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-XSS-Protection" content="1; mode=block" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=()" />
    
    <!-- Content Security Policy -->
    <meta http-equiv="Content-Security-Policy" content="
      default-src 'self';
      script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com https://cdn.socket.io;
      style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net;
      font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net;
      img-src 'self' data: https: blob:;
      connect-src 'self' http://localhost:* http://backend:* https://api.gelymar.com ws://localhost:* wss://localhost:*;
      frame-src 'none';
      object-src 'none';
      base-uri 'self';
      form-action 'self';
    " />

    <!-- CSS del spinner inicial -->
    <style>
      #globalSpinnerInit {
        position: fixed;
        inset: 0;
        background-color: white;
        opacity: 0.8;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
      }
      html.dark #globalSpinnerInit {
        background-color: #111827;
      }
    </style>

    <!-- Socket.io -->
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script is:inline>
      // Verificar que Socket.io esté disponible
      window.socketIoReady = false;
      if (typeof io !== 'undefined') {
        window.socketIoReady = true;
      } else {
        // Esperar a que se cargue
        window.addEventListener('load', () => {
          if (typeof io !== 'undefined') {
            window.socketIoReady = true;
            console.log('Socket.io cargado correctamente');
          } else {
            console.error('Socket.io no se pudo cargar');
          }
        });
      }
    </script>
    
    <!-- WATCHER TOKEN -->
    <script is:inline define:vars={{ 
      SERVER_API_URL: import.meta.env.SERVER_API_URL, 
      PUBLIC_API_URL: import.meta.env.PUBLIC_API_URL 
    }}>
      // Función de logout simplificada
      function logout() {
        try {
          localStorage.removeItem('token');
          localStorage.removeItem('userRole');
          localStorage.removeItem('userEmail');
          document.cookie = 'token=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;';
          window.location.href = '/authentication/sign-in';
        } catch (error) {
          console.error('Error en logout:', error);
          window.location.href = '/authentication/sign-in';
        }
      }

      // Función para verificar token
      function checkTokenExpiration() {
        const token = localStorage.getItem('token');
        if (!token) return;

        try {
          const payload = JSON.parse(atob(token.split('.')[1]));
          const expirationTime = payload.exp * 1000;
          const currentTime = Date.now();
          const timeUntilExpiration = expirationTime - currentTime;
          const fiveMinutes = 5 * 60 * 1000;

          if (timeUntilExpiration <= fiveMinutes && timeUntilExpiration > 0) {
            const modal = document.getElementById('tokenWarningModal');
            if (modal) modal.classList.remove('hidden');
          } else if (timeUntilExpiration <= 0) {
            logout();
          }
        } catch (error) {
          console.error('Error checking token:', error);
        }
      }

      window.addEventListener('DOMContentLoaded', () => {
        const logoutBtn = document.getElementById('logoutNow');
        const extendBtn = document.getElementById('extendSession');
        const modal = document.getElementById('tokenWarningModal');

        // Verificar token cada minuto
        setInterval(checkTokenExpiration, 60000);
        
        // Verificar al cargar
        checkTokenExpiration();

        logoutBtn?.addEventListener('click', () => {
          logout();
        });

        extendBtn?.addEventListener('click', async () => {
          try {
            const apiUrl = `${SERVER_API_URL || PUBLIC_API_URL}/api/auth/refresh`;
            
            const res = await fetch(apiUrl, {
              method: 'POST',
              headers: {
                'Authorization': `Bearer ${localStorage.getItem('token')}`
              }
            });
            
            const data = await res.json();

            if (res.ok && data.token) {
              localStorage.setItem('token', data.token);
              if (modal) modal.classList.add('hidden');
            } else {
              logout();
            }
          } catch (e) {
            console.error('Error al renovar token:', e);
            logout();
          }
        });
      });
    </script>

    <script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script is:inline>
      if (
        localStorage.getItem('color-theme') === 'dark' ||
        (!('color-theme' in localStorage) &&
          window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>

  <body
    class:list={[
      clazz,
      'bg-gray-50 dark:bg-gray-800',
      'scrollbar scrollbar-w-3 scrollbar-thumb-rounded-[0.25rem]',
      'scrollbar-track-slate-200 scrollbar-thumb-gray-400',
      'dark:scrollbar-track-gray-900 dark:scrollbar-thumb-gray-700',
    ]}
  >
    <!-- Spinner inicial -->
    <div id="globalSpinnerInit">
      <div class="w-16 h-16 border-4 border-blue-600 border-t-transparent border-solid rounded-full animate-spin"></div>
    </div>
    <AuthGuard />
    <slot />

    <!-- MODAL DE SESIÓN -->
    <div id="tokenWarningModal" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden justify-center items-center">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-xl max-w-md w-full mx-4 shadow-xl">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Sesión por expirar</h2>
        <p class="text-sm text-gray-600 dark:text-gray-300 mb-4">Tu sesión expirará pronto. ¿Deseas extenderla?</p>
        <div class="flex justify-end gap-2">
          <button id="logoutNow" class="px-4 py-2 rounded-md bg-red-600 text-white hover:bg-red-700">Cerrar sesión</button>
          <button id="extendSession" class="px-4 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-700">Mantener sesión</button>
        </div>
      </div>
    </div>

    <!-- ELIMINA SPINNER CUANDO CARGUE -->
    <script>
      window.addEventListener('DOMContentLoaded', () => {
        const spinner = document.getElementById('globalSpinnerInit');
        if (spinner) spinner.remove();
      });
    </script>
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap');
</style>
