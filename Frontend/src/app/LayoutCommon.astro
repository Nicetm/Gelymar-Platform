---
import pkg from '../../package.json' assert { type: 'json' };
import { url } from '../lib/data.js';
import { SITE_TITLE } from './constants.js';
import AuthGuard from '../components/AuthGuard.astro';

const { class: clazz } = Astro.props;

// Construir CSP dinámica para connect-src según entornos
const apiPublic = import.meta.env.PUBLIC_API_URL || '';
const frontendPublic = import.meta.env.PUBLIC_FRONTEND_BASE_URL || '';

function toOrigin(u: string) {
  try {
    return new URL(u).origin;
  } catch {
    return '';
  }
}

function toWs(u: string) {
  try {
    const url = new URL(u);
    url.protocol = url.protocol === 'https:' ? 'wss:' : 'ws:';
    return `${url.protocol}//${url.host}`;
  } catch {
    return '';
  }
}

const apiOrigin = toOrigin(apiPublic);
const apiWsOrigin = toWs(apiPublic);
const frontendOrigin = toOrigin(frontendPublic);
const frontendWsOrigin = toWs(frontendPublic);

const connectSrc = [
  "'self'",
  'http://localhost:*',
  'http://backend:*',
  'https://api.gelymar.com',
  'ws://localhost:*',
  'wss://localhost:*',
  apiOrigin,
  apiWsOrigin,
  frontendOrigin,
  frontendWsOrigin,
  'https://cdn.socket.io',
  'https://unpkg.com'
].filter(Boolean).join(' ');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{SITE_TITLE}</title>
    <link rel="icon" type="image/svg+xml" href="/gelymar.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pkg.description} />
    <meta name="author" content="Sebastián Allende - Pablo Santibañez | Softkey" />
    <meta name="copyright" content="MIT" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="sitemap" type="application/xml" href={url('sitemap-index.xml')} />

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-XSS-Protection" content="1; mode=block" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=()" />
    
    <!-- Content Security Policy (connect-src dinámico para Socket.io/API) -->
    <meta http-equiv="Content-Security-Policy" content={`
      default-src 'self';
      script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://unpkg.com https://cdn.socket.io https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/;
      style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net;
      font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net;
      img-src 'self' data: https: blob:;
      connect-src ${connectSrc} https://www.google.com/recaptcha/;
      frame-src 'self' data: blob: https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/;
      object-src 'none';
      base-uri 'self';
      form-action 'self';
    `} />

    <!-- CSS del spinner inicial -->
    <style>
      #globalSpinnerInit {
        position: fixed;
        inset: 0;
        background-color: white;
        opacity: 0.8;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
      }
      html.dark #globalSpinnerInit {
        background-color: #111827;
      }
    </style>

    <!-- Socket.io -->
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script is:inline>
      (function() {
        try {
          const storedTheme = localStorage.getItem('color-theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const shouldUseDark = storedTheme === 'dark' || (!storedTheme && prefersDark);
          document.documentElement.classList.toggle('dark', shouldUseDark);
        } catch (_) {
          // ignore access issues (e.g., localStorage disabled)
        }
      })();
    </script>
    <script
      type="module"
      define:vars={{
        API_BASE: import.meta.env.PUBLIC_API_URL,
        FRONTEND_BASE: import.meta.env.PUBLIC_FRONTEND_BASE_URL
      }}
    >
      import { initLayoutCommon } from '/js/layout-common.js';

      initLayoutCommon({
        apiBase: API_BASE || '',
        frontendBase: FRONTEND_BASE || '',
      });
    </script>

  </head>

  <body
    class:list={[
      clazz,
      'bg-gray-50 dark:bg-gray-800',
      'scrollbar scrollbar-w-3 scrollbar-thumb-rounded-[0.25rem]',
      'scrollbar-track-slate-200 scrollbar-thumb-gray-400',
      'dark:scrollbar-track-gray-900 dark:scrollbar-thumb-gray-700',
    ]}
  >
    <!-- Spinner inicial -->
    <div id="globalSpinnerInit">
      <div class="w-16 h-16 border-4 border-blue-600 border-t-transparent border-solid rounded-full animate-spin"></div>
    </div>
    <AuthGuard />
    <slot />

    <!-- MODAL DE SESIÓN -->
    <div id="tokenWarningModal" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden justify-center items-center">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-xl max-w-md w-full mx-4 shadow-xl">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Sesión por expirar</h2>
        <p class="text-sm text-gray-600 dark:text-gray-300 mb-4">Tu sesión expirará pronto. ¿Deseas extenderla?</p>
        <div class="flex justify-end gap-2">
          <button id="logoutNow" class="px-4 py-2 rounded-md bg-red-600 text-white hover:bg-red-700">Cerrar sesión</button>
          <button id="extendSession" class="px-4 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-700">Mantener sesión</button>
        </div>
      </div>
    </div>

  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap');
</style>
