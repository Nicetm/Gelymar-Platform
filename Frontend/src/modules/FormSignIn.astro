<div class="w-full max-w-4xl mx-auto mt-10 animate-fade-in">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
    <!-- FORM -->
    <form id="loginForm" class="space-y-6" autocomplete="off" aria-label="Login form">
      <div>
        <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
          Email
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="user@company.com"
          class="input max-w-sm"
          autocomplete="username"
        />
      </div>

      <div>
        <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
          Password
        </label>
        <input
          type="password"
          id="password"
          name="password"
          required
          placeholder="••••••••"
          class="input max-w-sm"
          autocomplete="current-password"
        />
      </div>

			<!-- OTP (oculto por defecto) -->
			<div id="otpField" class="hidden">
				<label for="otp" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
					Código 2FA (Google Authenticator)
				</label>
				<input
					type="text"
					id="otp"
					name="otp"
					inputmode="numeric"
					pattern="[0-9]{6}"
					placeholder="123456"
					class="input max-w-sm"
				/>
			</div>

      <button
        type="submit"
        class="w-full px-5 py-3 text-base font-semibold text-white bg-[#00538C] rounded-lg hover:bg-[#003F6B] transition"
      >
        Sign in
      </button>

      <div class="text-sm text-gray-600 dark:text-gray-300">
        <a href="/authentication/forgot-password" class="hover:underline text-[#00538C]">
          Forgot password?
        </a>
      </div>

      <p class="text-xs text-gray-500 mt-4 italic">
        “Sustainable marine solutions since 1993.”
      </p>

      <p id="loginError" class="text-red-500 text-sm hidden mt-2" aria-live="polite">
        Invalid credentials
      </p>
    </form>

    <!-- QR -->
    <div id="qrWrapper" class="hidden flex flex-col items-center">
      <img
        id="qrImage"
        src=""
        alt="Código QR 2FA"
        class="w-56 h-56 rounded shadow-md border border-gray-300"
      />
      <p class="text-sm text-gray-600 mt-4 text-center">Escanea este código con Google Authenticator</p>
      <code id="qrSecret" class="mt-2 text-xs text-gray-500"></code>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const emailInput = document.getElementById('email');

    emailInput.addEventListener('blur', async () => {
      const email = emailInput.value.trim();
      if (!email) return;

      try {
        const res = await fetch(`http://localhost:3000/api/auth/2fa/setup?email=${encodeURIComponent(email)}`);
        if (!res.ok) {
          console.warn('No se encontró el QR para este usuario.');
          return;
        }

        const { qr } = await res.json();
        document.getElementById('qrImage').src = qr;
        document.getElementById('qrWrapper').classList.remove('hidden');
      } catch (err) {
        console.error('Error al obtener QR 2FA:', err);
      }
    });
  });

  // Handler del login
  document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = e.target.email.value.trim();
    const password = e.target.password.value.trim();
    const otp = e.target.otp?.value.trim(); // si agregas campo OTP más adelante

    try {
      const res = await fetch('http://localhost:3000/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password, otp })
      });

      const data = await res.json();

      if (!res.ok) {
        document.getElementById('loginError').textContent = data.message || 'Error';
        document.getElementById('loginError').classList.remove('hidden');
        return;
      }

      localStorage.setItem('token', data.token);
      const payload = JSON.parse(atob(data.token.split('.')[1]));
      window.location.href = payload.role === 'admin' ? '/admin/dashboard' : '/cliente/home';
    } catch {
      document.getElementById('loginError').textContent = 'Error de conexión';
      document.getElementById('loginError').classList.remove('hidden');
    }
  });

	document.addEventListener('DOMContentLoaded', () => {
  const emailInput = document.getElementById('email');

  emailInput.addEventListener('blur', async () => {
    const email = emailInput.value.trim();
    if (!email) return;

    try {
      const res = await fetch(`http://localhost:3000/api/auth/2fa/setup?email=${encodeURIComponent(email)}`);
      if (!res.ok) return;

      const { qr } = await res.json();

      // Mostrar QR
      document.getElementById('qrImage').src = qr;
      document.getElementById('qrWrapper').classList.remove('hidden');

      // Mostrar campo OTP
      document.getElementById('otpField').classList.remove('hidden');
    } catch (err) {
      console.error('Error al obtener QR 2FA:', err);
    }
  });
});
</script>

