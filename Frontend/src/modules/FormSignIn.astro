---
// import { asset } from '../lib/data.js';
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const apiPublic = import.meta.env.PUBLIC_API_URL;
const adminAppUrl = import.meta.env.PUBLIC_ADMIN_APP_URL || '';
const clientAppUrl = import.meta.env.PUBLIC_CLIENT_APP_URL || '';
const sellerAppUrl = import.meta.env.PUBLIC_SELLER_APP_URL || '';
const rawAppContext = (import.meta.env.PUBLIC_APP_CONTEXT || 'both').toLowerCase();
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';

const requestUrl = Astro.request?.url ? new URL(Astro.request.url) : null;
const requestOrigin = requestUrl?.origin ?? '';

const getOrigin = (value) => {
  if (!value) return '';
  try {
    return new URL(value, requestOrigin || 'http://localhost').origin;
  } catch {
    return '';
  }
};

const contextCandidates = [
  { key: 'admin', url: adminAppUrl },
  { key: 'client', url: clientAppUrl },
  { key: 'seller', url: sellerAppUrl },
];

const matchedByOrigin = contextCandidates.find(({ url }) => url && getOrigin(url) === requestOrigin)?.key;
const matchedByPath = (() => {
  const pathname = requestUrl?.pathname ?? '';
  if (pathname.startsWith('/admin')) return 'admin';
  if (pathname.startsWith('/client')) return 'client';
  if (pathname.startsWith('/seller')) return 'seller';
  return null;
})();

const activeAppContext =
  rawAppContext !== 'both'
    ? rawAppContext
    : matchedByOrigin || matchedByPath || 'admin';

const contextInfo = (() => {
  const normalized = activeAppContext;
  if (normalized === 'admin') {
    return {
      label: 'Admin Portal',
      helper: 'Exclusive access for internal staff',
      badgeClasses: 'bg-amber-100 text-amber-700 border border-amber-200'
    };
  }
  if (normalized === 'client') {
    return {
      label: 'Client Portal',
      helper: 'Login for external customers',
      badgeClasses: 'bg-emerald-100 text-emerald-700 border border-emerald-200'
    };
  }
  if (normalized === 'seller') {
    return {
      label: 'Seller Portal',
      helper: 'Login for external sellers',
      badgeClasses: 'bg-blue-100 text-blue-700 border border-blue-200'
    };
  }
  return null;
})();

---

<div class="w-full max-w-md mx-auto mt-10 space-y-6 animate-fade-in">

  <!-- Header -->
  <div class="flex flex-col items-center text-center gap-6">
    <!-- Logo + Nombre animado -->
    <div class="flex items-center gap-2">
      <img src="/assets/gelymar.svg" alt="Gelymar Logo" class="h-10 w-10"/>
      <span class="text-[2rem] font-bold tracking-tight text-[#002E50] dark:text-gray-100">
        Gelymar
      </span>
    </div>

  </div>

  <div class="text-center">
    <h1 class="text-2xl font-bold text-[#002E50]">
      {contextInfo?.label ?? 'Welcome back'}
    </h1>
    <p class="mt-1 text-sm text-[#002E50]/80">
      {contextInfo?.helper ?? 'Access your dashboard and documentation tools.'}
    </p>
  </div>
  
  <!-- Mensaje de contraseña actualizada -->
  <p id="resetSuccessMessage" class="text-sm text-center text-green-600 hidden">
    Your password has been updated. You can now log in.
  </p>

  <form id="loginForm" class="space-y-6" method="POST" action="javascript:void(0);" onsubmit="return false;" novalidate>
    <!-- Username -->
    <div class="relative">
      <label for="username" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        Username
      </label>
      <input
        type="text"
        id="username"
        name="username"
        required
        autocomplete="username"
        class="input"
        placeholder="Enter your username"
      />
    
      <div class="group absolute right-2 top-9">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-5 h-5 text-gray-400 cursor-help"
        >
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M8.625 9.75a3.375 3.375 0 016.75 0c0 1.875-3.375 1.875-3.375 3.75m0 3.75h.008v.008h-.008v-.008z" />
        </svg>
        <!-- Tooltip -->
        <span
          class="absolute hidden group-hover:block bg-blue-800 text-white text-xs rounded px-3 py-2 -top-11 right-0 whitespace-nowrap">
          e.g., 15000222-4
        </span>
      </div>
    </div>

    <!-- Password -->
    <div>
      <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Password</label>
      <input type="password" id="password" name="password" required class="input" placeholder="••••••••" autocomplete="current-password"/>
    </div>

    {recaptchaSiteKey && (
      <div class="flex justify-center">
        <div class="g-recaptcha" data-sitekey={recaptchaSiteKey}></div>
      </div>
    )}

    <!-- OTP input -->
    <div id="otpContainer" class="hidden">
      <label for="otp" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">2FA Code</label>
      <input type="text" id="otp" name="otp" class="input" placeholder="123456"/>
    </div>

    <!-- QR -->
    <div id="qrContainer" class="hidden text-center">
      <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">
        Scan this QR code in Google Authenticator:
      </p>
      <img id="qrImage" class="w-40 h-40 mx-auto rounded border" />
    </div>

    <!-- Dynamic message -->
    <p id="loginMessage" class="text-sm text-center hidden mt-1"></p>

    <!-- Submit -->
    <button
      type="submit"
      class="w-full px-5 py-3 text-base font-semibold text-white bg-[#00538C] rounded-lg hover:bg-[#003F6B] transition hover:scale-[1.01] active:scale-[.98]"
    >
      Sign in
    </button>
  </form>
</div>

</div>

<style is:global>
  .input {
    @apply bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-[#00538C] focus:border-[#00538C];
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fade-in 0.5s ease-out both;
  }
</style>

<script type="module" define:vars={{ apiPublic, apiBase, adminAppUrl, clientAppUrl, sellerAppUrl, appContext: activeAppContext, recaptchaSiteKey }}>
  import { initSignIn } from '/js/sign-in.js';

  initSignIn({
    apiPublic,
    apiBase,
    adminAppUrl,
    clientAppUrl,
    sellerAppUrl,
    appContext,
    recaptchaSiteKey,
  });
</script>

