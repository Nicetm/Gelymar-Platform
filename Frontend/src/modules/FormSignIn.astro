---
// import { asset } from '../lib/data.js';
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const apiPublic = import.meta.env.PUBLIC_API_URL;
const adminAppUrl = import.meta.env.PUBLIC_ADMIN_APP_URL || '';
const clientAppUrl = import.meta.env.PUBLIC_CLIENT_APP_URL || '';
const appContext = import.meta.env.PUBLIC_APP_CONTEXT || 'both';
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';

const contextInfo = (() => {
  const normalized = appContext.toLowerCase();
  if (normalized === 'admin') {
    return {
      label: 'Admin Portal',
      helper: 'Exclusive access for internal staff',
      badgeClasses: 'bg-amber-100 text-amber-700 border border-amber-200'
    };
  }
  if (normalized === 'client') {
    return {
      label: 'Client Portal',
      helper: 'Login for external customers',
      badgeClasses: 'bg-emerald-100 text-emerald-700 border border-emerald-200'
    };
  }
  return null;
})();

---

<div class="w-full max-w-md mx-auto mt-10 space-y-6 animate-fade-in">

  <!-- Header -->
  <div class="flex flex-col items-center text-center gap-6">
    <!-- Logo + Nombre animado -->
    <div class="flex items-center gap-2">
      <img src="/assets/gelymar.svg" alt="Gelymar Logo" class="h-10 w-10"/>
      <span class="text-[2rem] font-bold tracking-tight text-[#002E50] dark:text-gray-100">
        Gelymar
      </span>
    </div>

  </div>

  <div class="text-center">
    <h1 class="text-2xl font-bold text-[#002E50]">
      {contextInfo?.label ?? 'Welcome back'}
    </h1>
    <p class="mt-1 text-sm text-[#002E50]/80">
      {contextInfo?.helper ?? 'Access your dashboard and documentation tools.'}
    </p>
  </div>
  
  <!-- Mensaje de contraseña actualizada -->
  <p id="resetSuccessMessage" class="text-sm text-center text-green-600 hidden">
    Your password has been updated. You can now log in.
  </p>

  <form id="loginForm" class="space-y-6" method="POST" action="javascript:void(0);" onsubmit="return false;" novalidate>
    <!-- Username -->
    <div class="relative">
      <label for="username" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        Username
      </label>
      <input
        type="text"
        id="username"
        name="username"
        required
        class="input"
        placeholder="Enter your username"
      />
    
      <div class="group absolute right-2 top-9">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-5 h-5 text-gray-400 cursor-help"
        >
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M8.625 9.75a3.375 3.375 0 016.75 0c0 1.875-3.375 1.875-3.375 3.75m0 3.75h.008v.008h-.008v-.008z" />
        </svg>
        <!-- Tooltip -->
        <span
          class="absolute hidden group-hover:block bg-blue-800 text-white text-xs rounded px-3 py-2 -top-11 right-0 whitespace-nowrap">
          e.g., 15000222-4
        </span>
      </div>
    </div>

    <!-- Password -->
    <div>
      <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Password</label>
      <input type="password" id="password" name="password" required class="input" placeholder="••••••••" autocomplete="current-password"/>
    </div>

    {recaptchaSiteKey && (
      <div class="flex justify-center">
        <div class="g-recaptcha" data-sitekey={recaptchaSiteKey}></div>
      </div>
    )}

    <!-- OTP input -->
    <div id="otpContainer" class="hidden">
      <label for="otp" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">2FA Code</label>
      <input type="text" id="otp" name="otp" class="input" placeholder="123456"/>
    </div>

    <!-- QR -->
    <div id="qrContainer" class="hidden text-center">
      <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">
        Scan this QR code in Google Authenticator:
      </p>
      <img id="qrImage" class="w-40 h-40 mx-auto rounded border" />
    </div>

    <!-- Dynamic message -->
    <p id="loginMessage" class="text-sm text-center hidden mt-1"></p>

    <!-- Submit -->
    <button
      type="submit"
      class="w-full px-5 py-3 text-base font-semibold text-white bg-[#00538C] rounded-lg hover:bg-[#003F6B] transition hover:scale-[1.01] active:scale-[.98]"
    >
      Sign in
    </button>
  </form>
</div>

</div>

<style is:global>
  .input {
    @apply bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-[#00538C] focus:border-[#00538C];
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fade-in 0.5s ease-out both;
  }
</style>

<script is:inline define:vars={{ apiPublic, apiBase, adminAppUrl, clientAppUrl, appContext, recaptchaSiteKey }}>

  let otpShown = false;

  const normalizedAdminUrl = adminAppUrl && adminAppUrl.trim() !== '' ? adminAppUrl.trim() : '/admin/';
  const normalizedClientUrl = clientAppUrl && clientAppUrl.trim() !== '' ? clientAppUrl.trim() : '/client/';
  const normalizedAppContext = (appContext || 'both').toLowerCase();
  localStorage.removeItem('token');
  localStorage.removeItem('orders_cache');
  localStorage.removeItem('customers_cache');
  localStorage.removeItem('orders_cache_timestamp');
  localStorage.removeItem('customers_cache_timestamp');
  localStorage.removeItem('customersWithoutAccount');

  const isAbsoluteUrl = (url) => /^https?:\/\//i.test(url);
  const navigateTo = (targetUrl) => {
    if (!targetUrl) return;
    if (isAbsoluteUrl(targetUrl)) {
      window.location.href = targetUrl;
    } else {
      window.location.href = targetUrl.startsWith('/') ? targetUrl : `/${targetUrl}`;
    }
  };

  const showPortalMismatchMessage = (message) => {
    const msg = document.getElementById('loginMessage');
    msg.textContent = message;
    msg.classList.remove('hidden');
    msg.classList.remove('text-green-600', 'text-blue-600');
    msg.classList.add('text-red-500');
  };

  // Mostrar mensaje si viene de reseteo de contrasena
  const params = new URLSearchParams(window.location.search);
  if (params.get('reset') === 'success') {
    document.getElementById('resetSuccessMessage').classList.remove('hidden');
  }

  // Event listener único para el formulario
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('loginForm');

    if (recaptchaSiteKey) {
      const existingScript = document.querySelector('script[src*="recaptcha/api.js"]');
      if (!existingScript) {
        const script = document.createElement('script');
        script.src = 'https://www.google.com/recaptcha/api.js';
        script.async = true;
        script.defer = true;
        document.head.appendChild(script);
      }
    }

    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        e.stopPropagation();
        
        // Obtener datos del formulario
        const formData = new FormData(e.target);
        const username = formData.get('username')?.trim() || '';
        const password = formData.get('password') || '';
        const otp = formData.get('otp')?.trim() || '';
        let captchaResponse = '';

        if (recaptchaSiteKey) {
          if (!window.grecaptcha || typeof window.grecaptcha.getResponse !== 'function') {
            const msg = document.getElementById('loginMessage');
            msg.textContent = 'Captcha is not ready yet. Please wait a moment and try again.';
            msg.classList.remove('hidden');
            msg.classList.remove('text-green-600');
            msg.classList.add('text-red-500');
            return;
          }

          captchaResponse = window.grecaptcha.getResponse();
          if (!captchaResponse) {
            const msg = document.getElementById('loginMessage');
            msg.textContent = 'Please confirm you are not a robot';
            msg.classList.remove('hidden');
            msg.classList.remove('text-green-600');
            msg.classList.add('text-red-500');
            return;
          }
        }

        // Validación básica
        if (!username || !password) {
          const msg = document.getElementById('loginMessage');
          msg.textContent = 'Please complete all required fields';
          msg.classList.remove('hidden');
          msg.classList.remove('text-green-600');
          msg.classList.add('text-red-500');
          return;
        }
        
        const msg = document.getElementById('loginMessage');
        msg.classList.add('hidden');
        msg.textContent = 'Iniciando sesión...';
        msg.classList.remove('hidden');
        msg.classList.remove('text-red-500');
        msg.classList.add('text-blue-600');

        try {
          const res = await fetch(`${apiPublic}/api/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password, otp, captchaResponse })
          });

          const data = await res.json();

          if (!res.ok) {
            if ((data.message?.toLowerCase().includes('2fa') || data.message?.toLowerCase().includes('código 2fa')) && !otpShown) {
              otpShown = true;
              document.getElementById('otpContainer').classList.remove('hidden');

              const statusRes = await fetch(`${apiPublic}/api/auth/2fa/status?username=${encodeURIComponent(username)}`);
              const { twoFAEnabled } = await statusRes.json();

              if (!twoFAEnabled) {
                document.getElementById('qrContainer').classList.remove('hidden');
                const qrRes = await fetch(`${apiPublic}/api/auth/2fa/setup?username=${encodeURIComponent(username)}`);
                const { qr } = await qrRes.json();
                document.getElementById('qrImage').src = qr;
              }

              msg.textContent = 'Please enter your 2FA code from the authenticator app.';
              msg.classList.remove('hidden');
              msg.classList.remove('text-red-500');
              msg.classList.add('text-green-600');
              return;
            }

            msg.textContent = data.message || 'Login failed';
            msg.classList.remove('hidden');
            msg.classList.remove('text-green-600');
            msg.classList.add('text-red-500');
            return;
          }

          // Guardar token y datos adicionales
          localStorage.setItem('token', data.token);
          document.cookie = `token=${data.token}; path=/; SameSite=Strict`;
          
          // Guardar cantidad de clientes sin cuenta
          if (data.customersWithoutAccount !== undefined) {
            localStorage.setItem('customersWithoutAccount', data.customersWithoutAccount);
          }

          // Obtener rol del usuario
          try {
            const meRes = await fetch(`${apiPublic}/api/auth/me`, {
              headers: { Authorization: `Bearer ${data.token}` }
            });

            if (meRes.ok) {
              const user = await meRes.json();
              const userRole = user.role || ((user.role_id === 1 || user.role_id === 3) ? 'admin' : 'client');
              
              // Verificar si debe cambiar password
              if (user.change_pw === 0) {
                localStorage.setItem('userRole', userRole);
                window.location.href = '/authentication/change-password';
                return;
              }

              localStorage.setItem('cfg', user.role_cfg);
              localStorage.setItem('userRole', userRole);

              // Redirigir según rol
              if (userRole === 'admin') {
                if (normalizedAppContext === 'client' && !isAbsoluteUrl(normalizedAdminUrl)) {
                  showPortalMismatchMessage('Acceso de administracion disponible solo desde la intranet. Usa el portal interno.');
                  return;
                }
                navigateTo(normalizedAdminUrl);
              } else {
                if (normalizedAppContext === 'admin' && !isAbsoluteUrl(normalizedClientUrl)) {
                  showPortalMismatchMessage('Portal de clientes disponible en el dominio publico. Usa la URL de clientes.');
                  return;
                }
                navigateTo(normalizedClientUrl);
              }
            } else {
              msg.textContent = 'Error validando usuario';
              msg.classList.remove('hidden');
              msg.classList.add('text-red-500');
            }
          } catch (error) {
            console.error('Error obteniendo rol:', error);
            msg.textContent = 'Error validando usuario';
            msg.classList.remove('hidden');
            msg.classList.add('text-red-500');
          }

        } catch (err) {
          console.error('Error en login:', err); // Debug
          msg.textContent = 'Connection error';
          msg.classList.remove('hidden');
          msg.classList.add('text-red-500');
        } finally {
          if (recaptchaSiteKey && window.grecaptcha && typeof window.grecaptcha.reset === 'function') {
            window.grecaptcha.reset();
          }
        }
      });
    }
  });
</script>

