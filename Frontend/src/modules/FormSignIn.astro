<div class="w-full max-w-4xl mx-auto mt-10 animate-fade-in">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
    <!-- FORM -->
    <form id="loginForm" class="space-y-6" autocomplete="off" aria-label="Login form">
      <div>
        <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Email</label>
        <input type="email" id="email" name="email" required placeholder="user@company.com" class="input max-w-sm" autocomplete="username" />
      </div>

      <div>
        <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Password</label>
        <input type="password" id="password" name="password" required placeholder="••••••••" class="input max-w-sm" autocomplete="current-password" />
      </div>

      <!-- OTP -->
      <div id="otpField" class="hidden">
        <label for="otp" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Código 2FA (Google Authenticator)</label>
        <input type="text" id="otp" name="otp" inputmode="numeric" pattern="[0-9]{6}" placeholder="123456" class="input max-w-sm" />
      </div>

      <!-- Reintentar setup -->
      <div id="showSetupBtnWrapper" class="hidden">
        <button id="showSetupBtn" type="button" class="mt-2 text-sm text-[#00538C] underline hover:text-[#003F6B]">
          ¿No pudiste escanear el código? Haz clic aquí para reintentarlo.
        </button>
      </div>

      <button type="submit" class="w-full px-5 py-3 text-base font-semibold text-white bg-[#00538C] rounded-lg hover:bg-[#003F6B] transition">Sign in</button>

      <div class="text-sm text-gray-600 dark:text-gray-300">
        <a href="/authentication/forgot-password" class="hover:underline text-[#00538C]">Forgot password?</a>
      </div>

      <p class="text-xs text-gray-500 mt-4 italic">“Sustainable marine solutions since 1993.”</p>

      <p id="loginError" class="text-red-500 text-sm hidden mt-2" aria-live="polite">Invalid credentials</p>
    </form>
  </div>
</div>

<!-- Modal 2FA Setup -->
<div id="setupModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
	<div class="bg-white dark:bg-gray-800 rounded-xl p-6 w-full max-w-sm shadow-2xl relative">
		<button id="closeModal" class="absolute top-2 right-4 text-gray-500 hover:text-gray-800 text-2xl font-bold">&times;</button>

		<h2 class="text-xl font-semibold mb-4 text-center text-gray-900 dark:text-white">
			Configura tu autenticación 2FA
		</h2>

		<p class="text-sm text-gray-600 dark:text-gray-300 mb-4 text-center">
			Escanea el código QR con Google Authenticator o Authy.<br />
			También puedes copiar el código manual a continuación.
		</p>

		<div class="flex justify-center mb-4">
			<img id="qrImage" class="w-44 h-44 border border-gray-300 rounded shadow" alt="QR Code 2FA" />
		</div>

		<div class="text-center mt-4">
			<label for="qrSecret" class="text-sm text-gray-700 dark:text-gray-300 mb-1 block">Código manual:</label>
			<div id="qrSecret"
					class="bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-white font-mono px-3 py-2 rounded-md text-sm tracking-widest inline-block max-w-full break-words select-all">
				<!-- El código se inserta dinámicamente -->
			</div>
		</div>
	</div>
</div>

<style is:global>
  .input {
    @apply bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-[#00538C] focus:border-[#00538C];
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fade-in 0.5s ease-out both;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const emailInput = document.getElementById('email');
    const otpField = document.getElementById('otpField');
    const setupModal = document.getElementById('setupModal');
    const closeModal = document.getElementById('closeModal');
    const qrImage = document.getElementById('qrImage');
    const qrSecret = document.getElementById('qrSecret');
    const showSetupBtnWrapper = document.getElementById('showSetupBtnWrapper');
    const showSetupBtn = document.getElementById('showSetupBtn');

    emailInput.addEventListener('blur', async () => {
      const email = emailInput.value.trim();
      if (!email) return;

      try {
        const statusRes = await fetch(`http://localhost:3000/api/auth/2fa/status?email=${encodeURIComponent(email)}`);
        const { twoFAEnabled } = await statusRes.json();

        if (twoFAEnabled) {
          otpField.classList.remove('hidden');
        } else {
          const setupRes = await fetch(`http://localhost:3000/api/auth/2fa/setup?email=${encodeURIComponent(email)}`);
          if (!setupRes.ok) {
            alert('Este usuario no existe. No se puede configurar 2FA.');
            return;
          }

          const { qr, secret } = await setupRes.json();
          qrImage.src = qr;
          qrSecret.textContent = secret;
          setupModal.classList.remove('hidden');
        }
      } catch (err) {
        console.error('Error verificando estado 2FA:', err);
      }
    });

    closeModal.addEventListener('click', () => {
      setupModal.classList.add('hidden');
      otpField.classList.remove('hidden');
      showSetupBtnWrapper.classList.remove('hidden');
    });

    showSetupBtn.addEventListener('click', async () => {
      const email = emailInput.value.trim();
      if (!email) return;

      try {
        const setupRes = await fetch(`http://localhost:3000/api/auth/2fa/setup?email=${encodeURIComponent(email)}`);
        if (!setupRes.ok) {
          alert('No se pudo recuperar el QR. Verifica tu email.');
          return;
        }

        const { qr, secret } = await setupRes.json();
        qrImage.src = qr;
        qrSecret.textContent = secret;
        setupModal.classList.remove('hidden');
        otpField.classList.add('hidden');
        showSetupBtnWrapper.classList.add('hidden');
      } catch (err) {
        console.error('Error al recargar QR:', err);
      }
    });

    document.getElementById('loginForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = e.target.email.value.trim();
      const password = e.target.password.value.trim();
      const otp = e.target.otp?.value.trim();

      try {
        const res = await fetch('http://localhost:3000/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password, otp })
        });

        const data = await res.json();

        if (!res.ok) {
          document.getElementById('loginError').textContent = data.message || 'Error';
          document.getElementById('loginError').classList.remove('hidden');
          return;
        }

        localStorage.setItem('token', data.token);
        const payload = JSON.parse(atob(data.token.split('.')[1]));
        window.location.href = payload.role === 'admin' ? '/admin/dashboard' : '/cliente/home';
      } catch {
        document.getElementById('loginError').textContent = 'Error de conexión';
        document.getElementById('loginError').classList.remove('hidden');
      }
    });
  });
</script>
