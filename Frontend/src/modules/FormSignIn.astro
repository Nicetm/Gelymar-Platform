---
// import { asset } from '../lib/data.js';
const apiBase = import.meta.env.PUBLIC_API_URL;
---

<div class="w-full max-w-md mx-auto mt-10 space-y-6 animate-fade-in">
  <!-- Mensaje de contraseña actualizada -->
  <p id="resetSuccessMessage" class="text-sm text-center text-green-600 hidden">
    Your password has been updated. You can now log in.
  </p>

  <form id="loginForm" class="space-y-6">
    <!-- Username -->
    <div>
      <label for="username" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Username</label>
      <input type="text" id="username" name="username" required class="input" placeholder="Enter your username" autocomplete="username"/>
    </div>

    <!-- Password -->
    <div>
      <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Password</label>
      <input type="password" id="password" name="password" required class="input" placeholder="••••••••" autocomplete="current-password"/>
    </div>

    <!-- OTP input -->
    <div id="otpContainer" class="hidden">
      <label for="otp" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">2FA Code</label>
      <input type="text" id="otp" name="otp" class="input" placeholder="123456"/>
    </div>

    <!-- QR -->
    <div id="qrContainer" class="hidden text-center">
      <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">
        Scan this QR code in Google Authenticator:
      </p>
      <img id="qrImage" class="w-40 h-40 mx-auto rounded border" />
    </div>

    <!-- Dynamic message -->
    <p id="loginMessage" class="text-sm text-center hidden mt-1"></p>

    <!-- Submit -->
    <button
      type="submit"
      class="w-full px-5 py-3 text-base font-semibold text-white bg-[#00538C] rounded-lg hover:bg-[#003F6B] transition hover:scale-[1.01] active:scale-[.98]"
    >
      Sign in
    </button>
  </form>
</div>

</div>

<style is:global>
  .input {
    @apply bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-[#00538C] focus:border-[#00538C];
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fade-in 0.5s ease-out both;
  }
</style>

<script is:inline define:vars={{ apiBase }}>
  let otpShown = false;

  // Mostrar mensaje si viene de reseteo de contraseña
  const params = new URLSearchParams(window.location.search);
  if (params.get('reset') === 'success') {
    document.getElementById('resetSuccessMessage').classList.remove('hidden');
  }

  document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const username = e.target.username.value.trim();
    const password = e.target.password.value.trim();
    const otp = e.target.otp?.value?.trim();
    const msg = document.getElementById('loginMessage');

    msg.classList.add('hidden');
    console.log(apiBase)

    try {
      const res = await fetch(`${apiBase}/api/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password, otp })
      });

      const data = await res.json();

      if (!res.ok) {
        if ((data.message?.toLowerCase().includes('2fa') || data.message?.toLowerCase().includes('código 2fa')) && !otpShown) {
          otpShown = true;
          document.getElementById('otpContainer').classList.remove('hidden');

          const statusRes = await fetch(`${apiBase}/api/auth/2fa/status?username=${encodeURIComponent(username)}`);
          const { twoFAEnabled } = await statusRes.json();

          if (!twoFAEnabled) {
            document.getElementById('qrContainer').classList.remove('hidden');
            const qrRes = await fetch(`${apiBase}/api/auth/2fa/setup?username=${encodeURIComponent(username)}`);
            const { qr } = await qrRes.json();
            document.getElementById('qrImage').src = qr;
          }

          msg.textContent = 'Please enter your 2FA code from the authenticator app.';
          msg.classList.remove('hidden');
          msg.classList.remove('text-red-500');
          msg.classList.add('text-green-600');
          return;
        }

        msg.textContent = data.message || 'Login failed';
        msg.classList.remove('hidden');
        msg.classList.remove('text-green-600');
        msg.classList.add('text-red-500');
        return;
      }

      // ✅ Guardar token
			document.cookie = `token=${data.token}; path=/; SameSite=Strict`;
      localStorage.setItem('token', data.token);

      // ✅ Consultar /me para obtener el rol seguro
      console.log('🔍 Llamando a /me con token:', data.token.substring(0, 20) + '...');
      
      const meRes = await fetch(`${apiBase}/api/auth/me`, {
        headers: {
          Authorization: `Bearer ${data.token}`
        }
      });

      console.log('🔍 Respuesta de /me:', meRes.status, meRes.statusText);

      if (!meRes.ok) {
        const errorText = await meRes.text();
        console.log('🔍 Error en /me:', errorText);
        msg.textContent = 'Error validando usuario';
        msg.classList.remove('hidden');
        msg.classList.add('text-red-500');
        return;
      }

      const user = await meRes.json();
      console.log('🔍 Usuario obtenido:', user);

      // ✅ Verificar si debe cambiar password
      if (user.change_pw === 0) {
        console.log('🔍 Usuario debe cambiar password');
        localStorage.setItem('userRole', user.role);
        window.location.href = '/authentication/change-password';
        return;
      }

      // ✅ Redirigir según rol real
      if (user.role === 'admin') {
        console.log('🔍 Redirigiendo a admin');
        window.location.href = '/admin/';
      } else {
        console.log('🔍 Redirigiendo a client');
        window.location.href = '/client/';
      }

    } catch (err) {
      msg.textContent = 'Connection error';
      msg.classList.remove('hidden');
      msg.classList.add('text-red-500');
    }
  });


</script>

