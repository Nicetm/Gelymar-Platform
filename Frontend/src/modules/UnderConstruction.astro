---
// import { url } from '../lib/data.js';
---

<!-- Wrapper full-height -->
<div class="flex flex-col justify-center items-center px-6 py-12 mx-auto min-h-[60vh] xl:px-0 bg-white dark:bg-gradient-to-b dark:from-gray-900 dark:to-gray-800">

  <!-- Ilustración -->
  <div class="w-[20rem] md:w-[32rem] h-auto mb-6 relative">
    <img
      src="/assets/3518832.webp"
      alt="Under construction illustration"
      class="w-full h-auto object-contain drop-shadow-2xl dark:brightness-95"
      loading="lazy"
    />
  </div>

  <!-- Texto -->
  <div class="text-center max-w-2xl">
    <h1 class="mb-3 text-2xl md:text-4xl font-bold text-gray-900 dark:text-white">
      This section is currently under maintenance
    </h1>
    <p class="mb-6 text-gray-600 md:text-base dark:text-gray-400">
      We’re fine-tuning this area to give you the best experience.<br />
      Please check back again soon!
    </p>

  </div>
</div>