---
// import { url } from '../lib/data.js';
---

<!-- Wrapper -->
<div class="relative overflow-hidden flex flex-col justify-center items-center min-h-screen px-6 py-12 bg-gradient-to-b from-white to-slate-50 dark:from-gray-900 dark:to-gray-800">

  <!-- Decorative blobs -->
  <span class="absolute -top-24 -left-24 w-80 h-80 bg-[#00538C]/20 rounded-full blur-3xl pointer-events-none"></span>
  <span class="absolute bottom-0 -right-24 w-96 h-96 bg-[#F6B234]/20 dark:bg-[#F6B234]/10 rounded-full blur-3xl pointer-events-none"></span>

  <!-- Glass-card -->
  <div class="flex flex-col items-center bg-white/70 dark:bg-gray-900/60 backdrop-blur-sm border border-white/30 dark:border-gray-700 rounded-xl p-10 shadow-xl">

    <!-- Illustration -->
    <div class="w-[20rem] md:w-[32rem] h-auto mb-6 relative animate-float">
      <img
        src="/assets/3518832.webp"
        alt="Under construction illustration"
        class="w-full h-auto object-contain drop-shadow-2xl dark:brightness-95"
        loading="lazy"
      />
    </div>

    <!-- Text -->
    <div class="text-center max-w-2xl">
      <h1 class="mb-3 text-3xl md:text-5xl font-bold text-gray-900 dark:text-white">
        This section is currently under maintenance<br class="hidden md:block" />
        <span class="text-lg font-medium md:text-xl text-gray-500 dark:text-gray-400">We’ll be back shortly</span>
      </h1>

      <p class="mb-8 text-gray-600 md:text-base dark:text-gray-400">
        We’re fine-tuning things to give you the best experience.<br />
        Please check back again soon!
      </p>

      <a
        href="/admin/"
        class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-[#00538C] text-white font-semibold shadow-lg hover:bg-[#004773] focus:outline-none focus:ring-2 focus:ring-[#00538C]/50 transition"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 9l9-7 9 7v11a2 2 0 01-2 2h-4a2 2 0 01-2-2V9m-6 0v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
        </svg>
        Back to Admin
      </a>
    </div><!-- /text -->
  </div><!-- /glass-card -->
</div>

<style is:inline>
  @layer utilities {
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(-6px); }
    }
    .animate-float {
      animation: float 4s ease-in-out infinite;
    }
  }
</style>