---
// import { asset } from '../lib/data.js';
---

<div class="w-full max-w-md mx-auto px-6 pt-2 animate-fade-in-up">
  <form class="mt-6 space-y-5" id="forgotForm">
    <!-- Email -->
    <div>
      <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        Your email
      </label>
      <input
        type="email"
        name="email"
        id="email"
        placeholder="name@company.com"
        class="input"
        required
      />
    </div>

    <!-- Mensaje -->
    <p id="forgotMessage" class="text-sm text-center hidden"></p>

    <!-- Botón -->
    <button
      type="submit"
      class="w-full px-5 py-3 text-base font-semibold text-white rounded-lg bg-[#00538C] hover:bg-[#003F6B] transition duration-300"
    >
      Send reset link
    </button>
  </form>
</div>

<style is:global>
  .input {
    @apply bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-[#00538C] focus:border-[#00538C];
  }

  @keyframes fade-in-up {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out both;
  }
</style>

<script is:inline>
  import { validateForm, showFormErrors, clearFormErrors, sanitizeText } from '/src/lib/validation.js';
  import { logSuspiciousActivity } from '/src/lib/security.js';
  import { checkRateLimit, recordFailedAttempt } from '/src/lib/rateLimiter.js';
  
  // Reglas de validación para recuperación de contraseña
  const forgotPasswordValidationRules = {
    email: {
      required: true,
      requiredMessage: 'El email es requerido',
      type: 'email',
      message: 'Email inválido'
    }
  };

  document.getElementById('forgotForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Limpiar errores anteriores
    clearFormErrors(e.target);

    // Verificar rate limiting
    const rateLimitCheck = checkRateLimit('PASSWORD_RESET');
    if (!rateLimitCheck.allowed) {
      const message = document.getElementById('forgotMessage');
      message.textContent = rateLimitCheck.message;
      message.className = 'text-sm text-center mt-2 text-red-600';
      message.classList.remove('hidden');
      return;
    }

    // Validar formulario
    const validation = validateForm(e.target, forgotPasswordValidationRules);
    if (!validation.isValid) {
      showFormErrors(e.target, validation.errors);
      return;
    }

    // Sanitizar email
    const email = sanitizeText(validation.data.email, { 
      maxLength: 100, 
      lowercase: true 
    });
    
    const message = document.getElementById('forgotMessage');

    message.classList.add('hidden');

    try {
      const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/auth/recover`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      const data = await res.json();
      
      if (!res.ok) {
        // Registrar intento fallido para rate limiting
        recordFailedAttempt('PASSWORD_RESET', email);
        
        // Registrar actividad sospechosa
        logSuspiciousActivity('password_reset_failed', {
          email: email,
          reason: data.message
        });
      }
      
      message.textContent = data.message || "Email sent.";
      message.className = `text-sm text-center mt-2 ${res.ok ? 'text-green-600' : 'text-red-600'}`;

      message.classList.remove('hidden');
    } catch (error) {
      // Registrar intento fallido para rate limiting
      recordFailedAttempt('PASSWORD_RESET', email);
      
      message.textContent = "Connection error.";
      message.className = 'text-sm text-center mt-2 text-red-600';
      message.classList.remove('hidden');
    }
  });
</script>
