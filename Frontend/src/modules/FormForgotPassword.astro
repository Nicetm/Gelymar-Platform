---
// import { asset } from '../lib/data.js';
import { loadTranslations, getServerLang } from '@lib/i18n.js';
const apiPublic = import.meta.env.PUBLIC_API_URL;
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';
const rawAppContext = (import.meta.env.PUBLIC_APP_CONTEXT || 'both').toLowerCase();
const lang = getServerLang(Astro.cookies);

let t: any = {};
try {
  t = {
    comond: await loadTranslations(lang, 'comond')
  };
} catch (error) {
  console.error('Error loading translations (FormForgotPassword):', error);
}

// Detect portal
const activeAppContext = rawAppContext !== 'both' ? rawAppContext : 'admin';

// Fetch captcha config for this portal
let captchaConfig = { active: 0, type: null };
try {
  const response = await fetch(`${apiBase}/api/config/recaptcha-login?portal=${activeAppContext}`);
  if (response.ok) captchaConfig = await response.json();
} catch (error) {
  console.error('[FormForgotPassword] Error loading captcha config:', error);
}
const captchaType = captchaConfig.active === 1 ? (captchaConfig.type || null) : null;
---

<div class="w-full max-w-md mx-auto mt-10 space-y-6 animate-fade-in">
  <!-- Header -->
  <div class="flex flex-col items-center text-center gap-6">
    <div class="flex items-center gap-2">
      <img src="/assets/gelymar.svg" alt="Gelymar Logo" class="h-10 w-10"/>
      <span class="text-[2rem] font-bold tracking-tight text-[#002E50] dark:text-gray-100">
        Gelymar
      </span>
    </div>
  </div>

  <div class="text-center">
    <h1 class="text-2xl font-bold text-[#002E50]">
      {t?.comond?.reset_password_title}
    </h1>
    <p class="mt-1 text-sm text-[#002E50]/80">
      {t?.comond?.reset_helper}
    </p>
  </div>

  <form class="space-y-5" id="forgotForm" method="post">
    <!-- Email -->
    <div>
      <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        {t?.comond?.email_label}
      </label>
      <input
        type="email"
        name="email"
        id="email"
        placeholder={t?.comond?.email_placeholder}
        class="input"
        required
      />
    </div>

    <!-- Mensaje -->
    <p id="forgotMessage" class="text-sm text-center hidden"></p>

    {captchaType === 'captcha-google' && recaptchaSiteKey && (
      <div class="flex justify-center">
        <div class="g-recaptcha" data-sitekey={recaptchaSiteKey}></div>
      </div>
    )}

    {captchaType === 'self-hosted' && (
      <div id="puzzleCaptchaContainer" class="flex justify-center"></div>
    )}

    <!-- Botón -->
    <button
      type="submit"
      id="forgotSubmitBtn"
      class="w-full px-5 py-3 text-base font-semibold text-white rounded-lg bg-[#00538C] hover:bg-[#003F6B] transition duration-300 inline-flex items-center justify-center gap-2"
    >
      {t?.comond?.send_reset_link}
    </button>
  </form>
</div>

<script type="module" define:vars={{ apiPublic, recaptchaSiteKey, captchaType, activeAppContext, comondTranslations: t?.comond ?? {} }}>
  const apiBase = apiPublic || window.location.origin;
  let puzzleVerificationToken = null;

  // Init puzzle captcha if needed
  if (captchaType === 'self-hosted') {
    const container = document.getElementById('puzzleCaptchaContainer');
    if (container) {
      import('/js/puzzle-captcha.js').then(({ initPuzzleCaptcha }) => {
        const captcha = initPuzzleCaptcha(container, {
          apiUrl: apiBase,
          portal: activeAppContext,
          onVerified: (token) => {
            puzzleVerificationToken = token;
            const frm = document.getElementById('forgotForm');
            if (frm) frm.requestSubmit();
          },
        });
        window._puzzleCaptchaForgot = captcha;
      });
    }
  }
  const forgotPasswordValidationRules = {
    email: {
      required: true,
      requiredMessage: comondTranslations.email_required,
      type: 'email',
      message: comondTranslations.email_invalid
    }
  };

  const isValidEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);

  const validateForm = (form, rules) => {
    const data = {};
    const errors = {};

    for (const [fieldName, rule] of Object.entries(rules)) {
      const field = form.querySelector(`#${fieldName}`);
      if (!field) continue;

      const value = field.value.trim();

      if (rule.required && !value) {
        errors[fieldName] = rule.requiredMessage;
        continue;
      }

      if (rule.type === 'email' && value && !isValidEmail(value)) {
        errors[fieldName] = rule.message;
        continue;
      }

      data[fieldName] = value;
    }

    return {
      isValid: Object.keys(errors).length === 0,
      data,
      errors
    };
  };

  const showFormErrors = (form, errors) => {
    const existingErrors = form.querySelectorAll('.error-message');
    existingErrors.forEach((error) => error.remove());

    for (const [fieldName, errorMessage] of Object.entries(errors)) {
      const field = form.querySelector(`#${fieldName}`);
      if (!field) continue;

      const errorDiv = document.createElement('div');
      errorDiv.className = 'error-message text-red-500 text-sm mt-1';
      errorDiv.textContent = errorMessage;

      field.parentNode.appendChild(errorDiv);
      field.classList.add('border-red-500');
    }
  };

  const clearFormErrors = (form) => {
    const existingErrors = form.querySelectorAll('.error-message');
    existingErrors.forEach((error) => error.remove());

    const fields = form.querySelectorAll('input');
    fields.forEach((field) => field.classList.remove('border-red-500'));
  };

  const form = document.getElementById('forgotForm');
  const submitBtn = document.getElementById('forgotSubmitBtn');
  const originalBtnText = submitBtn ? submitBtn.textContent : '';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    clearFormErrors(e.target);

    const validation = validateForm(e.target, forgotPasswordValidationRules);
    if (!validation.isValid) {
      showFormErrors(e.target, validation.errors);
      return;
    }

    const email = validation.data.email.toLowerCase();
    const message = document.getElementById('forgotMessage');
    let captchaResponse = '';

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = comondTranslations.sending;
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
    }

    message.classList.add('hidden');

    try {
      if (captchaType === 'captcha-google' && recaptchaSiteKey) {
        if (!window.grecaptcha || typeof window.grecaptcha.getResponse !== 'function') {
          message.textContent = comondTranslations.captcha_not_ready;
          message.className = 'text-sm text-center mt-2 text-red-600';
          message.classList.remove('hidden');
          return;
        }

        captchaResponse = window.grecaptcha.getResponse();
        if (!captchaResponse) {
          message.textContent = comondTranslations.captcha_required;
          message.className = 'text-sm text-center mt-2 text-red-600';
          message.classList.remove('hidden');
          return;
        }
      }

      if (captchaType === 'self-hosted' && !puzzleVerificationToken) {
        if (window._puzzleCaptchaForgot) window._puzzleCaptchaForgot.show();
        return;
      }

      const res = await fetch(`${apiBase}/api/auth/recover`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, captchaResponse, portal: activeAppContext, captchaVerificationToken: puzzleVerificationToken })
      });

      const data = await res.json();

      message.textContent = data.message || comondTranslations.reset_link_sent;
      message.className = `text-sm text-center mt-2 ${res.ok ? 'text-green-600' : 'text-red-600'}`;
      message.classList.remove('hidden');

      if (captchaType === 'captcha-google' && recaptchaSiteKey && window.grecaptcha && typeof window.grecaptcha.reset === 'function') {
        window.grecaptcha.reset();
      }
      if (captchaType === 'self-hosted') {
        puzzleVerificationToken = null;
      }
    } catch (error) {
      message.textContent = comondTranslations.connection_error;
      message.className = 'text-sm text-center mt-2 text-red-600';
      message.classList.remove('hidden');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnText;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    }
  });

  if (captchaType === 'captcha-google' && recaptchaSiteKey) {
    const existingScript = document.querySelector('script[src*="recaptcha/api.js"]');
    if (!existingScript) {
      const script = document.createElement('script');
      script.src = 'https://www.google.com/recaptcha/api.js';
      script.async = true;
      script.defer = true;
      document.head.appendChild(script);
    }
  }
</script>
