---
// import { asset } from '../lib/data.js';
import { loadTranslations, getServerLang } from '@lib/i18n.js';
const apiPublic = import.meta.env.PUBLIC_API_URL;
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';
const lang = getServerLang(Astro.cookies);

let t: any = {};
try {
  t = {
    comond: await loadTranslations(lang, 'comond')
  };
} catch (error) {
  console.error('Error loading translations (FormForgotPassword):', error);
}
---

<div class="w-full max-w-md mx-auto mt-10 space-y-6 animate-fade-in">
  <!-- Header -->
  <div class="flex flex-col items-center text-center gap-6">
    <div class="flex items-center gap-2">
      <img src="/assets/gelymar.svg" alt="Gelymar Logo" class="h-10 w-10"/>
      <span class="text-[2rem] font-bold tracking-tight text-[#002E50] dark:text-gray-100">
        Gelymar
      </span>
    </div>
  </div>

  <div class="text-center">
    <h1 class="text-2xl font-bold text-[#002E50]">
      {t?.comond?.reset_password_title}
    </h1>
    <p class="mt-1 text-sm text-[#002E50]/80">
      {t?.comond?.reset_helper}
    </p>
  </div>

  <form class="space-y-5" id="forgotForm" method="post">
    <!-- Email -->
    <div>
      <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        {t?.comond?.email_label}
      </label>
      <input
        type="email"
        name="email"
        id="email"
        placeholder={t?.comond?.email_placeholder}
        class="input"
        required
      />
    </div>

    <!-- Mensaje -->
    <p id="forgotMessage" class="text-sm text-center hidden"></p>

    {recaptchaSiteKey && (
      <div class="flex justify-center">
        <div class="g-recaptcha" data-sitekey={recaptchaSiteKey}></div>
      </div>
    )}

    <!-- Botón -->
    <button
      type="submit"
      id="forgotSubmitBtn"
      class="w-full px-5 py-3 text-base font-semibold text-white rounded-lg bg-[#00538C] hover:bg-[#003F6B] transition duration-300"
    >
      {t?.comond?.send_reset_link}
    </button>
  </form>
</div>

<script type="module" define:vars={{ apiPublic, recaptchaSiteKey, comondTranslations: t?.comond ?? {} }}>
  const apiBase = apiPublic || window.location.origin;
  const t = comondTranslations || {};
  const emailRequired = t.email_required || 'El correo es requerido';
  const emailInvalid = t.email_invalid || 'Correo inválido';
  const sendingLabel = t.sending || 'Enviando...';
  const captchaNotReady = t.captcha_not_ready || 'El captcha aún no está listo. Intenta de nuevo en un momento.';
  const captchaRequired = t.captcha_required || 'Por favor confirma que no eres un robot';
  const connectionError = t.connection_error || 'Error de conexión';
  const resetLinkSent = t.reset_link_sent || 'Email enviado.';
  const forgotPasswordValidationRules = {
    email: {
      required: true,
      requiredMessage: emailRequired,
      type: 'email',
      message: emailInvalid
    }
  };

  const isValidEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);

  const validateForm = (form, rules) => {
    const data = {};
    const errors = {};

    for (const [fieldName, rule] of Object.entries(rules)) {
      const field = form.querySelector(`#${fieldName}`);
      if (!field) continue;

      const value = field.value.trim();

      if (rule.required && !value) {
        errors[fieldName] = rule.requiredMessage || `${fieldName} es requerido`;
        continue;
      }

      if (rule.type === 'email' && value && !isValidEmail(value)) {
        errors[fieldName] = rule.message || 'Email invalido';
        continue;
      }

      data[fieldName] = value;
    }

    return {
      isValid: Object.keys(errors).length === 0,
      data,
      errors
    };
  };

  const showFormErrors = (form, errors) => {
    const existingErrors = form.querySelectorAll('.error-message');
    existingErrors.forEach((error) => error.remove());

    for (const [fieldName, errorMessage] of Object.entries(errors)) {
      const field = form.querySelector(`#${fieldName}`);
      if (!field) continue;

      const errorDiv = document.createElement('div');
      errorDiv.className = 'error-message text-red-500 text-sm mt-1';
      errorDiv.textContent = errorMessage;

      field.parentNode.appendChild(errorDiv);
      field.classList.add('border-red-500');
    }
  };

  const clearFormErrors = (form) => {
    const existingErrors = form.querySelectorAll('.error-message');
    existingErrors.forEach((error) => error.remove());

    const fields = form.querySelectorAll('input');
    fields.forEach((field) => field.classList.remove('border-red-500'));
  };

  const form = document.getElementById('forgotForm');
  const submitBtn = document.getElementById('forgotSubmitBtn');
  const originalBtnText = submitBtn ? submitBtn.textContent : '';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    clearFormErrors(e.target);

    const validation = validateForm(e.target, forgotPasswordValidationRules);
    if (!validation.isValid) {
      showFormErrors(e.target, validation.errors);
      return;
    }

    const email = validation.data.email.toLowerCase();
    const message = document.getElementById('forgotMessage');
    let captchaResponse = '';

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = sendingLabel;
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
    }

    message.classList.add('hidden');

    try {
      if (recaptchaSiteKey) {
        if (!window.grecaptcha || typeof window.grecaptcha.getResponse !== 'function') {
          message.textContent = captchaNotReady;
          message.className = 'text-sm text-center mt-2 text-red-600';
          message.classList.remove('hidden');
          return;
        }

        captchaResponse = window.grecaptcha.getResponse();
        if (!captchaResponse) {
          message.textContent = captchaRequired;
          message.className = 'text-sm text-center mt-2 text-red-600';
          message.classList.remove('hidden');
          return;
        }
      }

      const res = await fetch(`${apiBase}/api/auth/recover`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, captchaResponse })
      });

      const data = await res.json();

      message.textContent = data.message || resetLinkSent;
      message.className = `text-sm text-center mt-2 ${res.ok ? 'text-green-600' : 'text-red-600'}`;
      message.classList.remove('hidden');

      if (recaptchaSiteKey && window.grecaptcha && typeof window.grecaptcha.reset === 'function') {
        window.grecaptcha.reset();
      }
    } catch (error) {
      message.textContent = connectionError;
      message.className = 'text-sm text-center mt-2 text-red-600';
      message.classList.remove('hidden');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnText;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    }
  });

  if (recaptchaSiteKey) {
    const existingScript = document.querySelector('script[src*="recaptcha/api.js"]');
    if (!existingScript) {
      const script = document.createElement('script');
      script.src = 'https://www.google.com/recaptcha/api.js';
      script.async = true;
      script.defer = true;
      document.head.appendChild(script);
    }
  }
</script>
