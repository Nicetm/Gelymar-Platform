---
import { loadTranslations, getServerLang } from '../../lib/i18n.js';

const lang = getServerLang(Astro.cookies);
let t: any = {};
try {
  t = {
    documentos: await loadTranslations(lang, 'documentos'),
  };
} catch (error) {
  console.warn('Error cargando traducciones:', error);
}
---
<section id="documents-section"
         class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">

  <!-- Filters -->
  <header class="p-6 border-b border-gray-200 dark:border-gray-700">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">{t.documentos.sharedDocuments}</h2>
        <p  class="text-sm text-gray-600 dark:text-gray-400 mt-1">
          {t.documentos.sharedDocumentsDescription}
        </p>
      </div>

      <div class="flex items-center gap-3">
        <select id="type-filter"
                class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg
                       bg-white dark:bg-gray-700 text-gray-900 dark:text-white
                       focus:ring-2 focus:ring-blue-500 focus:border-transparent">
          <option value="">{t.documentos.allTypes}</option>
          <option value="pdf">PDF</option>
          <option value="doc">{t.documentos.documents}</option>
          <option value="img">{t.documentos.images}</option>
          <option value="other">{t.documentos.others}</option>
        </select>

        <div class="relative">
          <input id="search-input" type="text" placeholder={t.documentos.searchDocuments}
                 class="pl-8 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg
                        bg-white dark:bg-gray-700 text-gray-900 dark:text-white
                        focus:ring-2 focus:ring-blue-500 focus:border-transparent w-48" />
          <svg class="absolute left-2.5 top-2.5 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
      </div>
    </div>
  </header>

  <!-- Table -->
  <div class="overflow-auto">
    <!-- Grid de cards en lugar de tabla -->
    <div id="documents-container" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-3 p-4 min-h-[200px]">
      <!-- Document cards will be injected by JS -->
    </div>
  </div>

</section>

<script type="module" define:vars={{ lang, t }}>
  // Hacer las variables disponibles globalmente
  window.translations = t;
</script>

