---
/*  docsByOrder is an object keyed by order-id.
    The JS will inject the right list + pagination later. */
// Mostrar por defecto, no depender del JavaScript para visibilidad
import PaginationControls from './PaginationControls.astro';
---
<section id="documents-section"
         class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">

  <!-- Filters -->
  <header class="p-6 border-b border-gray-200 dark:border-gray-700">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Shared Documents</h2>
        <p  class="text-sm text-gray-600 dark:text-gray-400 mt-1">
          View, download, and manage all documents shared with you by the company
        </p>
      </div>

      <div class="flex items-center gap-3">
        <select id="type-filter"
                class="px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg
                       bg-white dark:bg-gray-700 text-gray-900 dark:text-white
                       focus:ring-2 focus:ring-blue-500 focus:border-transparent">
          <option value="">All types</option>
          <option value="pdf">PDF</option>
          <option value="doc">Documents</option>
          <option value="img">Images</option>
          <option value="other">Others</option>
        </select>

        <div class="relative">
          <input id="search-input" type="text" placeholder="Search documents..."
                 class="pl-8 pr-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg
                        bg-white dark:bg-gray-700 text-gray-900 dark:text-white
                        focus:ring-2 focus:ring-blue-500 focus:border-transparent w-48" />
          <svg class="absolute left-2.5 top-2.5 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
      </div>
    </div>
  </header>

  <!-- List -->
  <div class="divide-y divide-gray-200 dark:divide-gray-700" id="documents-container">
    <!-- Document rows will be injected by JS -->
  </div>

  <!-- Pagination -->
  <footer class="px-6 py-4 border-t border-gray-200 dark:border-gray-700">
    <PaginationControls />
  </footer>
</section>

