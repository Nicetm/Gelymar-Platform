---
export interface Props {
  icon   : 'file-text' | 'trending-up' | 'clock' | 'check-circle';
  colour : 'blue' | 'green' | 'yellow' | 'purple';
  label  : string;
  valueId: string;
  extraId?: string;
  barId?  : string;
}
const { icon, colour, label, valueId, extraId, barId } = Astro.props;
const colourMap = {
  blue   : { bg:'bg-blue-100 dark:bg-blue-900/30',  text:'text-blue-600 dark:text-blue-400' },
  green  : { bg:'bg-green-100 dark:bg-green-900/30',text:'text-green-600 dark:text-green-400' },
  yellow : { bg:'bg-yellow-100 dark:bg-yellow-900/30',text:'text-yellow-600 dark:text-yellow-400' },
  purple : { bg:'bg-purple-100 dark:bg-purple-900/30',text:'text-purple-600 dark:text-purple-400' },
};

const iconMap = {
  'file-text': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  'trending-up': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`,
  'clock': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  'check-circle': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`
};
---

<div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-200 dark:border-gray-700">
  <div class="flex items-center">
    <div class={`p-3 ${colourMap[colour].bg} rounded-lg`}>
      <svg class={`w-6 h-6 ${colourMap[colour].text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconMap[icon]} />
    </div>
    <div class="ml-4">
      <p  class="text-sm font-medium text-gray-600 dark:text-gray-400">{label}</p>
      <p  class="text-2xl font-bold text-gray-900 dark:text-white" id={valueId}>0</p>
      {extraId &&
        <p class="text-xs text-gray-500 dark:text-gray-400" id={extraId}>—</p>}
    </div>
  </div>

  {barId &&
    <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2 mt-4">
      <div id={barId}
           class="bg-purple-600 h-2 rounded-full transition-all duration-300"
           style="width:0%"></div>
    </div>}
</div>