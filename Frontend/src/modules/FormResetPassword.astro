---
// src/modules/FormResetPassword.astro
// import { asset } from '../lib/data.js';
import { loadTranslations, getServerLang } from '@lib/i18n.js';
const apiPublic = import.meta.env.PUBLIC_API_URL;
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';
const lang = getServerLang(Astro.cookies);

let t: any = {};
try {
  t = {
    comond: await loadTranslations(lang, 'comond')
  };
} catch (error) {
  console.error('Error loading translations (FormResetPassword):', error);
}

---

<div class="w-full max-w-md mx-auto mt-10 space-y-6 animate-fade-in">
  <!-- Header -->
  <div class="flex flex-col items-center text-center gap-6">
    <div class="flex items-center gap-2">
      <img src="/assets/gelymar.svg" alt="Gelymar Logo" class="h-10 w-10"/>
      <span class="text-[2rem] font-bold tracking-tight text-[#002E50] dark:text-gray-100">
        Gelymar
      </span>
    </div>
  </div>

  <div class="text-center">
    <h1 class="text-2xl font-bold text-[#002E50]">
      {t?.comond?.reset_password_title}
    </h1>
    <p class="mt-1 text-sm text-[#002E50]/80">
      {t?.comond?.reset_password_subtitle}
    </p>
  </div>

  <form id="resetForm" class="space-y-5" method="post">
    <!-- Hidden username field for accessibility -->
    <input type="text" name="username" autocomplete="username" style="display: none;" tabindex="-1" aria-hidden="true" />
    <!-- Email -->
    <div>
      <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        {t?.comond?.email_label}
      </label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder={t?.comond?.email_placeholder}
        class="input"
        required
      />
    </div>

    <!-- New password -->
    <div>
      <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        {t?.comond?.new_password_label}
      </label>
      <input
        type="password"
        id="password"
        name="password"
        placeholder="••••••••"
        class="input"
        required
        autocomplete="new-password"
      />
      <ul id="resetPasswordRules" class="mt-3 text-xs space-y-1 text-gray-600 dark:text-gray-400">
        <li data-rule="length" class="flex items-center gap-2">
          <span class="rule-icon text-red-500">✗</span>
          <span>{t?.comond?.password_rule_min}</span>
        </li>
        <li data-rule="upper" class="flex items-center gap-2">
          <span class="rule-icon text-red-500">✗</span>
          <span>{t?.comond?.password_rule_upper}</span>
        </li>
        <li data-rule="lower" class="flex items-center gap-2">
          <span class="rule-icon text-red-500">✗</span>
          <span>{t?.comond?.password_rule_lower}</span>
        </li>
        <li data-rule="number" class="flex items-center gap-2">
          <span class="rule-icon text-red-500">✗</span>
          <span>{t?.comond?.password_rule_number}</span>
        </li>
      </ul>
    </div>

    <!-- Confirm password -->
    <div>
      <label for="confirm-password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        {t?.comond?.confirm_new_password_label}
      </label>
      <input
        type="password"
        id="confirm-password"
        name="confirm-password"
        placeholder="••••••••"
        class="input"
        required
        autocomplete="new-password"
      />
    </div>

    <!-- Mensaje -->
    <p id="resetMessage" class="text-sm text-center hidden"></p>

    {recaptchaSiteKey && (
      <div class="flex justify-center">
        <div class="g-recaptcha" data-sitekey={recaptchaSiteKey}></div>
      </div>
    )}

    <!-- Botón -->
    <button
      type="submit"
      class="w-full px-5 py-3 text-base font-semibold text-white rounded-lg bg-[#00538C] hover:bg-[#003F6B] transition duration-300 inline-flex items-center justify-center gap-2"
    >
      {t?.comond?.reset_password_button}
    </button>
  </form>
</div>

<script type="module" define:vars={{ apiPublic, recaptchaSiteKey, comondTranslations: t?.comond ?? {} }}>
  const apiBase = apiPublic || window.location.origin;

  const resetPasswordValidationRules = {
    email: {
      required: true,
      requiredMessage: comondTranslations.email_required,
      type: 'email',
      message: comondTranslations.email_invalid
    },
    password: {
      required: true,
      requiredMessage: comondTranslations.new_password_required
    },
    'confirm-password': {
      required: true,
      requiredMessage: comondTranslations.confirm_password_required
    }
  };

  const isValidEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);

  const validatePassword = (value) => {
    const errors = [];
    if (value.length < 8) errors.push(comondTranslations.password_rule_min);
    if (!/[A-Z]/.test(value)) errors.push(comondTranslations.password_rule_upper);
    if (!/[a-z]/.test(value)) errors.push(comondTranslations.password_rule_lower);
    if (!/[0-9]/.test(value)) errors.push(comondTranslations.password_rule_number);
    return {
      isValid: errors.length === 0,
      errors
    };
  };

  const updatePasswordRules = (value) => {
    const rulesList = document.getElementById('resetPasswordRules');
    if (!rulesList) return;
    const rules = {
      length: value.length >= 8,
      upper: /[A-Z]/.test(value),
      lower: /[a-z]/.test(value),
      number: /[0-9]/.test(value)
    };

    rulesList.querySelectorAll('li[data-rule]').forEach((item) => {
      const ruleKey = item.getAttribute('data-rule');
      const passed = !!rules[ruleKey];
      const icon = item.querySelector('.rule-icon');
      if (icon) {
        icon.textContent = passed ? '✓' : '✗';
        icon.classList.toggle('text-green-500', passed);
        icon.classList.toggle('text-red-500', !passed);
      }
      item.classList.toggle('text-green-600', passed);
      item.classList.toggle('text-red-500', !passed);
    });
  };

  const validateForm = (form, rules) => {
    const data = {};
    const errors = {};

    for (const [fieldName, rule] of Object.entries(rules)) {
      const field = form.querySelector(`#${fieldName}`);
      if (!field) continue;

      const value = field.value.trim();

      if (rule.required && !value) {
        errors[fieldName] = rule.requiredMessage;
        continue;
      }

      if (rule.type === 'email' && value && !isValidEmail(value)) {
        errors[fieldName] = rule.message;
        continue;
      }

      data[fieldName] = value;
    }

    return {
      isValid: Object.keys(errors).length === 0,
      data,
      errors
    };
  };

  const showFormErrors = (form, errors) => {
    const existingErrors = form.querySelectorAll('.error-message');
    existingErrors.forEach((error) => error.remove());

    for (const [fieldName, errorMessage] of Object.entries(errors)) {
      const field = form.querySelector(`#${fieldName}`);
      if (!field) continue;

      const errorDiv = document.createElement('div');
      errorDiv.className = 'error-message text-red-500 text-sm mt-1';
      errorDiv.textContent = errorMessage;

      field.parentNode.appendChild(errorDiv);
      field.classList.add('border-red-500');
    }
  };

  const clearFormErrors = (form) => {
    const existingErrors = form.querySelectorAll('.error-message');
    existingErrors.forEach((error) => error.remove());

    const fields = form.querySelectorAll('input');
    fields.forEach((field) => field.classList.remove('border-red-500'));
  };

  document.getElementById('resetForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    clearFormErrors(e.target);

    const validation = validateForm(e.target, resetPasswordValidationRules);
    if (!validation.isValid) {
      showFormErrors(e.target, validation.errors);
      return;
    }

    const email = validation.data.email.toLowerCase();
    const password = validation.data.password;
    const confirm = validation.data['confirm-password'];

    const urlParams = new URLSearchParams(window.location.search);
    const token = urlParams.get('token');

    if (password !== confirm) {
      showFormErrors(e.target, { 'confirm-password': comondTranslations.passwords_mismatch });
      return;
    }

    const passwordValidation = validatePassword(password);
    if (!passwordValidation.isValid) {
      showFormErrors(e.target, { password: comondTranslations.password_strength_error });
      return;
    }

    const message = document.getElementById('resetMessage');
    let captchaResponse = '';

    message.classList.add('hidden');

    try {
      if (recaptchaSiteKey) {
        if (!window.grecaptcha || typeof window.grecaptcha.getResponse !== 'function') {
          message.textContent = comondTranslations.captcha_not_ready;
          message.className = 'text-sm text-center mt-2 text-red-600';
          message.classList.remove('hidden');
          return;
        }

        captchaResponse = window.grecaptcha.getResponse();
        if (!captchaResponse) {
          message.textContent = comondTranslations.captcha_required;
          message.className = 'text-sm text-center mt-2 text-red-600';
          message.classList.remove('hidden');
          return;
        }
      }

      const res = await fetch(`${apiBase}/api/auth/reset-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, newPassword: password, token, captchaResponse })
      });

      const data = await res.json();

      message.textContent = data.message || comondTranslations.reset_password_title;
      message.className = `text-sm text-center mt-2 ${res.ok ? 'text-green-600' : 'text-red-600'}`;
      message.classList.remove('hidden');

      if (recaptchaSiteKey && window.grecaptcha && typeof window.grecaptcha.reset === 'function') {
        window.grecaptcha.reset();
      }

      if (res.ok) {
        setTimeout(() => {
          window.location.href = '/authentication/sign-in';
        }, 1500);
      }
    } catch (error) {
      message.textContent = comondTranslations.connection_error;
      message.className = 'text-sm text-center mt-2 text-red-600';
      message.classList.remove('hidden');
    }
  });

  const passwordInput = document.getElementById('password');
  if (passwordInput) {
    updatePasswordRules(passwordInput.value || '');
    passwordInput.addEventListener('input', (e) => updatePasswordRules(e.target.value || ''));
  }

  if (recaptchaSiteKey) {
    const existingScript = document.querySelector('script[src*="recaptcha/api.js"]');
    if (!existingScript) {
      const script = document.createElement('script');
      script.src = 'https://www.google.com/recaptcha/api.js';
      script.async = true;
      script.defer = true;
      document.head.appendChild(script);
    }
  }
</script>
