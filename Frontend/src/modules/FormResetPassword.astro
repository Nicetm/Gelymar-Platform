---
// src/modules/FormResetPassword.astro
// import { asset } from '../lib/data.js';
---

<div class="w-full max-w-md mx-auto px-6 pt-4 animate-fade-in-up">
  <form id="resetForm" class="space-y-5">
    <!-- Email -->
    <div>
      <label for="email" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        Your email
      </label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="name@company.com"
        class="input"
        required
      />
    </div>

    <!-- New password -->
    <div>
      <label for="password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        New password
      </label>
      <input
        type="password"
        id="password"
        name="password"
        placeholder="••••••••"
        class="input"
        required
      />
    </div>

    <!-- Confirm password -->
    <div>
      <label for="confirm-password" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">
        Confirm new password
      </label>
      <input
        type="password"
        id="confirm-password"
        name="confirm-password"
        placeholder="••••••••"
        class="input"
        required
      />
    </div>

    <!-- Términos -->
    <div class="flex items-start text-sm">
      <input
        id="terms"
        name="terms"
        type="checkbox"
        required
        class="w-4 h-4 mt-1 mr-2 border-gray-300 rounded bg-gray-50 focus:ring-[#00538C] dark:bg-gray-700 dark:border-gray-600"
      />
      <label for="terms" class="text-gray-700 dark:text-white">
        I accept the
        <a href="/info/terms-and-conditions" class="text-[#00538C] hover:underline dark:text-[#F6B234]">
          Terms and Conditions
        </a>
      </label>
    </div>

    <!-- Mensaje -->
    <p id="resetMessage" class="text-sm text-center hidden"></p>

    <!-- Botón -->
    <button
      type="submit"
      class="w-full px-5 py-3 text-base font-semibold text-white rounded-lg bg-[#00538C] hover:bg-[#003F6B] transition duration-300"
    >
      Reset password
    </button>
  </form>
</div>

<style is:global>
  .input {
    @apply bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-[#00538C] focus:border-[#00538C];
  }

  @keyframes fade-in-up {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out both;
  }
</style>

<script is:inline>
  document.getElementById('resetForm').addEventListener('submit', async (e) => {
		e.preventDefault();

		const email = e.target.email.value.trim();
		const password = e.target.password.value.trim();
		const confirm = e.target['confirm-password'].value.trim();
		const urlParams = new URLSearchParams(window.location.search);
		const token = urlParams.get('token');

		const message = document.getElementById('resetMessage');
		message.classList.add('hidden');

		if (password !== confirm) {
			message.textContent = "Passwords do not match.";
			message.className = 'text-sm text-center mt-2 text-red-600';
			message.classList.remove('hidden');
			return;
		}

		try {
			const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/auth/reset-password`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ email, newPassword: password, token })
			});

			const data = await res.json();
			message.textContent = data.message || "Password reset.";
			message.className = `text-sm text-center mt-2 ${res.ok ? 'text-green-600' : 'text-red-600'}`;
			message.classList.remove('hidden');
		} catch {
			message.textContent = "Connection error.";
			message.className = 'text-sm text-center mt-2 text-red-600';
			message.classList.remove('hidden');
		}
	});

</script>
