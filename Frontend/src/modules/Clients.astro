---
import { loadTranslations } from '../lib/i18n.js';
import type { Customers } from '../types/entities.js';

const apiBase = import.meta.env.PUBLIC_API_URL;
const setLang = import.meta.env.PUBLIC_LANG;

const lang = setLang;
const t: any = {
  clientes: await loadTranslations(lang, 'clientes'),
	comond: await loadTranslations(lang, 'comond'),
};

const token = Astro.cookies.get('token')?.value;
const customers: Customers[] = await fetch(`${apiBase}/api/customers`, {
  headers: { Authorization: `Bearer ${token}` }
}).then(res => res.json());
---

<section id="clientSection" class="px-4 pt-24 pb-6 sm:px-6 lg:px-8">
  <!-- Encabezado y breadcrumb -->
  <header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="/admin" class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            <span>{t.clientes.home}</span>
          </a>
        </li>
        <li aria-current="page" class="flex items-center text-gray-400 dark:text-gray-300 font-medium">
          <span class="mx-1">/</span>{t.clientes.title}
        </li>
      </ol>
    </nav>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{t.clientes.allCustomers}</h1>
    </div>

    <!-- Búsqueda y botón agregar cliente -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mt-4">
      <div class="relative w-full sm:max-w-xs">
        <label for="searchInput" class="sr-only">{t.clientes.search}</label>
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
          </svg>
        </div>
        <input id="searchInput" type="text" placeholder={t.clientes.search} class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
     <button id="addClientBtn" class="flex items-center justify-center gap-2 px-4 py-2 rounded-md text-sm font-semibold shadow-sm
              bg-gray-200 hover:bg-gray-300 text-gray-700 transition-all dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-white
              focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
        <svg id="addIcon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        <svg id="spinnerIcon" class="w-4 h-4 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z" />
        </svg>
        <span id="addClientText">{t.clientes.addClient}</span>
      </button>
    </div>
  </header>

  <!-- Tabla de clientes -->
  <div class="overflow-auto mt-6 rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed">
      <thead class="bg-gray-100 dark:bg-gray-800 sticky top-0 z-10">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.name}</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.email}</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.country}</th>
          <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.status}</th>
          <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.directory}</th>
          <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.actions}</th>
        </tr>
      </thead>
      <tbody id="customersTableBody" class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-sm min-h-[600px]">
        <!-- Las filas <tr> se agregan dinámicamente aquí con JavaScript -->
				 {Array.isArray(customers) && customers.map(customer => (
						<tr data-id={customer.id} class="hover:shadow-sm hover:bg-gray-50 dark:hover:bg-gray-800 transition">
							<td class="px-6 py-4 items-center gap-3">{customer.name}</td>
							<td class="px-6 py-4 items-center gap-3">{customer.email}</td>
							<td class="px-6 py-4 items-center gap-3">{customer.country}</td>
							<td data-status={customer.status} class="px-6 py-4 text-center gap-3">{customer.status}</td>
							<td class="px-6 py-4 text-center gap-3">{customer.order_count}</td>
							<td class="px-6 py-4 items-center gap-3">
								<div class="flex justify-center items-center gap-3 text-gray-900 dark:text-white">
									<a href={`/admin/clients/folders/view/${customer.uuid}?c=${customer.name}`} title="Orders" class="hover:text-yellow-500 transition">
										<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 3h18v4H3z"/><path d="M3 7h18v13H3z"/><path d="M16 3v4"/></svg>
									</a>
									<a href="#" data-uuid={`${customer.uuid}`} title="View more details" class="hover:text-blue-500 transition">
										<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 20.5C6.753 20.5 2.5 16.247 2.5 11S6.753 1.5 12 1.5 21.5 5.753 21.5 11 17.247 20.5 12 20.5z"/></svg>
									</a>
									<a href={`/admin/clients/send-mail/view/${customer.uuid}`} title="Send mail" class="hover:text-indigo-500 transition">
										<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4h16v16H4V4z" /><path stroke-linecap="round" stroke-linejoin="round" d="M22 6l-10 7L2 6" /></svg>
									</a>
									<a href="#" data-uuid={`${customer.uuid}`} title="Edit Client" class="hover:text-green-500 transition">
										<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 11l6.586-6.586a2 2 0 112.828 2.828L11.828 13.83a2 2 0 01-.586.414L9 15l.756-2.243a2 2 0 01.414-.586z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5"/></svg>
									</a>
								</div>
							</td>
						</tr>
					))}
      </tbody>
    </table>
  </div>

  <!-- Paginación -->
  <div class="mt-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-6 text-sm">
    <div class="flex items-center gap-3">
      <label for="itemsPerPageSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.perPage}</label>
      <div class="relative">
        <select id="itemsPerPageSelect" class="block w-20 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-sm text-gray-900 dark:text-white rounded-md pl-3 pr-8 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="10">10</option>
          <option value="20">20</option>
          <option value="30">30</option>
        </select>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button id="prevPageBtn" aria-label="Previous page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <span id="pageIndicator" class="px-4 py-1 rounded-lg bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-white text-sm font-medium shadow-sm">Page 1 of 5</span>
      <button id="nextPageBtn" aria-label="Next page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- Modal overlay and form -->
<div id="addClientModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
	<div class="bg-white rounded-lg p-6 w-full max-w-md relative"> <!-- <-- Aquí -->
		<!-- Botón de cerrar -->
		<button id="closeModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition">
			<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
		<h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">{t.clientes.createTitle}</h2>

		<div class="mb-4">
			<label for="clientName" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.name}</label>
			<input id="clientName" type="text" class="w-full mt-1 px-4 py-2 border rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white" required />
		</div>

		<div class="mb-4 flex gap-4">
			<div class="w-1/2">
				<label for="clientCountry" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.country}</label>
				<input id="clientCountry" type="text" class="w-full mt-1 px-4 py-2 border rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white" required />
			</div>
			<div class="w-1/2">
				<label for="clientCity" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.city}</label>
				<input id="clientCity" type="text" class="w-full mt-1 px-4 py-2 border rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white" required />
			</div>
		</div>

		<div class="mb-4 flex gap-4">
			<div class="w-1/2">
				<label for="clientPhoneCode" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.country_code}</label>
				<input id="clientPhoneCode" type="text" class="w-full mt-1 px-4 py-2 border rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white" required />
			</div>
			<div class="w-1/2">
				<label for="clientPhone" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.phone}</label>
				<input id="clientPhone" type="text" class="w-full mt-1 px-4 py-2 border rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white" required />
			</div>
		</div>

		<div class="mb-4">
			<label for="clientAddress" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.address}</label>
			<input id="clientAddress" type="text" class="w-full mt-1 px-4 py-2 border rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white" required />
		</div>

		<div class="mb-4">
			<label for="clientEmail" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.email}</label>
			<input id="clientEmail" type="email" class="w-full mt-1 px-4 py-2 border rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white" required />
		</div>

		<div class="flex justify-end gap-2">
			<button id="cancelUploadBtn" class="px-4 py-2 bg-gray-300 rounded-md">{t.comond.cancel}</button>
			<button id="confirmUploadBtn" class="bg-[#00538C] hover:bg-[#004773] text-white px-4 py-2 rounded-md font-medium">{t.comond.confirm}</button>
		</div>

		<p id="folderMessage" class="text-sm font-medium text-center text-red-600 dark:text-red-400 hidden pt-4"></p>
	</div>
</div>

<script is:inline>
	const qs = id => document.getElementById(id);
  const searchInput = qs('searchInput');
	const itemsPerPageSelect = qs('itemsPerPageSelect');
	const prevPageBtn = qs('prevPageBtn');
	const nextPageBtn = qs('nextPageBtn');
	const pageIndicator = qs('pageIndicator');
	const tableBody = qs('customersTableBody');
	const addClientBtn = qs('addClientBtn');
	const addIcon = qs('addIcon');
	const spinnerIcon = qs('spinnerIcon');
	const allRows = Array.from(tableBody.querySelectorAll('tr'));

	let currentPage = 1;
	let itemsPerPage = parseInt(itemsPerPageSelect.value, 10);
	let filteredRows = [...allRows];

	/**
	 * Función principal de render de la tabla según búsqueda y paginación.
	 * Oculta todas las filas y solo muestra las correspondientes a la página actual.
	 */
	function renderTable() {
		allRows.forEach(originalRow => {
			const row = originalRow;
			row.style.display = 'none';

			// Obtener status de data-status
			const statusCell = row.querySelector('td[data-status]');
			if (statusCell) {
				const statusValue = parseInt(statusCell.dataset.status, 10);
				const isActive = statusValue === 1;

				// Definir clases
				const statusClass = isActive
					? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300'
					: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300';

				const statusIcon = isActive
					? `<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
							</svg>`
					: `<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
							</svg>`;

				// Insertar el HTML en la celda
				statusCell.innerHTML = `
					<div class="flex justify-center items-center h-full">
						<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${statusClass}">
							${statusIcon} ${isActive ? 'Active' : 'Inactive'}
						</span>
					</div>`;
			}
		});

		const start = (currentPage - 1) * itemsPerPage;
		const pageData = filteredRows.slice(start, start + itemsPerPage);
		
		pageData.forEach(originalRow => {
			const row = originalRow;
			row.style.display = '';
		});

		const totalPages = Math.ceil(filteredRows.length / itemsPerPage);
		pageIndicator.textContent = `Page ${currentPage} of ${totalPages}`;
	}

	addClientBtn?.addEventListener('click', () => {
		addIcon.classList.add('hidden');
		spinnerIcon.classList.remove('hidden');
		setTimeout(() => {
			spinnerIcon.classList.add('hidden');
			addIcon.classList.remove('hidden');
			const uploadModal = qs('addClientModal');
			uploadModal.classList.remove('hidden');
			uploadModal.style.display = 'flex';
		}, 500);
	});

	// Cerrar modal
	['cancelUploadBtn', 'closeModalBtn'].forEach(id => {
    qs(id).addEventListener('click', () => {
        const uploadModal = qs('addClientModal');
        uploadModal.classList.add('hidden');
        uploadModal.style.display = 'none';

        qs('clientName').value = '';
    });
	});

	/**
	 * Buscador dinámico: filtra las filas según el texto ingresado.
	 */
	searchInput.addEventListener('input', () => {
		const query = searchInput.value.toLowerCase();
		filteredRows = allRows.filter(row => {
			const text = row.textContent.toLowerCase();
			return text.includes(query);
		});
		currentPage = 1;
		renderTable();
	});

	/**
	 * Manejo del cambio en cantidad de items por página.
	 */
	itemsPerPageSelect.addEventListener('change', () => {
		itemsPerPage = parseInt(itemsPerPageSelect.value, 10);
		currentPage = 1;
		renderTable();
	});

	/**
	 * Navegación hacia la página anterior
	 */
	prevPageBtn.addEventListener('click', () => {
		if (currentPage > 1) {
			currentPage-=1;
			renderTable();
		}
	});

	/**
	 * Navegación hacia la página siguiente
	 */
	nextPageBtn.addEventListener('click', () => {
		const totalPages = Math.ceil(filteredRows.length / itemsPerPage);
		if (currentPage < totalPages) {
			currentPage+=1;
			renderTable();
		}
	});

	// Render inicial de la tabla al cargar
	renderTable();
</script>
