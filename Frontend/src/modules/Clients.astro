---
import { loadTranslations } from '../lib/i18n.js';
import type { Customers } from '../types/entities.js';

const apiBase = import.meta.env.PUBLIC_API_URL;
const lang = import.meta.env.PUBLIC_LANG;

const t: any = {
  clientes: await loadTranslations(lang, 'clientes'),
	comond: await loadTranslations(lang, 'comond'),
};

const token = Astro.cookies.get('token')?.value;
const customers: Customers[] = await fetch(`${apiBase}/api/customers`, {
  headers: { Authorization: `Bearer ${token}` }
}).then(res => res.json());
---

<section id="clientSection" class="px-4 pt-24 pb-6 sm:px-6 lg:px-8">
  <!-- Encabezado y breadcrumb -->
  <header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="/admin" class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            <span>{t.clientes.home}</span>
          </a>
        </li>
        <li aria-current="page" class="flex items-center text-gray-400 dark:text-gray-300 font-medium">
          <span class="mx-1">/</span>{t.clientes.title}
        </li>
      </ol>
    </nav>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{t.clientes.allCustomers}</h1>
    </div>

    <!-- Búsqueda y botón agregar cliente -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mt-4">
      <div class="relative w-full sm:max-w-xs">
        <label for="searchInput" class="sr-only">{t.clientes.search}</label>
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
          </svg>
        </div>
        <input id="searchInput" type="text" placeholder={t.clientes.search} class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>

    </div>
  </header>

  <!-- Tabla de clientes -->
  <div class="overflow-auto mt-6 rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed">
      <thead class="bg-gray-100 dark:bg-gray-800 sticky top-0 z-10">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.name}</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.rut}</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.email}</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.phone}</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.country}</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.city}</th>
          <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.directory}</th>
          <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.actions}</th>
        </tr>
      </thead>
      <tbody id="customersTableBody" class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-sm min-h-[600px]">
        <!-- Las filas <tr> se agregan dinámicamente aquí con JavaScript -->
		{Array.isArray(customers) && customers.map(customer => (
			<tr data-id={customer.id} class="hover:shadow-sm hover:bg-gray-50 dark:hover:bg-gray-800 transition">
				<td class="px-6 py-4 items-center gap-3">{customer.name}</td>
				<td class="px-6 py-4 items-center gap-3">{customer.rut}</td>
				<td class="px-6 py-4 items-center gap-3">{customer.email}</td>
				<td class="px-6 py-4 items-center gap-3">{customer.phone}</td>
				<td class="px-6 py-4 items-center gap-3">{customer.country}</td>
				<td class="px-6 py-4 items-center gap-3">{customer.city}</td>
				<td class="px-6 py-4 text-center gap-3">{customer.order_count}</td>
				<td class="px-6 py-4 items-center gap-3">
					<div class="flex justify-center items-center gap-3 text-gray-900 dark:text-white">
						<a href={`/admin/clients/folders/view/${customer.uuid}?c=${customer.name}`} title="Orders" class="hover:text-yellow-500 transition">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 3h18v4H3z"/><path d="M3 7h18v13H3z"/><path d="M16 3v4"/></svg>
						</a>
						<a href="#" data-uuid={`${customer.uuid}`} title="View more details" class="hover:text-blue-500 transition">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 20.5C6.753 20.5 2.5 16.247 2.5 11S6.753 1.5 12 1.5 21.5 5.753 21.5 11 17.247 20.5 12 20.5z"/></svg>
						</a>
						<a href="#" data-uuid={`${customer.uuid}`} data-name={`${customer.name}`} title="Manage contacts" class="hover:text-indigo-500 transition manage-contacts-btn">
							<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
						</a>
					</div>
				</td>
			</tr>
		))}
      </tbody>
    </table>
  </div>

  <!-- Paginación -->
  <div class="mt-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-6 text-sm">
    <div class="flex items-center gap-3">
      <label for="itemsPerPageSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.perPage}</label>
      <div class="relative">
        <select id="itemsPerPageSelect" class="block w-20 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-sm text-gray-900 dark:text-white rounded-md pl-3 pr-8 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="10">10</option>
          <option value="20">20</option>
          <option value="30">30</option>
        </select>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button id="prevPageBtn" aria-label="Previous page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <span id="pageIndicator" class="px-4 py-1 rounded-lg bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-white text-sm font-medium shadow-sm">Page 1 of 5</span>
      <button id="nextPageBtn" aria-label="Next page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- Modal de Contactos -->
<div id="contactsModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
  <div class="bg-white dark:bg-gray-800 rounded-lg p-6 w-full max-w-2xl mx-4 relative max-h-[90vh] overflow-y-auto">
    <!-- Botón de cerrar -->
    <button id="closeContactsModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
      <span id="clientNameTitle"></span> - {t.clientes.contacts}
    </h2>
	<!-- Formulario para agregar nuevos contactos -->
    <div id="contactsFormContainer" class="border-b border-gray-200 dark:border-gray-700 pb-4">
		<!-- Aquí van las filas de nuevos contactos -->
	</div>

    <!-- Tabla de contactos existentes -->
    <div id="existingContactsTable" class="mb-6 mt-4">
      <!-- Aquí se inyectará la tabla por JS -->
    </div>

    <div class="flex justify-between items-center mt-4">
      <!-- Botón + contacto a la izquierda -->
      <button id="addContactRowBtn" type="button"
        class="flex items-center gap-1 text-green-600 hover:text-green-800 font-medium transition bg-transparent border-none shadow-none p-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        contacto
      </button>
      <!-- Botones a la derecha -->
      <div class="flex gap-2">
        <button id="cancelAddContactBtn"
          class="px-4 py-2 bg-gray-300 dark:bg-gray-600 text-gray-700 dark:text-gray-300 rounded-md hover:bg-gray-400 dark:hover:bg-gray-500 transition">
          {t.comond.cancel}
        </button>
        <button id="addContactBtn"
          class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md font-medium transition">
          {t.comond.add}
        </button>
      </div>
    </div>
  </div>
</div>

<script type="module" define:vars={{ apiBase, lang }}>
  import { initClientsScript } from '/js/clients.js';
  
  // Hacer las variables disponibles globalmente
  window.apiBase = apiBase;
  window.lang = lang;

  // Inicializar el script cuando el DOM esté completamente cargado
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initClientsScript();
    });
  } else {
    // Si el DOM ya está cargado, ejecutar inmediatamente
    initClientsScript();
  } 
</script>
