---
import { loadTranslations } from '../lib/i18n.js';

const apiBase = import.meta.env.PUBLIC_API_URL;
const fileServer = import.meta.env.PUBLIC_FILE_SERVER_URL;
const setLang = import.meta.env.PUBLIC_LANG;
const lang = setLang;

const { id } = Astro.params;
const t: any = {
  documentos: await loadTranslations(lang, 'documentos'),
  comond: await loadTranslations(lang, 'comond'),
};
---

<section id="filesSection" data-api-base={apiBase} data-file-server={fileServer} data-uuid={id} class="px-4 pt-16 pb-6 sm:px-6 lg:px-8">
  <!-- Encabezado y breadcrumb -->
  <header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="/admin" class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            <span>{t.comond.home}</span>
          </a>
        </li>
        <li class="flex items-center text-gray-400 dark:text-gray-300 font-medium" aria-current="page">
          <span class="mx-1">/</span>{t.documentos.title}
        </li>
      </ol>
    </nav>

    <!-- Título -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h1 id="titleFile" class="text-3xl font-bold text-gray-900 dark:text-white">{t.documentos.title}</h1>
		</div>

    <!-- Búsqueda y botón agregar archivo -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mt-4">
      <div class="relative w-full sm:max-w-xs">
        <label for="searchInput" class="sr-only">{t.comond.search}</label>
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
          </svg>
        </div>
        <input id="searchInput" type="text" placeholder={t.comond.search} class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>

			<button id="uploadFileBtn" class="flex items-center justify-center gap-2 px-4 py-2 rounded-md text-sm font-semibold shadow-sm bg-[#00538C] hover:bg-[#004773] text-white transition-all dark:bg-[#0077b6] dark:hover:bg-[#006194] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        {t.documentos.upload}
      </button>

    </div>
  </header>

  <div class="overflow-x-auto mt-6">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg text-sm">
      <thead class="bg-gray-100 dark:bg-gray-800">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.name}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.status}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.created}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.updated}</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.docType}</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.comond.actions}</th>
        </tr>
      </thead>
      <tbody id="filesTableBody" class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
        <!-- Documentos renderizados aquí -->
      </tbody>
    </table>
  </div>

  <div class="mt-6 flex justify-between items-center text-sm">
    <div class="flex items-center gap-3">
      <label for="itemsPerPageSelect">{t.documentos.perPage}</label>
      <select id="itemsPerPageSelect" class="w-20 bg-white dark:bg-gray-800 border rounded-md">
        <option value="10">10</option>
        <option value="20">20</option>
        <option value="30">30</option>
      </select>
    </div>
    <div class="flex items-center gap-3">
      <button id="prevPageBtn" class="w-9 h-9 flex items-center justify-center bg-gray-200 dark:bg-gray-700 rounded-md">‹</button>
      <span id="pageIndicator" class="text-sm text-gray-700 dark:text-gray-300">Página 1</span>
      <button id="nextPageBtn" class="w-9 h-9 flex items-center justify-center bg-gray-200 dark:bg-gray-700 rounded-md">›</button>
    </div>
  </div>
</section>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script is:inline>
(() => {
		const qs = id => document.getElementById(id);
		const section = qs('filesSection');
		const uuid = section?.dataset.uuid;
		const apiBase = section?.dataset.apiBase;
		const fileServer = section?.dataset.fileServer;
		const params = new URLSearchParams(window.location.search);
		const folderId = params.get('f');
		const pc = params.get('pc');
		const notification = qs('notification');

		if (pc) {
			const decoded = decodeURIComponent(pc);
			const title = qs('titleFile');
			if (title) title.textContent += ` ${decoded}`;
		}

		if (!uuid || !folderId) {
			console.error('Faltan parámetros');
			return;
		}

		const token = localStorage.getItem('token');
		if (!token) {
			window.location.href = '/login';
			return;
		}

		function showNotification(message) {
			notification.textContent = message;
			notification.classList.remove('hidden');
			setTimeout(() => notification.classList.add('hidden'), 3000);
		}

		async function fetchFiles() {
			try {
				const res = await fetch(`${apiBase}/api/files/${uuid}?f=${folderId}`, {
					headers: { Authorization: `Bearer ${token}` }
				});
				if (!res.ok) throw new Error('Error al obtener archivos');
				const files = await res.json();
				renderTable(files);
			} catch (err) {
					console.error('Error al obtener archivos:', err);
			}
		}

		function attachGenerateEvents() {
			document.querySelectorAll('.generate-btn').forEach(btn => {
				btn.addEventListener('click', async (e) => {
					e.preventDefault();
					const { fileId } = btn.dataset;

					try {
						const res = await fetch(`${apiBase}/api/files/generate/${fileId}`, {
							method: 'POST',
							headers: { 'Authorization': `Bearer ${token}` }
						});

						if (!res.ok) {
							const error = await res.json();
							throw new Error(error.message || 'Error al generar el archivo');
						}

						await fetchFiles();
						showNotification('Documento generado correctamente');
					} catch (err) {
						console.error('Error al generar documento:', err);
						showNotification('Error al generar documento');
					}
				});
			});
		}

		async function renderTable(files) {
			const tableBody = document.getElementById('filesTableBody');
			tableBody.innerHTML = '';

			if (!files.length) {
				tableBody.innerHTML = `<tr><td colspan="8" class="text-center py-4 text-gray-500">No hay archivos registrados.</td></tr>`;
				return;
			}

			files.forEach(file => {
				const row = document.createElement('tr');
				let statusColor = '';
				switch (file.status_id) {
					case 1: statusColor = 'bg-red-500'; break;
					case 2: statusColor = 'bg-yellow-400'; break;
					case 3: statusColor = 'bg-green-500'; break;
					default: statusColor = 'bg-gray-400';
				}

					let actionButton = '';
					if (file.status_id === 1) {
						actionButton = `
						<div class="flex items-center gap-3 justify-center">
							<a href="#" class="generate-btn" data-file-id="${file.id}" title="Generar documento">
								<svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path d="M12 4v16m8-8H4"/>
								</svg>
							</a>
						</div>`;
					} else if (file.status_id === 2) {
						actionButton = `
						<div class="flex items-center gap-3 justify-center">
							<a href="#" class="send-btn" data-file-id="${file.id}" title="Enviar documento">
								<svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4l16 8-16 8V4z"/></svg>
							</a>
							<a href="${fileServer}/uploads/${file.path}" target="_blank" title="Ver archivo ${file.name}" class="hover:text-blue-500 transition">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
									<polyline points="14 2 14 8 20 8"/>
								</svg>
							</a>
						</div>`;
					} else if (file.status_id === 3) {
						actionButton = `
						<div class="flex items-center gap-3 justify-center">
							<a href="#" class="resend-btn" data-file-id="${file.id}" title="Reenviar documento">
								<svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4l16 8-16 8V4z"/></svg>
							</a>
							<a href="${fileServer}/uploads/${file.path}" target="_blank" title="Ver archivo ${file.name}" class="hover:text-blue-500 transition">
								<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
									<polyline points="14 2 14 8 20 8"/>
								</svg>
							</a>
						</div>`;
					}
					row.innerHTML = `
						<td class="px-4 py-3">${file.name}</td>
						<td class="px-4 py-3">
							<div class="flex items-center">
								<span class="w-2.5 h-2.5 rounded-full mr-2 ${statusColor}"></span>
								${file.status_name || '-'}
							</div>
						</td>
						<td class="px-4 py-3">${file.created_at ? new Date(file.created_at).toLocaleString('es-CL') : '-'}</td>
						<td class="px-4 py-3">${file.updated_at ? new Date(file.updated_at).toLocaleString('es-CL') : '-'}</td>
						<td class="px-4 py-3">${file.document_type || '-'}</td>
						<td class="px-4 py-3"><div>${actionButton}</div></td>
					`;
					tableBody.appendChild(row);
			});
				attachGenerateEvents();
		}
		fetchFiles();
})();
</script>
	
	
