---
import { loadTranslations, getServerLang } from '../lib/i18n.js';
import type { Files } from '../types/entities.js';

const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const apiPublic = import.meta.env.PUBLIC_API_URL;
const fileServer = import.meta.env.PUBLIC_FILE_SERVER_URL;
const lang = getServerLang(Astro.cookies);

const url = new URL(Astro.url.href);
const clientName = url.searchParams.get('c') ?? '';
const decodedClientName = decodeURIComponent(clientName);
const folderId = url.searchParams.get('f') ?? '';
const pc = url.searchParams.get('pc') ?? '';

const { id } = Astro.params;
const t: any = {
  documentos: await loadTranslations(lang, 'documentos'),
  carpetas: await loadTranslations(lang, 'carpetas'),
  comond: await loadTranslations(lang, 'comond'),
};

const token = Astro.cookies.get('token')?.value;
const files: Files[] = await fetch(`${apiBase}/api/files/${id}?f=${folderId}`, {
  headers: { Authorization: `Bearer ${token}` }
}).then(res => res.json());

// Obtener tipos de documentos desde la API
const documentTypes = await fetch(`${apiBase}/api/document-types`, {
  headers: { Authorization: `Bearer ${token}` }
}).then(res => res.json()).catch(() => []);

// Obtener OC y PC de la base de datos (del primer archivo)
const orderPc = files.length > 0 ? files[0]?.pc : '';
const orderOc = files.length > 0 ? files[0]?.oc : '';
---

<section id="filesSection" data-api-base={apiBase} data-file-server={fileServer} data-uuid={id} data-lang={lang} class="px-4 pt-24 pb-6 sm:px-6 lg:px-8">
  <!-- Debug: Mostrar apiBase en el HTML -->
  <script>
    console.log('DEBUG - apiBase en HTML:', '{apiBase}');
  </script>
  <!-- Encabezado y breadcrumb -->
  <header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="/admin" class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            <span>{t.comond.home}</span>
          </a>
        </li>
        <li class="flex items-center text-gray-400 dark:text-gray-300 font-medium" aria-current="page">
          <span class="mx-1">/ <a href="/admin/clients">{t.carpetas.customers} </a> / <a href={`/admin/clients/folders/view/${id}?c=${decodedClientName}`}>{t.carpetas.title}</a> / </span>{t.documentos.title}
        </li>
			</ol>
    </nav>

    <!-- Título -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex flex-col gap-1">
        <h1 id="titleFile" class="text-3xl font-bold text-gray-900 dark:text-white">{decodedClientName} - Order {t.documentos.title}</h1>
        <div class="flex flex-col gap-1 text-sm text-gray-600 dark:text-gray-400">
          {orderPc && <span class="font-bold">{t.documentos.pcNumber}: {orderPc}</span>}
          {orderOc && <span class="font-bold">{t.documentos.ocNumber}: {orderOc}</span>}
        </div>
      </div>
	</div>

    <!-- Búsqueda y botón agregar archivo -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mt-4">
      <div class="relative w-full sm:max-w-xs">
        <label for="searchInput" class="sr-only">{t.comond.search}</label>
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
          </svg>
        </div>
        <input id="searchInput" type="text" placeholder={t.comond.search} class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
			<button id="uploadFileBtn" class="flex items-center justify-center gap-2 px-4 py-2 rounded-md text-sm font-semibold shadow-sm
							bg-gray-200 hover:bg-gray-300 text-gray-700 transition-all dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-white
							focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
				<svg id="addIcon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
				</svg>
				<svg id="spinnerIcon" class="w-4 h-4 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
					<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
					<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z" />
				</svg>
				<span id="addClientText">{t.documentos.upload}</span>
			</button>
    </div>
  </header>

  <div class="overflow-auto mt-6 rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed">
      <thead id="filesHead" class="bg-gray-100/70 dark:bg-gray-800/70 backdrop-blur-md transition-shadow sticky top-0 z-10">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.name}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.status}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.fechaETD}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.fechaETA}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.created}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.updated}</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.is_visible_to_customer}</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.comond.actions}</th>
        </tr>
      </thead>
      <tbody id="filesTableBody" class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-sm min-h-[600px] text-gray-900 dark:text-gray-200 transition-all duration-300 ease-out motion-safe:animate-fade-slide">
				{Array.isArray(files) && files.map(file => {
					let statusColor = '';
					switch (file.status_id) {
						case 1:
							statusColor = 'bg-red-500';
							break;
						case 2:
							statusColor = 'bg-yellow-400';
							break;
						case 3:
							statusColor = 'bg-green-500';
							break;
						case 4:
							statusColor = 'bg-blue-500';
							break;
						default:
							statusColor = 'bg-gray-400';
					}
			
					return (
					<tr data-id={file.id} class="transition-colors duration-150 hover:bg-gray-100 dark:hover:bg-gray-800 hover:shadow-[0_1px_3px_rgba(0,0,0,0.12)]">
						<td class="px-6 py-4 text-sm editable-filename group cursor-pointer" data-id={file.id} title="Doble clic para editar">
							<div class="inline-flex items-center gap-1">
								<span class="filename-text block truncate">{file.name}</span>
								<svg class="w-4 h-4 text-gray-400 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5 M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"/>
								</svg>
							</div>
						</td>
						<td class="px-4 py-3"><div class="flex items-center"><span class={`w-2.5 h-2.5 rounded-full mr-2 ${statusColor}`}></span>{file.status_name || '-'}</div></td>
						<td class="px-6 py-4 items-center gap-3">{file.etd ? new Date(file.etd).toLocaleDateString("es-CL") : '-'}</td>
						<td class="px-6 py-4 items-center gap-3">{file.eta ? new Date(file.eta).toLocaleDateString("es-CL") : '-'}</td>
						<td class="px-6 py-4 items-center gap-3">{new Date(file.created_at).toLocaleString("es-CL")}</td>
						<td class="px-6 py-4 items-center gap-3">{new Date(file.updated_at).toLocaleString("es-CL")}</td>
						<td data-v={file.is_visible_to_client} class="px-6 py-4 text-center">
							<label class="relative inline-flex items-center cursor-pointer">
								<input
									type="checkbox"
									class="sr-only peer visibility-toggle"
									data-file-id={file.id}
									checked={file.is_visible_to_client} />
								<div
									class="w-9 h-5 bg-gray-200 rounded-full transition-colors
												 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary-500
												 peer-checked:bg-primary-600 dark:bg-gray-700 dark:peer-checked:bg-primary-500"></div>
								<div
									class="absolute left-1 top-1 w-3 h-3 bg-white rounded-full transition-transform
												 peer-checked:translate-x-4"></div>
							</label>
						</td>
						<td class="px-6 py-4 items-center gap-3">
							<div class="flex items-center gap-3 justify-center">
								{file.status_id === 1 && (
									<a href="#" class="generate-btn" data-file-id={file.id} title="Generar documento">
										<svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" d="M12 15.5A3.5 3.5 0 1 0 12 8.5a3.5 3.5 0 0 0 0 7zm7.5-.5a7.49 7.49 0 0 1-1.035 3.743l1.432 1.432a1 1 0 1 1-1.414 1.414l-1.432-1.432A7.49 7.49 0 0 1 12.5 20.5v2a1 1 0 1 1-2 0v-2a7.49 7.49 0 0 1-3.743-1.035l-1.432 1.432a1 1 0 1 1-1.414-1.414l1.432-1.432A7.49 7.49 0 0 1 3.5 15.5h-2a1 1 0 1 1 0-2h2a7.49 7.49 0 0 1 1.035-3.743L3.103 8.325a1 1 0 1 1 1.414-1.414l1.432 1.432A7.49 7.49 0 0 1 11.5 3.5v-2a1 1 0 1 1 2 0v2a7.49 7.49 0 0 1 3.743 1.035l1.432-1.432a1 1 0 1 1 1.414 1.414l-1.432 1.432A7.49 7.49 0 0 1 20.5 11.5h2a1 1 0 1 1 0 2h-2z" />
										</svg>
									</a>
								)}

								{file.status_id === 2 && (
									<a href="#" class="send-btn" data-file-id={file.id} data-file-name={file.name} data-order={orderOc} title="Enviar documento">
										<svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8" />
											<path stroke-linecap="round" stroke-linejoin="round" d="M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
										</svg>
									</a>
								)}

								{(file.status_id === 3 || file.status_id === 4) && (
									<a href="#" class="resend-btn" data-file-id={file.id} data-file-name={file.name} data-order={orderOc} title="Reenviar documento">
										<svg class="w-5 h-5 text-yellow-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H7a4 4 0 010-8h1" />
										</svg>
									</a>
								)}

								{(file.status_id === 2 || file.status_id === 3 || file.status_id === 4) && (
									<a href={`${fileServer}/${file.path}`} target="_blank" class="hover:text-blue-500 transition" title="Ver documento">
										<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
											<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
											<polyline points="14 2 14 8 20 8"/>
										</svg>
									</a>
								)}

								<a href="#" class="edit-btn hover:text-blue-500 transition" data-file-id={file.id} title="Editar documento">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z" />
									</svg>
								</a>
								<a href="#" class="delete-btn hover:text-red-500 transition" data-file-id={file.id} title="Eliminar documento">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M10 11v6M14 11v6M5 7l1 12a2 2 0 002 2h8a2 2 0 002-2l1-12M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3" />
									</svg>
								</a>
							</div>
						</td>
					</tr>
					);
				})}
			</tbody>			
    </table>
  </div>

  <!-- Paginación -->
  <div class="mt-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-6 text-sm">
    <div class="flex items-center gap-3">
      <label for="itemsPerPageSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">{t.documentos.perPage}</label>
      <div class="relative">
        <select id="itemsPerPageSelect" class="block w-20 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-sm text-gray-900 dark:text-white rounded-md pl-3 pr-8 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="10">10</option>
          <option value="20">20</option>
          <option value="30">30</option>
        </select>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button id="prevPageBtn" aria-label="Previous page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <span id="pageIndicator" class="px-4 py-1 rounded-lg bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-white text-sm font-medium shadow-sm">Página 1</span>
      <button id="nextPageBtn" aria-label="Next page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
  <!-- Modal de Enviar Documento -->
	<div id="messageModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
		<div class="bg-white dark:bg-gray-800 dark:text-white rounded-lg p-6 w-full max-w-md">
			<h2 class="text-xl font-bold mb-4">{t.documentos.sendCustomMessage}</h2>
	
			<div class="mb-4">
				<label for="orderNumber" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.documentos.orderNumber}</label>
				<input type="text" id="orderNumber" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white rounded-md shadow-sm p-2" readonly>
			</div>

			<div class="mb-4">
				<label for="orderDocument" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.documentos.nameOfDocument}</label>
				<input type="text" id="orderDocument" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white rounded-md shadow-sm p-2" readonly>
			</div>
	
			<div class="mb-4">
				<label for="customMessage" class="block text-sm font-medium text-gray-700 dark:text-gray-300 flex items-center gap-2">
					{t.documentos.message}
					<div class="relative group">
						<svg class="w-4 h-4 text-blue-500 hover:text-blue-600 cursor-help transition-colors duration-200" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
						<div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-3 px-4 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-sm rounded-xl shadow-2xl opacity-0 group-hover:opacity-100 transition-all duration-300 ease-out scale-95 group-hover:scale-100 w-80 z-20 backdrop-blur-sm border border-blue-400/20">
							<div class="flex items-start gap-2">
								<svg class="w-4 h-4 text-blue-200 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
								</svg>
								<span class="leading-relaxed">{t.documentos.messageTooltip}</span>
							</div>
							<div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-6 border-r-6 border-t-6 border-transparent border-t-blue-600"></div>
						</div>
					</div>
				</label>
				<textarea id="customMessage" rows="4" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white rounded-md shadow-sm p-2"></textarea>
			</div>
	
			<div class="flex justify-end gap-2">
				<button id="cancelMessageBtn" class="px-4 py-2 bg-gray-300 dark:bg-gray-600 dark:text-white rounded-md">{t.comond.cancel}</button>
				<button id="confirmMessageBtn" class="px-4 py-2 bg-blue-600 text-white rounded-md">{t.comond.confirm}</button>
			</div>
		</div>
	</div>

	<div id="uploadModal" data-folder-name={pc} data-folder-id={folderId} class="fixed inset-0 hidden justify-center items-center z-50 bg-black/50 flex backdrop-blur-sm opacity-0 transition-opacity duration-500">
		<div class="modal-card bg-white/95 dark:bg-gray-800/95 text-gray-900 dark:text-gray-100 rounded-2xl p-8 w-full max-w-lg relative shadow-2xl ring-1 ring-gray-200 dark:ring-white/10 transform opacity-0 scale-90 translate-y-6 transition-all duration-500 ease-[cubic-bezier(.22,1,.36,1)]"> <!-- <-- Aquí -->
			<!-- Botón de cerrar -->
			<button id="closeModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
			<h2 class="text-xl font-bold mb-4 dark:text-white">{t.documentos.dragTitle}</h2>
	
			<div class="mb-4">
				<label for="uploadFileName" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.documentos.nameOfDocument}</label>
				<!-- Solo valores predefinidos -->
				<div class="relative">
				  <select id="uploadFileName"
				          class="appearance-none pr-10 pl-3 py-2 block w-full border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500">
				    <option value="" disabled selected>— {t.documentos.selectDocumentName} —</option>
				    {documentTypes.map((docType: any) => (
				      <option value={docType.name}>{docType.name}</option>
				    ))}
				  </select>
				  <!-- Flecha personalizada -->
				  <svg class="w-4 h-4 text-gray-500 dark:text-gray-400 pointer-events-none absolute right-3 top-1/2 -translate-y-1/2"
				       fill="currentColor" viewBox="0 0 20 20">
				    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.08 1.04l-4.25 4.25a.75.75 0 01-1.06 0L5.25 8.27a.75.75 0 01-.02-1.06z" clip-rule="evenodd"/>
				  </svg>
				</div>
			</div>
	
			<div class="mb-4 flex gap-4">
				<!-- Tipo de Documento -->
				<div class="w-1/2">
					<label for="uploadFileType" class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.documentos.typeofDocument}</label>
					<select id="uploadFileType" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white rounded-md shadow-sm p-2">
						<option value="PDF">PDF</option>
					</select>
				</div>
			
				<!-- Visible al cliente -->
				<div class="w-1/2">
					<label for="isVisibleToClient" class="block text-sm font-medium text-gray-700 dark:text-gray-300">¿Visible al cliente?</label>
					<select id="isVisibleToClient" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white rounded-md shadow-sm p-2">
						<option value="true">Sí</option>
						<option value="false">No</option>
					</select>
				</div>
			</div>
	
			<div class="mb-4">
				<label class="block text-sm font-medium text-gray-700 dark:text-gray-300">{t.documentos.selectDocument}</label>
				<div id="dropZone" class="flex flex-col items-center justify-center border-2 border-dashed border-gray-400 dark:border-gray-600 rounded-md p-6 cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700">
					<p id="dropZoneText" class="text-gray-500">{t.documentos.dragAndDrop}</p>
					<input type="file" id="uploadFileInput" class="hidden" />
				</div>
			</div>
	
			<div class="flex justify-end gap-2">
				<button
					id="cancelUploadBtn"
					class="px-4 py-2 bg-gray-300 hover:bg-gray-400 dark:bg-gray-600 dark:hover:bg-gray-500 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500"
				>
					{t.comond.cancel}
				</button>
				<button
					id="confirmUploadBtn"
					class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500"
				>
					{t.comond.upload}
				</button>
			</div>
		</div>
	</div>

	<!-- Modal de Editar Archivo -->
	<div id="editFileModal" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden flex justify-center items-center">
		<div class="bg-white dark:bg-gray-800 p-6 rounded-xl max-w-md w-full mx-4 shadow-xl">
			<div class="flex items-center justify-between mb-4">
				<h2 class="text-lg font-semibold text-gray-900 dark:text-white">{t.documentos.editFile}</h2>
				<button id="closeEditModalBtn" class="text-gray-400 hover:text-red-500 transition">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
			
			<div class="mb-4">
				<label for="editFileName" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{t.documentos.newFileName}</label>
				<input type="text" id="editFileName" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Ej: Aviso de Embarque V2">
			</div>
			
			<div class="mb-6">
				<label for="editFileVisible" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{t.documentos.visibleToClient}</label>
				<select id="editFileVisible" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500">
					<option value="1">{t.documentos.yes}</option>
					<option value="0">{t.documentos.no}</option>
				</select>
			</div>
			
			<div class="flex justify-end gap-2">
				<button id="cancelEditBtn" class="px-4 py-2 rounded-md bg-gray-300 hover:bg-gray-400 dark:bg-gray-600 dark:hover:bg-gray-500 dark:text-white transition-colors">{t.documentos.cancel}</button>
				<button id="confirmEditBtn" class="px-4 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-700 transition-colors">{t.documentos.save}</button>
			</div>
		</div>
	</div>

	<!-- Modal de Renombrar Archivo -->
	<div id="renameFileModal" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 hidden flex justify-center items-center">
		<div class="bg-white dark:bg-gray-800 p-6 rounded-xl max-w-md w-full mx-4 shadow-xl">
			<div class="flex items-center justify-between mb-4">
				<h2 class="text-lg font-semibold text-gray-900 dark:text-white">{t.documentos.renameFile}</h2>
				<button id="closeRenameModalBtn" class="text-gray-400 hover:text-red-500 transition">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
			
			<div class="mb-6">
				<label for="renameFileName" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{t.documentos.newFileName}</label>
				<input type="text" id="renameFileName" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500">
			</div>
			
			<div class="flex justify-end gap-2">
				<button id="cancelRenameBtn" class="px-4 py-2 rounded-md bg-gray-300 hover:bg-gray-400 dark:bg-gray-600 dark:hover:bg-gray-500 dark:text-white transition-colors">{t.documentos.cancel}</button>
				<button id="confirmRenameBtn" class="px-4 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-700 transition-colors">{t.documentos.save}</button>
			</div>
		</div>
	</div>

	<div id="notification" class="hidden fixed top-5 right-5 px-6 py-4 rounded-lg shadow-lg z-50 text-black text-base font-semibold transition-all duration-300 ease-in-out"></div>
	<div id="globalSpinner" class="fixed inset-0 bg-black bg-opacity-40 flex justify-center items-center z-50 invisible">
		<div class="w-16 h-16 border-4 border-white border-t-transparent border-solid rounded-full animate-spin"></div>
	</div>
</section>

<script type="module" define:vars={{ apiPublic, fileServer, lang, documentTypes, orderOc }}>
  import { initFilesScript } from '/js/files.js';
  
  // Hacer las variables disponibles globalmente
  window.apiBase = apiPublic;
  window.fileServer = fileServer;
  window.lang = lang;
  window.documentTypes = documentTypes;
  window.orderOc = orderOc;

  // Inicializar el script cuando el DOM esté completamente cargado
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initFilesScript();
    });
  } else {
    // Si el DOM ya está cargado, ejecutar inmediatamente
    initFilesScript();
  } 
</script>


<style is:inline>
  @layer utilities {
    @keyframes fade-slide {
      0%   { opacity: 0; transform: translateY(8px); }
      100% { opacity: 1; transform: translateY(0);   }
    }
    .animate-fade-slide {
      animation: fade-slide .25s both;
    }
  }
</style>
