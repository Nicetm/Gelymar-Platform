---
// i18n y tipos
import { loadTranslations } from '../lib/i18n.js';
import type { Users } from '../types/entities.js';

const apiBase = import.meta.env.PUBLIC_API_URL;
const fileServer = import.meta.env.PUBLIC_FILE_SERVER_URL;
const setLang = import.meta.env.PUBLIC_LANG;

const lang = setLang;
const t: any = {
  clientes: await loadTranslations(lang, 'clientes'),
};

const token = Astro.cookies.get('token')?.value;
const users: Users[] = await fetch(`${apiBase}/api/users`, {
  headers: { Authorization: `Bearer ${token}` }
}).then(res => res.json());
---

<section id="userSection" data-api-base={apiBase} data-file-server={fileServer} class="px-4 pt-24 pb-6 sm:px-6 lg:px-8">
  <!-- Encabezado y breadcrumb -->
  <header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="/admin" class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            <span>{t.clientes.home}</span>
          </a>
        </li>
        <li class="inline-flex items-center">
          <span class="mx-1">/</span>
          <a href="#" class="hover:text-primary-600 dark:hover:text-white">Users</a>
        </li>
        <li class="inline-flex items-center text-gray-400 dark:text-gray-300 font-medium">
          <span class="mx-1">/</span>User list
        </li>
      </ol>
    </nav>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Users list</h1>
  </header>

  <!-- Tabla de usuarios -->
  <div class="overflow-x-auto mt-6 rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed">
      <thead class="bg-gray-100 dark:bg-gray-800 sticky top-0 z-10">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">Name</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">Phone</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">Country</th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">City</th>
          <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">Status</th>
          <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-sm">
        {users.map(user => (
          <tr class="hover:shadow-sm hover:bg-gray-50 dark:hover:bg-gray-800 transition">
			<td class="px-6 py-4 flex items-center gap-3">
			<div class="w-10 h-10 relative">
				<!-- Imagen para modo claro (gris oscuro) -->
				<img
				src={`https://api.dicebear.com/7.x/initials/svg?seed=${user.full_name}&backgroundColor=4b5563&fontColor=ffffff`}
				alt={user.full_name}
				class="w-10 h-10 rounded-full dark:hidden"
				/>
				<!-- Imagen para modo oscuro (azul oscuro Tailwind) -->
				<img
				src={`https://api.dicebear.com/7.x/initials/svg?seed=${user.full_name}&backgroundColor=1e293b&fontColor=ffffff`}
				alt={user.full_name}
				class="w-10 h-10 rounded-full hidden dark:inline"
				/>
			</div>
			<div>
				<p class="font-medium text-gray-900 dark:text-white">{user.full_name}</p>
				<p class="text-sm text-gray-500 dark:text-gray-400">{user.email}</p>
			</div>
			</td>
            <td class="px-6 py-4 text-gray-900 dark:text-white">{user.phone}</td>
            <td class="px-6 py-4 text-gray-900 dark:text-white">{user.country}</td>
            <td class="px-6 py-4 text-gray-900 dark:text-white">{user.city}</td>
            <td class="px-6 py-4 text-center">
              <span class={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${user.twoFAEnabled ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' : 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300'}`}>
                {user.twoFAEnabled ? 'Enabled' : 'Disabled'}
              </span>
            </td>
            <td class="px-6 py-4 text-center">
              <div class="flex justify-center items-center gap-3 text-gray-900 dark:text-white">
                <button data-modal-toggle="edit-user-modal" title="Edit" class="hover:text-green-500 transition">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 11l6.586-6.586a2 2 0 112.828 2.828L11.828 13.83a2 2 0 01-.586.414L9 15l.756-2.243a2 2 0 01.414-.586z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5" />
                  </svg>
                </button>
                <button data-modal-toggle="delete-user-modal" title="Delete" class="hover:text-red-500 transition">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
