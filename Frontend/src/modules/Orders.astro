---
import { loadTranslations } from '../lib/i18n.js';
import type { Orders } from '../types/entities.js';

const apiBase = import.meta.env.PUBLIC_API_URL;
const setLang = import.meta.env.PUBLIC_LANG;
const lang = setLang;

const t: any = {
  documentos: await loadTranslations(lang, 'documentos'),
  carpetas: await loadTranslations(lang, 'carpetas'),
  clientes: await loadTranslations(lang, 'clientes'),
  comond: await loadTranslations(lang, 'comond'),
};

const token = Astro.cookies.get('token')?.value;
const orders: Orders[] = await fetch(`${apiBase}/api/orders`, {
  headers: { Authorization: `Bearer ${token}` }
}).then(res => res.json());
---

<section id="OrderSection" class="px-4 pt-24 pb-6 sm:px-6 lg:px-8">
  <!-- Encabezado y breadcrumb -->
  <header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="/admin" class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            <span>{t.comond.home}</span>
          </a>
        </li>
        <li class="flex items-center text-gray-400 dark:text-gray-300 font-medium" aria-current="page">
          <span class="mx-1">/ {t.comond.search} {t.carpetas.orders}
        </li>
			</ol>
    </nav>

    <!-- Título -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h1 id="titleFile" class="text-3xl font-bold text-gray-900 dark:text-white">{t.comond.search} {t.carpetas.orders}</h1>
		</div>
  </header>

	<!-- Buscador avanzado -->
	<div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 bg-gray-50 dark:bg-gray-800 p-4 rounded-md shadow-sm">
		<!-- Orden -->
		<div>
			<label for="orden" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.orden ?? 'Orden'}</label>
			<input type="text" id="orden" name="orden" placeholder="Ej: OC-1234"
				class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
		</div>

		<!-- Cliente -->
		<div>
			<label for="cliente" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.cliente ?? 'Cliente'}</label>
			<input type="text" id="cliente" name="cliente" placeholder="Nombre cliente"
				class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
		</div>

		<!-- Fecha Ingreso -->
		<div>
			<label for="fechaIngreso" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.fecha_ingreso ?? 'Fecha Ingreso'}</label>
			<input type="date" id="fechaIngreso" name="fechaIngreso"
				class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
		</div>

		<!-- Fecha ETD -->
		<div>
			<label for="fechaETD" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.fecha_etd ?? 'Fecha ETD'}</label>
			<input type="date" id="fechaETD" name="fechaETD"
				class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
		</div>

		<!-- Fecha ETA -->
		<div>
			<label for="fechaETA" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.fecha_eta ?? 'Fecha ETA'}</label>
			<input type="date" id="fechaETA" name="fechaETA"
				class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
		</div>

		<!-- Estado -->
		<div>
			<label for="estado" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.estado ?? 'Estado'}</label>
			<select id="estado" name="estado"
				class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
				<option value="">{t.comond.all ?? 'Todos'}</option>
				<option value="pendiente">Pendiente</option>
				<option value="enviado">Enviado</option>
				<option value="completado">Completado</option>
			</select>
		</div>
	</div>

	<div class="mt-4 flex justify-end gap-2">
		<!-- Botón Limpiar -->
		<button id="limpiarBtn" class="flex items-center gap-2 px-4 py-2 bg-gray-500 text-white text-sm font-semibold rounded-md shadow-sm hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400">
			<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
			{t.comond.clear}
		</button>
	
		<!-- Botón Buscar -->
		<button id="buscarBtn" data-api-base={apiBase} class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
			<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
			</svg>
			{t.comond.search}
		</button>
	</div>

	<!-- Tabla de resultados -->
	<div class="overflow-auto mt-6 rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700 scrollbar-thin scrollbar-thumb-primary-500/60 dark:scrollbar-thumb-primary-400/60 scrollbar-track-gray-200 dark:scrollbar-track-gray-800">
		<table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed">
			<thead id="ordersHead" class="bg-gray-100/70 dark:bg-gray-800/70 backdrop-blur-md transition-shadow sticky top-0 z-10">
				<tr>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.name}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.client_name}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.createdAt}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.updatedAt}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.dateEtd}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.dateEta}</th>
					<th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.comond.actions}</th>
				</tr>
			</thead>
			<tbody id="resultadosTabla" class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-sm min-h-[600px] text-gray-900 dark:text-gray-200 transition-all duration-300 ease-out motion-safe:animate-fade-slide">
				{Array.isArray(orders) && orders.map(order => (
					<tr data-id={order.id} class="transition-colors duration-150 hover:bg-gray-100 dark:hover:bg-gray-800 hover:shadow-[0_1px_3px_rgba(0,0,0,0.12)]">
						<td class="px-6 py-4 text-sm editable-filename group cursor-pointer" data-id={order.id}>{order.name}</td>
						<td class="px-4 py-3 break-all text-blue-600 dark:text-blue-400">{order.customer_name}</td>
						<td class="px-6 py-4 items-center gap-3">{new Date(order.created_at).toLocaleString("es-CL")}</td>
						<td class="px-6 py-4 items-center gap-3">{new Date(order.updated_at).toLocaleString("es-CL")}</td>
						<td class="px-6 py-4 items-center gap-3">{order.date_etd || '-'}</td>
						<td class="px-6 py-4 items-center gap-3">{order.date_eta || '-'}</td>
						<td class="px-6 py-4 items-center gap-3">
							<div class="flex justify-center items-center gap-3 text-gray-900 dark:text-white">
								<a href={`/admin/clients/documents/view/${order.customer_uuid}?f=${order.id}&pc=${order.name}&c=${order.customer_name}`} class="go-to-order-btn" title="Ir a la orden">
									<svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7m0 0v7m0-7L10 14m-4 0h.01M5 14a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h5a1 1 0 0 0 1-1v-.01" />
									</svg>
								</a>
								<a href="#" title={`Editar ${order.name}`} class="edit-btn hover:text-green-500 transition">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 11l6.586-6.586a2 2 0 112.828 2.828L11.828 13.83a2 2 0 01-.586.414L9 15l.756-2.243a2 2 0 01.414-.586z" />
										<path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5" />
									</svg>
								</a>
							</div>
						</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>

	<!-- Paginación -->
  <div class="mt-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-6 text-sm">
    <div class="flex items-center gap-3">
      <label for="itemsPerPageSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.perPage}</label>
      <div class="relative">
        <select id="itemsPerPageSelect" class="block w-20 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-sm text-gray-900 dark:text-white rounded-md pl-3 pr-8 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="10">10</option>
          <option value="20">20</option>
          <option value="30">30</option>
        </select>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button id="prevPageBtn" aria-label="Previous page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <span id="pageIndicator" class="px-4 py-1 rounded-lg bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-white text-sm font-medium shadow-sm">Page 1 of 5</span>
      <button id="nextPageBtn" aria-label="Next page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>

	<!-- Modal overlay and form -->
	<div id="editOrderModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
		<div class="bg-white dark:bg-gray-800 dark:text-white rounded-lg p-6 w-full max-w-md relative"> <!-- <-- Aquí -->
			<!-- Botón de cerrar -->
			<button id="closeModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
			<h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">{t.clientes.createTitle}</h2>
		</div>
		<div class="flex justify-end gap-2">
			<button id="cancelEditBtn" class="px-4 py-2 bg-gray-300 dark:bg-gray-600 dark:text-white rounded-md">{t.comond.cancel}</button>
			<button id="confirmEditBtn" class="bg-[#00538C] hover:bg-[#004773] text-white px-4 py-2 rounded-md font-medium">{t.comond.confirm}</button>
		</div>
	</div>
</section>

<script is:inline type="module">
	import { showNotification, openEditFileModal } from '../../public/js/notifications';

	// Abrir modal editar
	document.addEventListener('click', async (e) => {
		const btn = e.target.closest('.edit-btn');
		if (!btn) return;

		e.preventDefault();
		const fileId = btn.dataset.fileId;

		const row = btn.closest('tr');
		const span = row.querySelector('.filename-text');
		const currentName = span?.textContent?.trim() || '';
		const visibleCell = row?.querySelector('[data-v]');
		const currentVisible = visibleCell?.dataset?.v === '1';
		console.log('currentVisible', currentVisible);

		await openEditFileModal(fileId, currentName, currentVisible);
	});

</script>
<script is:inline>
(() => {
  const qs = id => document.getElementById(id);

  const buscarBtn = qs('buscarBtn');
  const tablaBody = qs('resultadosTabla');
  const section = qs('OrderSection');
  const editorderBtn = qs('editorderBtn');

  const itemsPerPageSelect = qs('itemsPerPageSelect');
  const prevPageBtn        = qs('prevPageBtn');
  const nextPageBtn        = qs('nextPageBtn');
  const pageIndicator      = qs('pageIndicator');

  let itemsPerPage = parseInt(itemsPerPageSelect.value, 10);
  let currentPage   = 1;
  let currentData   = [];     // se llena tras la búsqueda

  function updatePageIndicator() {
    const totalPages = Math.max(1, Math.ceil(currentData.length / itemsPerPage));
    pageIndicator.textContent = `Page ${currentPage} of ${totalPages}`;
    prevPageBtn.disabled = currentPage === 1;
    nextPageBtn.disabled = currentPage >= totalPages;
    prevPageBtn.classList.toggle('opacity-50', prevPageBtn.disabled);
    nextPageBtn.classList.toggle('opacity-50', nextPageBtn.disabled);
  }

  function renderPage() {
    const start = (currentPage - 1) * itemsPerPage;
    const end   = start + itemsPerPage;
    const pageData = currentData.slice(start, end);

    if (pageData.length === 0) {
      tablaBody.innerHTML = `<tr><td colspan="7" class="px-4 py-4 text-center text-gray-400 dark:text-gray-500">Sin resultados</td></tr>`;
      updatePageIndicator();
      return;
    }

    tablaBody.innerHTML = pageData.map(order => `
      <tr data-id="${order.id}" class="transition-colors duration-150 hover:bg-gray-100 dark:hover:bg-gray-800 hover:shadow-[0_1px_3px_rgba(0,0,0,0.12)]">
        <td class="px-6 py-4 items-center gap-3">${order.name || '-'}</td>
        <td class="px-4 py-3 break-all text-blue-600 dark:text-blue-400">${order.customer_name || '-'}</td>
        <td class="px-6 py-4 items-center gap-3">${new Date(order.created_at).toLocaleString("es-CL")}</td>
        <td class="px-6 py-4 items-center gap-3">${new Date(order.updated_at).toLocaleString("es-CL")}</td>
        <td class="px-6 py-4 items-center gap-3">${order.date_etd || '-'}</td>
        <td class="px-6 py-4 items-center gap-3">${order.date_eta || '-'}</td>
        <td class="px-6 py-4">
          <div class="flex justify-center items-center gap-3 text-gray-900 dark:text-white">
            <a href="/admin/clients/documents/view/${order.customer_uuid}?f=${order.id}&pc=${order.name}&c=${order.customer_name}" class="go-to-order-btn" title="Ir a la orden">
              <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7m0 0v7m0-7L10 14m-4 0h.01M5 14a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h5a1 1 0 0 0 1-1v-.01" />
              </svg>
            </a>
            <a href="#" title="Editar ${order.name}" class="hover:text-green-500 transition">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 11l6.586-6.586a2 2 0 112.828 2.828L11.828 13.83a2 2 0 01-.586.414L9 15l.756-2.243a2 2 0 01.414-.586z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5" />
              </svg>
            </a>
          </div>
        </td>
      </tr>
    `).join('');
    updatePageIndicator();
  }

  // Skeleton loader helper
  function showSkeleton(count = 8) {
    const skeletonRow = `
      <tr class="animate-pulse">
        <td colspan="7" class="px-6 py-4">
          <div class="space-y-2">
            <div class="h-4 w-3/4 bg-gray-300 dark:bg-gray-700 rounded"></div>
            <div class="h-4 w-1/2 bg-gray-300 dark:bg-gray-700 rounded"></div>
          </div>
        </td>
      </tr>`;
    tablaBody.innerHTML = skeletonRow.repeat(count);
  }

  // Eventos de paginación
  itemsPerPageSelect.addEventListener('change', () => {
    itemsPerPage = parseInt(itemsPerPageSelect.value, 10);
    currentPage  = 1;
    renderPage();
  });

  prevPageBtn.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderPage();
    }
  });

  nextPageBtn.addEventListener('click', () => {
    const totalPages = Math.ceil(currentData.length / itemsPerPage);
    if (currentPage < totalPages) {
      currentPage++;
      renderPage();
    }
  });

  /*Funcion para buscar ordenes*/
  buscarBtn.addEventListener('click', async () => {
    const cliente = qs('cliente')?.value.trim() ?? '';
    const orden = qs('orden')?.value.trim() ?? '';
    const estado = qs('estado')?.value ?? '';
    const fechaIngreso = qs('fechaIngreso')?.value ?? '';
    const fechaETD = qs('fechaETD')?.value ?? '';
    const fechaETA = qs('fechaETA')?.value ?? '';

    const apiBase = buscarBtn?.dataset.apiBase;
    const token = localStorage.getItem('token');

    const filtros = {
      orderName: orden,
      customerName: cliente,
      estado: estado !== 'Todos' && estado !== '' ? estado : undefined,
      fechaIngreso: fechaIngreso || undefined,
      fechaETD: fechaETD || undefined,
      fechaETA: fechaETA || undefined
    };
    // Elimina claves vacías o sin sentido
    Object.keys(filtros).forEach(key => {
      if (filtros[key] === undefined || filtros[key] === '') {
        delete filtros[key];
      }
    });

    showSkeleton();

    try {
      const response = await fetch(`${apiBase}/api/orders/search`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`
        },
        body: JSON.stringify(filtros)
      });
      const data = await response.json();

      console.log(data)

      currentData   = Array.isArray(data) ? data : [];
      itemsPerPage  = parseInt(itemsPerPageSelect.value, 10);
      currentPage   = 1;
      renderPage();
    } catch (error) {
      console.error(error);
      tablaBody.innerHTML = `<tr><td colspan="6" class="px-4 py-4 text-center text-red-500">Error al buscar</td></tr>`;
    }
  });

  limpiarBtn.addEventListener('click', () => {
    qs('cliente').value = '';
    qs('orden').value = '';
    qs('estado').value = '';
    qs('fechaIngreso').value = '';
    qs('fechaETD').value = '';
    qs('fechaETA').value = '';
  });

  updatePageIndicator();

  // --- sombra header al hacer scroll ---
  const head = document.getElementById('ordersHead');
  window.addEventListener('scroll', () => {
    head.classList.toggle('shadow-lg', window.scrollY > 40);
  });
})();
</script>

</script>
<style is:inline>
  @layer utilities {
    @keyframes fade-slide {
      0%   { opacity: 0; transform: translateY(8px); }
      100% { opacity: 1; transform: translateY(0);   }
    }
    .animate-fade-slide {
      animation: fade-slide .25s both;
    }
  }
</style>