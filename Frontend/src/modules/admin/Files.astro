---
import { loadTranslations, getServerLang } from '@lib/i18n.js';
import type { Files } from '../../types/entities.js';
import { getApiBase, getPublicApiUrl, getFileServerUrl } from '@app/constants.js';

const apiBase = getApiBase();
const apiPublic = getPublicApiUrl();
const fileServer = getFileServerUrl();
const lang = getServerLang(Astro.cookies);
const {
  basePath = '/admin',
  hideAdminActions = false,
  routeClientId = '',
  routePc = '',
  routeOc = '',
  routeCompany = '',
  routeFactura = ''
} = Astro.props;
const homeHref = basePath;
const clientsPath = `${basePath}/clients`;
const foldersViewPath = `${clientsPath}/folders/view`;

const url = new URL(Astro.url.href);
const clientName = url.searchParams.get('c') ?? routeCompany ?? '';
const decodedClientName = decodeURIComponent(clientName);
const folderId = url.searchParams.get('f') ?? '';
const idOv = url.searchParams.get('idov') ?? '';
const factura = url.searchParams.get('factura') ?? routeFactura ?? '';
const pc = url.searchParams.get('pc') ?? routePc ?? '';
const oc = url.searchParams.get('oc') ?? routeOc ?? '';

const { id: rawId } = Astro.params;
const id = rawId ?? routeClientId ?? '';

// Cargar traducciones de manera estática
let t: any = {};
try {
  t = {
    documentos: await loadTranslations(lang, 'documentos'),
    carpetas: await loadTranslations(lang, 'carpetas'),
    comond: await loadTranslations(lang, 'comond'),
  };
} catch (error) {
  console.warn('Error cargando traducciones, usando fallback:', error);
  // Fallback con traducciones básicas
  t = {
    documentos: {},
    carpetas: {},
    comond: {}
  };
}

const documentTypes: any[] = [];
const orderPc = pc || '';
const orderOc = oc || '';
const resolvedFolderId = folderId || '';
const emailRecipients: string[] = [];
const contactEmailMetadata: any[] = [];
---

<section
  id="filesSection"
  data-uuid={id}
  data-folder-id={resolvedFolderId}
  data-pc={orderPc}
  data-id-ov={idOv}
  data-factura={factura}
  data-base-path={basePath}
  data-clients-path={clientsPath}
  data-folders-path={foldersViewPath}
  class="px-4 pt-20 pb-6 sm:px-6 lg:px-8"
>
  <!-- Encabezado y breadcrumb -->
  <header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href={homeHref} class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            <span>{t.comond.home}</span>
          </a>
        </li>
        <li class="flex items-center text-gray-400 dark:text-gray-300 font-medium" aria-current="page">
          <span class="mx-1">/ <a href={clientsPath}>{t.carpetas.customers} </a> / <a href={`${foldersViewPath}/${id}?c=${decodedClientName}`}>{t.carpetas.title}</a> / </span>{t.documentos.title}
        </li>
			</ol>
    </nav>

    <!-- Título -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex flex-col gap-1">
        <h1 id="titleFile" class="text-3xl font-bold text-gray-900 dark:text-white">{decodedClientName} - {t.documentos.title}</h1>
        <div class="flex flex-col gap-1 text-sm text-gray-600 dark:text-gray-400">
          {orderPc && <span class="font-bold">{t.documentos.pcNumber}: {orderPc}</span>}
          {orderOc && <span class="font-bold">{t.documentos.ocNumber}: {orderOc}</span>}
        </div>
      </div>
	</div>

    <!-- Búsqueda y botones -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mt-4">
      <div class="relative w-full sm:max-w-xs">
        <label for="searchInput" class="sr-only">{t.comond.search}</label>
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
          </svg>
        </div>
        <input id="searchInput" type="text" placeholder={t.comond.search} class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-xs focus:outline-none focus:ring-2 focus:ring-primary-500" />
      </div>
      
      <!-- Botones de acción -->
      <div class="flex gap-2 items-center">
        {!hideAdminActions && (
          <button id="uploadHelpInlineBtn" type="button" class="w-9 h-9 inline-flex items-center justify-center rounded-md border border-blue-300 text-blue-600 hover:bg-blue-50 dark:border-blue-700 dark:text-blue-300 dark:hover:bg-blue-900/30 transition" aria-label={t.documentos.uploadHelpTitle}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.227 9a3 3 0 115.546 1c-.612.62-1.273 1.06-1.273 2M12 17h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
            </svg>
          </button>
        )}
        {/* Botón enviar documentos manuales en lote */}
        {!hideAdminActions && (
          <button id="bulkSendBtn" class="flex items-center justify-center gap-2 px-4 py-2 rounded-md text-sm font-semibold shadow-sm
              bg-blue-600 hover:bg-blue-700 text-white transition-all
              focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500
              disabled:bg-gray-400 disabled:cursor-not-allowed disabled:hover:bg-gray-400"
            data-tooltip={t.documentos.bulkSendTooltip ?? 'Enviar documentos por correo'}
            aria-label={t.documentos.bulkSendTooltip ?? 'Enviar documentos por correo'}>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <span>{t.documentos.bulkSend ?? 'Enviar documentos'}</span>
          </button>
        )}
        {/* Botón subir archivo (oculto para seller) */}
        {!hideAdminActions && (
          <button id="uploadFileBtn" class="flex items-center justify-center gap-2 px-4 py-2 rounded-md text-sm font-semibold shadow-sm
              bg-gray-200 hover:bg-gray-300 text-gray-700 transition-all dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-white
              focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
            <svg id="addIcon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            <svg id="spinnerIcon" class="w-4 h-4 animate-spin hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z" />
            </svg>
            <span id="addClientText">{t.documentos.upload}</span>
          </button>
        )}
        
        {/* Botón crear archivos por defecto (solo admin) */}
        {!hideAdminActions && (
          <button id="createDefaultFilesBtn" class="flex items-center justify-center gap-2 px-4 py-2 rounded-md text-sm font-semibold shadow-sm
              bg-green-600 hover:bg-green-700 text-white transition-all
              focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500
              disabled:bg-gray-400 disabled:cursor-not-allowed disabled:hover:bg-gray-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            <span>{t.documentos.createDefaultFiles}</span>
          </button>
        )}
      </div>
    </div>
  </header>

  <div class="overflow-auto mt-6 rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed">
      <thead id="filesHead" class="bg-gray-100/70 dark:bg-gray-800/70 backdrop-blur-md transition-shadow sticky top-0">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.name}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.status}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.created}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.generatedDate}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.sentDate}</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.resentDate}</th>
          <th class="px-4 py-3 text-center text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase">{t.documentos.visibleToClient}</th>
          <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 sticky right-0 z-20 min-w-[120px]">{t.comond.actions}</th>
        </tr>
      </thead>
      <tbody
        id="filesTableBody"
        class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-xs min-h-[600px] text-gray-900 dark:text-gray-200 transition-all duration-300 ease-out motion-safe:animate-fade-slide"
        data-hide-actions={hideAdminActions ? '1' : '0'}
      >
        <!-- Los datos se cargarán dinámicamente con JavaScript -->
        <tr id="loadingRow" class="bg-white dark:bg-gray-900">
          <td colspan="8" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">
            <div class="flex items-center justify-center">
              <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              {t.documentos.loadingFiles}
            </div>
          </td>
        </tr>
			</tbody>			
    </table>
  </div>

  <!-- Paginación -->
  <div class="mt-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-6 text-sm">
    <div class="flex items-center gap-3">
      <label for="itemsPerPageSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">{t.documentos.perPage}</label>
      <div class="relative">
        <select id="itemsPerPageSelect" class="block w-20 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-sm text-gray-900 dark:text-white rounded-md pl-3 pr-8 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="10">10</option>
          <option value="20">20</option>
          <option value="30">30</option>
        </select>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button id="prevPageBtn" aria-label="Previous page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <span id="pageIndicator" class="px-4 py-1 rounded-lg bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-white text-sm font-medium shadow-sm"></span>
      <button id="nextPageBtn" aria-label="Next page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
  <!-- Modal de Enviar Documento -->
	<div id="messageModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
		<div class="bg-white dark:bg-gray-800 dark:text-white rounded-lg p-6 w-full max-w-md relative">
			<div class="absolute top-3 right-3 flex items-center gap-2">
				<button id="messageHelpBtn" type="button" class="text-blue-600 hover:text-blue-800 dark:text-blue-300 dark:hover:text-blue-200" aria-label={t.documentos.sendDocumentsHelpTitle}>
					<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M8.227 9a3 3 0 115.546 1c-.612.62-1.273 1.06-1.273 2M12 17h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
					</svg>
				</button>
				<button id="closeMessageModalBtn" class="text-gray-400 hover:text-red-500 transition">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
			<div class="mb-4 pr-8">
				<h2 class="text-xl font-bold">{t.documentos.sendDocuments ?? t.documentos.sendCustomMessage}</h2>
			</div>
	
			<div class="mb-3 text-sm leading-5 space-y-1">
				<p class="text-gray-700 dark:text-gray-300">
					<strong>{t.documentos.orderNumber}:</strong>
					<span id="orderNumberDisplay" class="ml-1 text-gray-900 dark:text-white">-</span>
				</p>
				<p class="text-gray-700 dark:text-gray-300">
				<strong>{t.documentos.nameOfDocument}:</strong>
				<span id="orderDocumentDisplay" class="ml-1 text-gray-900 dark:text-white">-</span>
			</p>
			<hr class="border-t border-gray-200 dark:border-gray-700 pt-2">
			</div>
	
			<div class="mb-4">
				<label class="block text-sm font-medium text-gray-700 dark:text-gray-300">
					{t.documentos.emailRecipients}
				</label>
				<div
					id="emailRecipientsEditor"
					class="mt-2 space-y-3"
					data-initial-emails={JSON.stringify(emailRecipients)}
					data-no-active={t.documentos.noActiveEmails}
					data-invalid-email={t.documentos.invalidEmail}
					data-email-exists={t.documentos.emailAlreadySelected}
					data-no-recipients={t.documentos.noRecipientsSelected}
					data-add-placeholder={t.documentos.addEmailPlaceholder}
					data-add-button-label={t.documentos.addEmailButton}
					data-remove-label={t.documentos.removeEmail}
				>
					<div id="activeEmailChips" class="flex flex-wrap gap-2 rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/40 p-2 min-h-[40px]"></div>
					<div class="flex flex-wrap items-center gap-2">
						<input
							id="newEmailInput"
							type="email"
							class="flex-1 min-w-[200px] rounded-md border border-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white px-3 py-2 text-xs focus:outline-none focus:ring-2 focus:ring-blue-500"
							placeholder={t.documentos.addEmailPlaceholder}
						/>
						<button
							type="button"
							id="addEmailBtn"
							class="inline-flex items-center justify-center rounded-md bg-blue-600 px-3 py-2 text-xs font-semibold text-white shadow-sm transition hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
							aria-label={t.documentos.addEmailButton}
						>
							<svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
								<path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
							</svg>
						</button>
					</div>
					<div id="availableEmailsWrapper" class="hidden space-y-1">
						<p class="text-xs text-gray-500 dark:text-gray-400" id="availableEmailsLabel">
							{t.documentos.availableEmails}
						</p>
						<div id="availableEmailChips" class="flex flex-wrap gap-2"></div>
					</div>
          <div id="ccoEmailsWrapper" class="hidden space-y-1">
            <p class="text-xs text-gray-500 dark:text-gray-400" id="ccoEmailsLabel">
              {t.documentos.ccoEmails}
            </p>
            <div id="ccoEmailChips" class="flex flex-wrap gap-2"></div>
          </div>
					<input type="hidden" id="selectedEmailRecipients" value={emailRecipients.join(',')} />
				</div>
			</div>

      <div class="my-4 border-t border-gray-200 dark:border-gray-700"></div>
	
			<div class="flex justify-end gap-2">
				<button
					id="cancelMessageBtn"
					class="px-4 py-2 bg-gray-300 hover:bg-gray-400 dark:bg-gray-600 dark:hover:bg-gray-500 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500 text-xs"
				>
					{t.comond.cancel}
				</button>
				<button
					id="confirmMessageBtn"
					class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500 text-xs"
				>
					{t.comond.confirm}
				</button>
			</div>
		</div>
	</div>

	<div id="messageHelpModal" class="fixed inset-0 hidden justify-center items-center z-50 bg-black/50 flex backdrop-blur-sm">
		<div class="bg-white/95 dark:bg-gray-800/95 text-gray-900 dark:text-gray-100 rounded-2xl p-6 w-full max-w-md relative shadow-2xl ring-1 ring-gray-200 dark:ring-white/10">
			<button id="closeMessageHelpModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition text-xs">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
			<h3 class="text-lg font-bold mb-3">{t.documentos.sendDocumentsHelpTitle}</h3>
			<div class="my-3 border-t border-gray-200 dark:border-gray-700"></div>
			<ul class="text-sm text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
				<li>{t.documentos.sendDocumentsHelpAdd}</li>
				<li>{t.documentos.sendDocumentsHelpRemove}</li>
				<li>{t.documentos.sendDocumentsHelpRestricted}</li>
				<li>{t.documentos.sendDocumentsHelpCco}</li>
				<li>{t.documentos.sendDocumentsHelpManual}</li>
			</ul>
			<div class="my-4 border-t border-gray-200 dark:border-gray-700"></div>
			<div class="flex justify-end">
				<button id="closeMessageHelpModalFooterBtn" class="px-4 py-2 bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-white rounded-md text-sm">
					{t.comond.close}
				</button>
			</div>
		</div>
	</div>

	<!-- Modal de Envío Masivo de Documentos -->
	<div id="bulkSendModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
		<div class="bg-white dark:bg-gray-800 dark:text-white rounded-lg p-6 w-full max-w-lg relative max-h-[90vh] flex flex-col">
			<div class="absolute top-3 right-3 flex items-center gap-2">
				<button id="bulkSendHelpBtn" type="button" class="text-blue-600 hover:text-blue-800 dark:text-blue-300 dark:hover:text-blue-200" aria-label={t.documentos.bulkSendHelpTitle ?? 'Ayuda de envío masivo'}>
					<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M8.227 9a3 3 0 115.546 1c-.612.62-1.273 1.06-1.273 2M12 17h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
					</svg>
				</button>
				<button id="closeBulkSendModalBtn" class="text-gray-400 hover:text-red-500 transition">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
			</div>
			<div class="mb-4 pr-8">
				<h2 class="text-xl font-bold">{t.documentos.bulkSendTitle ?? 'Enviar documentos por correo'}</h2>
			</div>

			<div class="mb-3 text-sm leading-5 space-y-1">
				<p class="text-gray-700 dark:text-gray-300">
					<strong>{t.documentos.orderNumber}:</strong>
					<span id="bulkSendOrderDisplay" class="ml-1 text-gray-900 dark:text-white">-</span>
				</p>
			</div>

			<!-- Lista de documentos con checkboxes -->
			<div class="mb-4 border border-gray-200 dark:border-gray-700 rounded-md">
				<div id="bulkSendFileList" class="divide-y divide-gray-200 dark:divide-gray-700">
					<!-- Se llena dinámicamente -->
