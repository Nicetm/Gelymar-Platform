<script type="module" define:vars={{ apiBase, apiPublic, fileServer, lang, documentTypes, orderOc, orderPc, idOv, factura, t, emailRecipients, contactEmailMetadata }}>

  import { initFilesScript } from '/js/files.js';
  
  // Hacer las variables disponibles globalmente
  window.apiBase = apiPublic;
  window.fileServer = fileServer;
  window.lang = lang;
  window.documentTypes = documentTypes;
  window.orderOc = orderOc;
  window.orderPc = orderPc;
  window.orderIdOv = idOv;
  window.orderFactura = factura;
  window.translations = { ...(window.translations || {}), ...t };
  window.emailRecipients = Array.isArray(emailRecipients)
    ? Array.from(new Set(emailRecipients.map((email) => (typeof email === 'string' ? email.trim() : '')).filter(Boolean)))
    : [];
  window.emailRecipientMetadata = Array.isArray(contactEmailMetadata)
    ? contactEmailMetadata
        .map((contact) => ({
          email: typeof contact?.email === 'string' ? contact.email.trim() : '',
          name: typeof contact?.name === 'string' ? contact.name : '',
          sh_documents: !!contact?.sh_documents,
          reports: !!contact?.reports,
          cco: !!contact?.cco,
        }))
        .filter((contact) => contact.email)
    : [];

  // Inicializar el script cuando el DOM esté completamente cargado
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      // Pequeño delay para asegurar que todo esté listo
      setTimeout(() => {
        initFilesScript();
      }, 100);
    });
  } else {
    // Si el DOM ya está cargado, ejecutar con un pequeño delay
    setTimeout(() => {
      initFilesScript();
    }, 100);
  } 
</script>


