---
import { loadTranslations, getServerLang } from '../../lib/i18n.js';
import type { Folders } from '../../types/entities.js';
import { formatDateShort } from '../../utils/formatDate.js';

const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const fileServer = import.meta.env.PUBLIC_FILE_SERVER_URL;
const lang = getServerLang(Astro.cookies);

const url = new URL(Astro.url.href);
const clientName = url.searchParams.get('c') ?? '';
const decodedClientName = decodeURIComponent(clientName);
const { id } = Astro.params;
const t: any = {
  carpetas: await loadTranslations(lang, 'carpetas'),
  comond: await loadTranslations(lang, 'comond'),
};

const token = Astro.cookies.get('token')?.value;
const folders: Folders[] = await fetch(`${apiBase}/api/directories/${id}`, {
  headers: { Authorization: `Bearer ${token}` }
}).then(res => res.json());

---

<section id="folderSection" data-api-base={apiBase} data-file-server={fileServer} data-uuid={id} class="px-4 pt-24 pb-6 sm:px-6 lg:px-8">
	<!-- Encabezado y breadcrumb -->
	<header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
		<nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
			<ol class="inline-flex items-center space-x-1 md:space-x-2">
				<li class="inline-flex items-center">
					<a href="/admin" class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
							<path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
						</svg>
						<span>{t.comond.home}</span>
					</a>
				</li>
				<li aria-current="page" class="flex items-center text-gray-400 dark:text-gray-300 font-medium">
					<span class="mx-1">/ <a href="/admin/clients">{t.carpetas.customers} </a> / </span>{t.carpetas.title}
				</li>
			</ol>
		</nav>

		<!-- Título -->
		<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
			<h1 id="clientTitle" class="text-3xl font-bold text-gray-900 dark:text-white">{decodedClientName} - {t.carpetas.orders}</h1>
		</div>

		<!-- Búsqueda y botón agregar carpeta -->
		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mt-4">
			<div class="relative w-full sm:max-w-xs">
				<label for="searchInput" class="sr-only">{t.carpetas.search}</label>
				<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
					<svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
					</svg>
				</div>
				<input id="searchInput" type="text" placeholder={t.comond.search} class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500" />
			</div>
		</div>
	</header>

	<!-- Tabla de carpetas -->
	<div class="overflow-auto mt-6 rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700">
		<table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed">
			<thead class="bg-gray-100 dark:bg-gray-800 sticky top-0 z-10">
				<tr>
					<th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="pc">
						<div class="flex items-center justify-between">
							<span>{t.carpetas.pc}</span>
							<svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
							</svg>
						</div>
					</th>
					<th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="oc">
						<div class="flex items-center justify-between">
							<span>{t.carpetas.oc}</span>
							<svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
							</svg>
						</div>
					</th>
					<th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="fecha">
						<div class="flex items-center justify-between">
							<span>{t.carpetas.fecha}</span>
							<svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
							</svg>
						</div>
					</th>
					<th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="moneda">
						<div class="flex items-center justify-between">
							<span>{t.carpetas.moneda}</span>
							<svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
							</svg>
						</div>
					</th>
					<th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="medio_envio">
						<div class="flex items-center justify-between">
							<span>{t.carpetas.medioEnvio}</span>
							<svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
							</svg>
						</div>
					</th>
					<th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="factura">
						<div class="flex items-center justify-between">
							<span>{t.carpetas.factura}</span>
							<svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
							</svg>
						</div>
					</th>
					<th class="px-4 py-3 text-left text-xs font-semibold text-gray-700 dark:text-gray-300 uppercase cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="fecha_factura">
						<div class="flex items-center justify-between">
							<span>{t.carpetas.fechaFactura}</span>
							<svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
							</svg>
						</div>
					</th>
					<th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.comond.actions}</th>
				</tr>
			</thead>
			<tbody id="foldersTableBody" class="divide-y divide-gray-200 dark:divide-gray-700 bg-white dark:bg-gray-900">
				{Array.isArray(folders) && folders.map(folder => (
					<tr data-id={folder.id} class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-sm min-h-[600px]">
						<td class="px-6 py-4 items-center gap-3">{folder.pc}</td>
						<td class="px-6 py-4 items-center gap-3">{folder.oc}</td>
						<td class="px-6 py-4 items-center gap-3">{formatDateShort(folder.fecha_cliente)}</td>
						<td class="px-6 py-4 items-center gap-3">{folder.currency || '-'}</td>
						<td class="px-6 py-4 items-center gap-3">{folder.medio_envio || '-'}</td>
						<td class="px-6 py-4 items-center gap-3">{folder.factura || '-'}</td>
						<td class="px-6 py-4 items-center gap-3">{formatDateShort(folder.fecha_factura)}</td>
						<td class="px-6 py-4 items-center gap-3">
							<div class="flex justify-center items-center gap-3 text-gray-900 dark:text-white">
								<a href={`/admin/clients/documents/view/${folder.customer_uuid}?f=${folder.id}&pc=${folder.pc}&c=${clientName}`} title={`Ver documentos de PC ${folder.pc}`} class="hover:text-blue-500 transition">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
								</a>
								<a href="#" title={`${t.carpetas.viewItemsList} ${folder.pc}`} class="hover:text-indigo-500 transition">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
									</svg>
								</a>
								<a href="#" title={`${t.carpetas.orderDetails} ${folder.pc}`} class="order-detail-btn hover:text-blue-500 transition" data-order-id={folder.id}>
									<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
									</svg>
								</a>
							</div>
						</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>

	<!-- Paginación -->
	<div class="mt-6 flex flex-col sm:flex-row justify-between items-center gap-4 text-sm">
		<div class="flex items-center gap-3">
			<label for="itemsPerPageSelect" class="text-sm font-medium">{t.carpetas.perPage}</label>
			<select id="itemsPerPageSelect" class="block w-20 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white rounded-md py-2 pl-3 pr-8">
				<option value="10">10</option>
				<option value="20">20</option>
				<option value="30">30</option>
			</select>
		</div>

		<div class="flex items-center gap-3">
			<button id="prevPageBtn" class="w-9 h-9 flex items-center justify-center rounded-md bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white">
				‹
			</button>
			<span id="pageIndicator" data-page-label={t.comond.page} data-of-label={t.comond.of} class="text-sm font-medium text-gray-700 dark:text-gray-300">Página 1</span>
			<button id="nextPageBtn" class="w-9 h-9 flex items-center justify-center rounded-md bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white">
				›
			</button>
		</div>
	</div>
</section>



<!-- Modal de Items de la Orden -->
<div id="itemsModal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-black/80 hidden justify-center items-center z-50">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-6 w-full max-w-4xl mx-4 relative max-h-[90vh] overflow-y-auto shadow-2xl">
    <!-- Botón de cerrar -->
    <button id="closeItemsModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition dark:text-gray-300 dark:hover:text-red-400">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <!-- Header con logo y nombre -->
    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 bg-gradient-to-br from-green-500 to-emerald-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
        <span id="itemsInitials">IT</span>
      </div>
      <div>
        <h2 id="itemsOrderTitle" class="text-xl font-bold text-gray-900 dark:text-gray-100"></h2>
        <p id="itemsOrderSubtitle" class="text-sm text-gray-600 dark:text-gray-400">{t.carpetas.itemsList}</p>
      </div>
    </div>

    <!-- Tabla de items -->
    <div class="overflow-auto rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-100 dark:bg-gray-800 sticky top-0 z-10">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.itemCode}</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.itemName}</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.unitMeasure}</th>
            <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.requestedQuantity}</th>
            <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.unitPrice}</th>
            <th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.total}</th>
          </tr>
        </thead>
        <tbody id="itemsTableBody" class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800">
          <!-- Los items se cargarán dinámicamente aquí -->
        </tbody>
      </table>
    </div>

    <!-- Resumen de la orden -->
    <div class="mt-6 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">{t.carpetas.totalItems}</p>
          <p id="totalItems" class="text-lg font-bold text-gray-900 dark:text-gray-100">0</p>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">{t.carpetas.totalQuantity}</p>
          <p id="totalQuantity" class="text-lg font-bold text-gray-900 dark:text-gray-100">0</p>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">{t.carpetas.totalValue}</p>
          <p id="totalValue" class="text-lg font-bold text-green-600 dark:text-green-400">$0</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal de Detalles de la Orden -->
<div id="orderDetailModal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-black/80 hidden justify-center items-center z-50">
  <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-6 w-full max-w-2xl mx-4 relative max-h-[90vh] overflow-y-auto shadow-2xl">
    <!-- Botón de cerrar -->
    <button id="closeOrderDetailModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition dark:text-gray-300 dark:hover:text-red-400">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <!-- Header con logo y nombre -->
    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
        <span id="orderDetailInitials">OD</span>
      </div>
      <div>
        <h2 id="orderDetailTitle" class="text-xl font-bold text-gray-900 dark:text-gray-100"></h2>
        <p id="orderDetailSubtitle" class="text-sm text-gray-600 dark:text-gray-400">{t.carpetas.orderDetails}</p>
      </div>
    </div>

    <!-- Detalles de la orden -->
    <div class="space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{t.carpetas.pcNumber}</label>
          <p id="orderDetailPc" class="text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800 p-2 rounded border">-</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{t.carpetas.ocNumber}</label>
          <p id="orderDetailOc" class="text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800 p-2 rounded border">-</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{t.carpetas.fechaEtd}</label>
          <p id="orderDetailFechaEtd" class="text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800 p-2 rounded border">-</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{t.carpetas.fechaEta}</label>
          <p id="orderDetailFechaEta" class="text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800 p-2 rounded border">-</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{t.carpetas.incoterm}</label>
          <p id="orderDetailIncoterm" class="text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800 p-2 rounded border">-</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{t.carpetas.certificados}</label>
          <p id="orderDetailCertificados" class="text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800 p-2 rounded border">-</p>
        </div>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{t.carpetas.direccionDestino}</label>
        <p id="orderDetailDireccionDestino" class="text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800 p-2 rounded border min-h-[60px]">-</p>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{t.carpetas.puertoDestino}</label>
        <p id="orderDetailPuertoDestino" class="text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800 p-2 rounded border">-</p>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">{t.carpetas.observaciones}</label>
        <p id="orderDetailObservaciones" class="text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-gray-800 p-2 rounded border min-h-[60px]">-</p>
      </div>
    </div>
  </div>
</div>

<div id="notification" class="hidden fixed top-5 right-5 px-6 py-4 rounded-lg shadow-lg z-50 text-white text-base font-semibold transition-all duration-300 ease-in-out"></div>

<script type="module" define:vars={{ apiBase, fileServer, lang, t }}>
  import { initFoldersScript } from '/js/folders.js';
  
  // Hacer las variables disponibles globalmente
  window.apiBase = apiBase;
  window.fileServer = fileServer;
  window.lang = lang;
  window.translations = t;

  // Inicializar el script cuando el DOM esté completamente cargado
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initFoldersScript();
    });
  } else {
    // Si el DOM ya está cargado, ejecutar inmediatamente
    initFoldersScript();
  } 
</script>
		
