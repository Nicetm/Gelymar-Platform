---
import { loadTranslations, getServerLang } from '../../lib/i18n.js';
import type { Orders } from '../../types/entities.js';
import { formatDateShort } from '../../utils/formatDate.js';

// Para el código del servidor (SSR), usar SERVER_API_URL
// Para el código del cliente, usar PUBLIC_API_URL
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const clientApiBase = import.meta.env.PUBLIC_API_URL;
const lang = getServerLang(Astro.cookies);

const t: any = {
  documentos: await loadTranslations(lang, 'documentos'),
  carpetas: await loadTranslations(lang, 'carpetas'),
  clientes: await loadTranslations(lang, 'clientes'),
  comond: await loadTranslations(lang, 'comond'),
};

const token = Astro.cookies.get('token')?.value;
const orders: Orders[] = await fetch(`${apiBase}/api/orders`, {
  headers: { Authorization: `Bearer ${token}` }
}).then(res => res.json());
---

<section id="OrderSection" class="px-4 pt-20 pb-6 sm:px-6 lg:px-8">
  <!-- Encabezado y breadcrumb -->
  <header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="/admin" class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            <span>{t.comond.home}</span>
          </a>
        </li>
        <li class="flex items-center text-gray-400 dark:text-gray-300 font-medium" aria-current="page">
          <span class="mx-1">/ {t.comond.search} {t.carpetas.orders}
        </li>
			</ol>
    </nav>

    <!-- Título -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h1 id="titleFile" class="text-3xl font-bold text-gray-900 dark:text-white">{t.comond.search} {t.carpetas.orders}</h1>
		</div>
  </header>

	<!-- Buscador avanzado -->
	<div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 bg-gray-50 dark:bg-gray-800 p-4 rounded-md shadow-sm">
		<!-- Orden -->
		<div class="relative">
			<label for="orden" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.pc ?? 'PC'}</label>
			<div class="relative">
				<input type="text" id="orden" name="orden" placeholder={t.documentos.orderPlaceholder}
					class="w-full pl-10 pr-10 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
				<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
					<svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
					</svg>
				</div>
				<div class="absolute inset-y-0 right-0 flex items-center pr-3">
					<button type="button" id="clearOrdenBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-200 hidden">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
						</svg>
					</button>
				</div>
			</div>
		</div>

		<!-- Cliente -->
		<div class="relative">
			<label for="cliente" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.cliente ?? 'Cliente'}</label>
			<div class="relative">
				<input type="text" id="cliente" name="cliente" placeholder={t.documentos.clientPlaceholder}
					class="w-full pl-10 pr-20 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500"
					autocomplete="off">
				<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
					<svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
					</svg>
				</div>
				<div class="absolute inset-y-0 right-0 flex items-center pr-3 gap-1">
					<button type="button" id="clearClienteBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-200 hidden">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
						</svg>
					</button>
					<svg id="clienteDropdownIcon" class="w-5 h-5 text-gray-400 cursor-pointer" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
					</svg>
				</div>
			</div>
			<div id="clienteDropdown" class="absolute z-50 w-full mt-1 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md shadow-lg max-h-60 overflow-y-auto hidden">
				<!-- Las opciones se cargarán dinámicamente -->
			</div>
		</div>

		<!-- Fecha Ingreso -->
		<div class="relative">
			<label for="fechaIngreso" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.fechaIngreso ?? 'Fecha Ingreso'}</label>
			<div class="relative">
				<input type="date" id="fechaIngreso" name="fechaIngreso" placeholder={t.documentos.fechaIngresoPlaceholder}
					class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
				<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
					<svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
					</svg>
				</div>
			</div>
		</div>

		<!-- Estado -->
		<div class="relative">
			<label for="estado" class="block text-sm font-medium text-gray-700 dark:text-gray-200">{t.documentos.estado ?? 'Estado'}</label>
			<div class="relative">
				<select id="estado" name="estado"
					class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary-500">
					<option value="">{t.documentos.estadoTodos}</option>
					<option value="pendiente">{t.documentos.estadoPendiente}</option>
					<option value="enviado">{t.documentos.estadoEnviado}</option>
					<option value="completado">{t.documentos.estadoCompletado}</option>
				</select>
				<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
					<svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
				</div>
			</div>
		</div>
	</div>

	<div class="mt-4 flex justify-end gap-2">
		<!-- Botón Limpiar -->
		<button id="limpiarBtn" class="flex items-center gap-2 px-4 py-2 bg-gray-500 text-white text-sm font-semibold rounded-md shadow-sm hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-400">
			<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
			{t.comond.clear}
		</button>
	
		<!-- Botón Buscar -->
		<button id="buscarBtn" data-api-base={clientApiBase} class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
			<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z"/>
			</svg>
			{t.comond.search}
		</button>
	</div>

	<!-- Tabla de resultados -->
	<div class="overflow-auto mt-6 rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700 scrollbar-thin scrollbar-thumb-primary-500/60 dark:scrollbar-thumb-primary-400/60 scrollbar-track-gray-200 dark:scrollbar-track-gray-800">
		<table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed">
			<thead id="ordersHead" class="bg-gray-100/70 dark:bg-gray-800/70 backdrop-blur-md transition-shadow sticky top-0 z-10">
				<tr>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.name}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.oc}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.clientes.client_name}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.fecha}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.moneda}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.medioEnvio}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.factura}</th>
					<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.carpetas.fechaFactura}</th>
					<th class="px-6 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">{t.comond.actions}</th>
				</tr>
			</thead>
			<tbody id="resultadosTabla" class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-sm min-h-[600px] text-gray-900 dark:text-gray-200 transition-all duration-300 ease-out motion-safe:animate-fade-slide">
				{Array.isArray(orders) && orders.map(order => (
					<tr data-id={order.id} class="transition-colors duration-150 hover:bg-gray-100 dark:hover:bg-gray-800 hover:shadow-[0_1px_3px_rgba(0,0,0,0.12)]">
						<td class="px-6 py-4 text-sm editable-filename group cursor-pointer" data-id={order.id}>{order.pc}</td>
						<td class="px-6 py-4 text-sm editable-filename group cursor-pointer" data-id={order.id}>{order.oc}</td>
						<td class="px-4 py-3 break-all text-blue-600 dark:text-blue-400">{order.customer_name}</td>
						<td class="px-6 py-4 items-center gap-3">{formatDateShort(order.fecha_cliente)}</td>
						<td class="px-6 py-4 items-center gap-3">{order.currency || '-'}</td>
						<td class="px-6 py-4 items-center gap-3">{order.medio_envio || '-'}</td>
						<td class="px-6 py-4 items-center gap-3">{order.factura || '-'}</td>
						<td class="px-6 py-4 items-center gap-3">{formatDateShort(order.fecha_factura)}</td>
						<td class="px-6 py-4 items-center gap-3">
							<div class="flex justify-center items-center gap-3 text-gray-900 dark:text-white">
								<a href={`/admin/clients/documents/view/${order.customer_uuid}?f=${order.id}&pc=${order.pc}&c=${order.customer_name}`} class="go-to-order-btn" title="Ir a la orden">
									<svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7m0 0v7m0-7L10 14m-4 0h.01M5 14a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h5a1 1 0 0 0 1-1v-.01" />
									</svg>
								</a>
								<a href="#" title={`Editar ${order.oc}`} class="edit-btn hover:text-green-500 transition" data-file-id={order.id}>
									<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536M9 11l6.586-6.586a2 2 0 112.828 2.828L11.828 13.83a2 2 0 01-.586.414L9 15l.756-2.243a2 2 0 01.414-.586z" />
										<path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5" />
									</svg>
								</a>
							</div>
						</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>

	<!-- Paginación -->
  <div class="mt-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-6 text-sm">
    <div class="flex items-center gap-3">
      <label for="itemsPerPageSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">{t.clientes.perPage}</label>
      <div class="relative">
        <select id="itemsPerPageSelect" class="block w-20 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-sm text-gray-900 dark:text-white rounded-md pl-3 pr-8 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="10">10</option>
          <option value="20">20</option>
          <option value="30">30</option>
        </select>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button id="prevPageBtn" aria-label="Previous page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <span id="pageIndicator" class="px-4 py-1 rounded-lg bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-white text-sm font-medium shadow-sm">Page 1 of 5</span>
      <button id="nextPageBtn" aria-label="Next page" class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-white rounded-md transition-transform duration-150 active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary-500">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>

	<!-- Modal overlay and form -->
	<div id="editOrderModal" class="fixed inset-0 bg-black bg-opacity-50 hidden justify-center items-center z-50">
		<div class="bg-white dark:bg-gray-800 dark:text-white rounded-lg p-6 w-full max-w-md relative"> <!-- <-- Aquí -->
			<!-- Botón de cerrar -->
			<button id="closeModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 transition">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
			<h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">{t.clientes.createTitle}</h2>
		</div>
		<div class="flex justify-end gap-2">
			<button id="cancelEditBtn" class="px-4 py-2 bg-gray-300 dark:bg-gray-600 dark:text-white rounded-md">{t.comond.cancel}</button>
			<button id="confirmEditBtn" class="bg-[#00538C] hover:bg-[#004773] text-white px-4 py-2 rounded-md font-medium">{t.comond.confirm}</button>
		</div>
	</div>
</section>

<script type="module" define:vars={{ apiBase, lang }}>
  import { initOrdersScript, openEditOrderModal } from '/js/orders.js';
  import { showNotification } from '/js/utils.js';

  // Esperar a que el DOM esté listo antes de inicializar
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initOrdersScript();
    });
  } else {
    initOrdersScript();
  }

  window.openEditOrderModal = openEditOrderModal;

  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('.edit-btn');
    if (!btn) return;

    console.log('Botón de edición clickeado');
    e.preventDefault();
    const orderId = btn.dataset.fileId;
    const row = btn.closest('tr');
    const orderName = row.querySelector('td:first-child')?.textContent?.trim() || '';

    console.log('OrderId:', orderId, 'OrderName:', orderName);
    await openEditOrderModal(orderId, orderName);
  });

</script>
<style is:inline>
  @layer utilities {
    @keyframes fade-slide {
      0%   { opacity: 0; transform: translateY(8px); }
      100% { opacity: 1; transform: translateY(0);   }
    }
    .animate-fade-slide {
      animation: fade-slide .25s both;
    }
  }
</style>