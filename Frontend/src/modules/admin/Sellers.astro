---
import { loadTranslations, getServerLang } from '@lib/i18n.js';
import ModalChangePassword from '../../components/modals/clients/ModalChangePassword.astro';

const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const apiPublic = import.meta.env.PUBLIC_API_URL;
const lang = getServerLang(Astro.cookies);

let t: any = {};
try {
  t = {
    vendedores: await loadTranslations(lang, 'vendedores'),
    comond: await loadTranslations(lang, 'comond'),
  };
} catch (error) {
  console.warn('Error cargando traducciones de vendedores, usando fallback:', error);
  t = {
    vendedores: {
      home: 'Inicio',
      title: 'Vendedores',
      heading: 'Equipo de vendedores',
      search: 'Buscar vendedor...',
      name: 'Nombre',
      email: 'Correo',
      active: 'Activo',
      blocked: 'Bloqueado',
      actions: 'Acciones',
      action_change_password: 'Cambiar contraseña',
      action_update: 'Actualizar datos',
      modal_change_password_title: 'Cambiar contraseña del vendedor',
      modal_change_password_label: 'Vendedor',
      modal_change_password_submit: 'Actualizar contraseña',
      modal_update_title: 'Actualizar vendedor',
      modal_update_name: 'Nombre',
      modal_update_phone: 'Teléfono',
      modal_update_email: 'Email',
      modal_update_rut: 'RUT',
      modal_update_active: 'Activo',
      modal_update_blocked: 'Bloqueado',
      modal_update_save: 'Guardar cambios',
      modal_update_cancel: 'Cancelar',
      confirm_update_title: '¿Guardar cambios?',
      confirm_update_message: 'Se actualizarán los datos del vendedor.',
      confirm_password_title: '¿Cambiar contraseña?',
      confirm_password_message: 'La contraseña del vendedor será actualizada.',
      validation_required: 'Completa los campos obligatorios.',
      validation_email: 'Email inválido.',
      validation_phone: 'Teléfono debe tener entre 8 y 20 caracteres.',
      validation_rut: 'RUT inválido.',
      validation_password_match: 'Las contraseñas no coinciden.',
      validation_password_strength: 'La contraseña debe tener al menos 8 caracteres e incluir mayúscula, minúscula y número.',
      update_success: 'Vendedor actualizado correctamente.',
      update_error: 'Error al actualizar vendedor.',
      password_success: 'Contraseña actualizada correctamente.',
      password_error: 'Error al actualizar contraseña.',
      status: 'Estado',
      status_online: 'En línea',
      status_offline: 'Desconectado',
      created_at: 'Creado',
      updated_at: 'Actualizado',
      noResults: 'No se encontraron vendedores',
      loading: 'Cargando vendedores...'
    },
    comond: await loadTranslations(lang, 'comond')
  };
}
---

<section id="sellerSection" class="px-4 pt-20 pb-6 sm:px-6 lg:px-8">
  <header class="flex flex-col gap-4 border-b border-gray-200 dark:border-gray-700 pb-4">
    <nav class="text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="/admin" class="inline-flex items-center gap-1 hover:text-primary-600 dark:hover:text-white">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
            </svg>
            <span>{t.vendedores.home}</span>
          </a>
        </li>
        <li aria-current="page" class="flex items-center text-gray-400 dark:text-gray-300 font-medium">
          <span class="mx-1">/</span>{t.vendedores.title}
        </li>
      </ol>
    </nav>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">{t.vendedores.heading}</h1>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mt-4">
      <div class="relative w-full sm:max-w-xs">
        <label for="sellerSearchInput" class="sr-only">{t.vendedores.search}</label>
        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
          <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z" />
          </svg>
        </div>
        <input
          id="sellerSearchInput"
          type="text"
          placeholder={t.vendedores.search}
          class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-800 text-gray-900 dark:text-white text-xs focus:outline-none focus:ring-2 focus:ring-primary-500"
        />
      </div>
    </div>
  </header>

  <div class="mt-6 rounded-xl shadow ring-1 ring-gray-200 dark:ring-gray-700">
    <div class="relative" data-scroll-sync="sellers-table">
      <div class="sticky top-0 z-30 bg-gray-100 dark:bg-gray-800 hidden" data-scroll-header>
        <div class="overflow-x-auto scrollbar-hidden" data-scroll-header-track>
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed bg-white dark:bg-gray-900"></table>
        </div>
      </div>
      <div class="overflow-x-auto" style="border-radius: 10px;" data-scroll-body>
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 table-fixed bg-white dark:bg-gray-900">
          <thead class="bg-gray-100 dark:bg-gray-800">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="full_name">
            <div class="flex items-center justify-between">
              <span>{t.vendedores.name}</span>
              <svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
              </svg>
            </div>
          </th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="rut">
            <div class="flex items-center justify-between">
              <span>{t.vendedores.rut}</span>
              <svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
              </svg>
            </div>
          </th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="email">
            <div class="flex items-center justify-between">
              <span>{t.vendedores.email}</span>
              <svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
              </svg>
            </div>
          </th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="activo">
            <div class="flex items-center justify-between">
              <span>{t.vendedores.active}</span>
              <svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
              </svg>
            </div>
          </th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="bloqueado">
            <div class="flex items-center justify-between">
              <span>{t.vendedores.blocked}</span>
              <svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
              </svg>
            </div>
          </th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="online">
            <div class="flex items-center justify-between">
              <span>{t.vendedores.status}</span>
              <svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
              </svg>
            </div>
          </th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300 cursor-pointer hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors" data-sort="created_at">
            <div class="flex items-center justify-between">
              <span>{t.vendedores.created_at}</span>
              <svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l4-4 4 4m0 6l-4 4-4-4" />
              </svg>
            </div>
          </th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">
            <span>{t.vendedores.actions}</span>
          </th>
        </tr>
          </thead>
          <tbody id="sellersTableBody" class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800 text-sm min-h-[400px]">
        <tr id="sellersLoadingRow" class="bg-white dark:bg-gray-900">
          <td colspan="8" class="px-6 py-6 text-center text-gray-500 dark:text-gray-400">
            <div class="flex items-center justify-center">
              <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              {t.vendedores.loading}
            </div>
          </td>
        </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <ModalChangePassword
    changePassword={{
      title: t.vendedores.modal_change_password_title,
      customerLabel: t.vendedores.modal_change_password_label,
      newPasswordLabel: t.comond?.new_password_label || 'Nueva contraseña',
      confirmPasswordLabel: t.comond?.confirm_password_label || 'Confirmar contraseña',
      newPasswordPlaceholder: t.comond?.new_password_placeholder || 'Ingresa la nueva contraseña',
      confirmPasswordPlaceholder: t.comond?.confirm_password_placeholder || 'Confirma la nueva contraseña',
      submit: t.vendedores.modal_change_password_submit,
      rules: {
        minLength: t.comond?.password_rule_min || 'Debe tener al menos 8 caracteres',
        upper: t.comond?.password_rule_upper || 'Debe incluir una mayúscula',
        lower: t.comond?.password_rule_lower || 'Debe incluir una minúscula',
        number: t.comond?.password_rule_number || 'Debe incluir un número'
      }
    }}
    cancelLabel={t.vendedores.modal_update_cancel}
  />

  <div id="sellerUpdateModal" class="fixed inset-0 bg-black bg-opacity-50 dark:bg-black/80 hidden justify-center items-center z-50">
    <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg p-6 w-full max-w-lg mx-4 relative shadow-2xl">
      <button id="closeSellerUpdateModalBtn" class="absolute top-3 right-3 text-gray-400 hover:text-blue-500 transition dark:text-gray-300 dark:hover:text-blue-400">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <div class="flex items-center gap-3 mb-6">
        <div class="p-2 bg-green-100 dark:bg-green-900/30 rounded-lg">
          <svg class="w-6 h-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">{t.vendedores.modal_update_title}</h2>
      </div>

      <form id="sellerUpdateForm" class="space-y-4">
        <div>
          <label for="sellerUpdateName" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">
            {t.vendedores.modal_update_name}
          </label>
          <input
            id="sellerUpdateName"
            type="text"
            disabled
            class="w-full text-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 focus:outline-none"
          />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="sellerUpdatePhone" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">
              {t.vendedores.modal_update_phone}
            </label>
            <input
              id="sellerUpdatePhone"
              type="text"
              class="w-full text-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition"
            />
          </div>
          <div>
            <label for="sellerUpdateEmail" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">
              {t.vendedores.modal_update_email}
            </label>
            <input
              id="sellerUpdateEmail"
              type="email"
              class="w-full text-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="sellerUpdateRut" class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-2">
              {t.vendedores.modal_update_rut}
            </label>
            <input
              id="sellerUpdateRut"
              type="text"
              class="w-full text-xs px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition"
            />
          </div>
          <div class="flex items-center gap-4 pt-6">
            <label class="inline-flex items-center gap-2 text-xs text-gray-700 dark:text-gray-300">
              <input id="sellerUpdateActive" type="checkbox" class="h-4 w-4 accent-green-500">
              {t.vendedores.modal_update_active}
            </label>
            <label class="inline-flex items-center gap-2 text-xs text-gray-700 dark:text-gray-300">
              <input id="sellerUpdateBlocked" type="checkbox" class="h-4 w-4 accent-rose-500">
              {t.vendedores.modal_update_blocked}
            </label>
          </div>
        </div>
      </form>

      <div class="flex justify-end gap-3 mt-6 pt-4 border-t border-gray-200 dark:border-gray-700">
        <button id="cancelSellerUpdateBtn" type="button"
          class="text-xs px-4 py-2 bg-gray-300 dark:bg-gray-800 text-gray-700 dark:text-gray-100 rounded-md hover:bg-gray-400 dark:hover:bg-gray-700 transition font-medium">
          {t.vendedores.modal_update_cancel}
        </button>
        <button id="saveSellerUpdateBtn" type="button"
          class="text-xs px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-md font-medium transition flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          {t.vendedores.modal_update_save}
        </button>
      </div>
    </div>
  </div>
  <style>
    .scrollbar-hidden {
      scrollbar-width: none;
    }
    .scrollbar-hidden::-webkit-scrollbar {
      height: 0;
    }
    .sticky-scroll-header-floating {
      position: fixed;
      top: 64px;
    }
  </style>

  <div class="mt-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-6 text-sm">
    <div class="flex items-center gap-3">
      <label for="itemsPerPageSelect" class="text-sm font-medium text-gray-700 dark:text-gray-300">{t.vendedores.perPage}</label>
      <div class="relative">
        <select id="itemsPerPageSelect" class="block w-20 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-sm text-gray-900 dark:text-gray-100 rounded-md pl-3 pr-8 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="10">10</option>
          <option value="20">20</option>
          <option value="30">30</option>
        </select>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button
        id="prevPageBtn"
        type="button"
        aria-label="Previous page"
        class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-100 rounded-md transition disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <span id="pageIndicator" class="min-w-[120px] text-center px-4 py-1 rounded-lg bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-100 text-sm font-medium shadow-sm flex items-center justify-center"></span>
      <button
        id="nextPageBtn"
        type="button"
        aria-label="Next page"
        class="w-9 h-9 flex items-center justify-center bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-100 rounded-md transition disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<script type="module" define:vars={{ apiBase, apiPublic, lang, t }}>
  import { initSellersScript } from '/js/sellers.js';

  window.apiBase = apiPublic || apiBase;
  window.lang = lang;
  window.translations = { ...(window.translations || {}), ...t };

  const start = async () => {
    try {
      await initSellersScript();
    } catch (error) {
      console.error('Error inicializando vendedores:', error);
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start);
  } else {
    await start();
  }
</script>
