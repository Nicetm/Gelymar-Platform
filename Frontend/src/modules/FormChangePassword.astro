---
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const apiPublic = import.meta.env.PUBLIC_API_URL;
---

<div class="w-full max-w-md mx-auto space-y-6 animate-fade-in">
  <form id="changePasswordForm" class="space-y-6">
    <div>
      <label for="currentPassword" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Contraseña Actual</label>
      <input type="password" id="currentPassword" required class="input" placeholder="••••••••" />
    </div>
    
    <div>
      <label for="newPassword" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Nueva Contraseña</label>
      <input type="password" id="newPassword" required class="input" placeholder="••••••••" />
    </div>
    
    <div>
      <label for="confirmPassword" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Confirmar Nueva Contraseña</label>
      <input type="password" id="confirmPassword" required class="input" placeholder="••••••••" />
    </div>
    
    <p id="changePasswordMessage" class="text-sm text-center hidden"></p>
    
    <button type="submit" class="w-full px-5 py-3 text-base font-semibold text-white bg-[#00538C] rounded-lg hover:bg-[#003F6B] transition hover:scale-[1.01] active:scale-[.98]">
      Cambiar Contraseña
    </button>
  </form>
</div>

<style is:global>
  .input {
    @apply bg-gray-50 border border-gray-300 text-gray-900 sm:text-sm rounded-lg block w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white focus:ring-[#00538C] focus:border-[#00538C];
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fade-in 0.5s ease-out both;
  }
</style>

<script type="module" define:vars={{ apiBase, apiPublic }}>
  import { initChangePasswordScript } from '/src/scripts/change-password.js';
  
  // Hacer las variables disponibles globalmente
  window.apiBase = apiPublic;

  // Inicializar el script cuando el DOM esté completamente cargado
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', async () => {
      await initChangePasswordScript();
    });
  } else {
    initChangePasswordScript();
  }
</script> 
