---
import { loadTranslations, getServerLang } from '@lib/i18n.js';
const apiBase = import.meta.env.SERVER_API_URL || import.meta.env.PUBLIC_API_URL;
const apiPublic = import.meta.env.PUBLIC_API_URL;
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';
const lang = getServerLang(Astro.cookies);
let t: any = {};
try {
  t = {
    comond: await loadTranslations(lang, 'comond')
  };
} catch (error) {
  console.error('Error loading translations (FormChangePassword):', error);
}

---

<div class="w-full max-w-md mx-auto mt-10 space-y-6 animate-fade-in">
  <!-- Header -->
  <div class="flex flex-col items-center text-center gap-6">
    <div class="flex items-center gap-2">
      <img src="/assets/gelymar.svg" alt="Gelymar Logo" class="h-10 w-10"/>
      <span class="text-[2rem] font-bold tracking-tight text-[#002E50] dark:text-gray-100">
        Gelymar
      </span>
    </div>
  </div>

  <div class="text-center">
    <h1 class="text-2xl font-bold text-[#002E50]">
      {t?.comond?.change_password_title}
    </h1>
    <p class="mt-1 text-sm text-[#002E50]/80">
      {t?.comond?.change_password_subtitle}
    </p>
  </div>

  <form id="changePasswordForm" class="space-y-6">
    <!-- Hidden username field for accessibility -->
    <input type="text" name="username" autocomplete="username" style="display: none;" tabindex="-1" aria-hidden="true" />
    <div>
      <label for="currentPassword" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">{t?.comond?.current_password_label}</label>
      <input type="password" id="currentPassword" required autocomplete="current-password" class="input" placeholder="••••••••" />
    </div>
    
    <div>
      <label for="newPassword" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">{t?.comond?.new_password_label}</label>
      <input type="password" id="newPassword" required autocomplete="new-password" class="input" placeholder="••••••••" />
      <ul id="changePasswordRules" class="mt-3 text-xs space-y-1 text-gray-600 dark:text-gray-400">
        <li data-rule="length" class="flex items-center gap-2">
          <span class="rule-icon text-red-500">✗</span>
          <span>{t?.comond?.password_rule_min}</span>
        </li>
        <li data-rule="upper" class="flex items-center gap-2">
          <span class="rule-icon text-red-500">✗</span>
          <span>{t?.comond?.password_rule_upper}</span>
        </li>
        <li data-rule="lower" class="flex items-center gap-2">
          <span class="rule-icon text-red-500">✗</span>
          <span>{t?.comond?.password_rule_lower}</span>
        </li>
        <li data-rule="number" class="flex items-center gap-2">
          <span class="rule-icon text-red-500">✗</span>
          <span>{t?.comond?.password_rule_number}</span>
        </li>
      </ul>
    </div>
    
    <div>
      <label for="confirmPassword" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">{t?.comond?.confirm_password_label}</label>
      <input type="password" id="confirmPassword" required autocomplete="new-password" class="input" placeholder="••••••••" />
    </div>
    
    <p id="changePasswordMessage" class="text-sm text-center hidden"></p>

    {recaptchaSiteKey && (
      <div class="flex justify-center">
        <div class="g-recaptcha" data-sitekey={recaptchaSiteKey}></div>
      </div>
    )}
    
    <button type="submit" class="w-full px-5 py-3 text-base font-semibold text-white bg-[#00538C] rounded-lg hover:bg-[#003F6B] transition hover:scale-[1.01] active:scale-[.98] inline-flex items-center justify-center gap-2">
      {t?.comond?.change_password_button}
    </button>
  </form>
</div>

<script type="module" define:vars={{ apiBase, apiPublic, recaptchaSiteKey, comondTranslations: t?.comond ?? {} }}>
  // Hacer las variables disponibles globalmente
  window.apiBase = apiPublic;

  // Función para validar formulario
  function validateForm(form, rules) {
    const data = {};
    const errors = {};
    
    for (const [fieldName, rule] of Object.entries(rules)) {
      const field = form.querySelector(`#${fieldName}`);
      if (!field) continue;
      
      const value = field.value.trim();
      
      if (rule.required && !value) {
        errors[fieldName] = rule.requiredMessage;
        continue;
      }
      
      data[fieldName] = value;
    }
    
    return {
      isValid: Object.keys(errors).length === 0,
      data,
      errors
    };
  }

  // Función para mostrar errores
  function showFormErrors(form, errors) {
    // Limpiar errores anteriores
    const existingErrors = form.querySelectorAll('.error-message');
    existingErrors.forEach(error => error.remove());
    
    // Mostrar nuevos errores
    for (const [fieldName, errorMessage] of Object.entries(errors)) {
      const field = form.querySelector(`#${fieldName}`);
      if (!field) continue;
      
      const errorDiv = document.createElement('div');
      errorDiv.className = 'error-message text-red-500 text-sm mt-1';
      errorDiv.textContent = errorMessage;
      
      field.parentNode.appendChild(errorDiv);
      field.classList.add('border-red-500');
    }
  }

  // Función para limpiar errores
  function clearFormErrors(form) {
    const existingErrors = form.querySelectorAll('.error-message');
    existingErrors.forEach(error => error.remove());
    
    const fields = form.querySelectorAll('input');
    fields.forEach(field => field.classList.remove('border-red-500'));
  }

  // Inicializar cuando el DOM esté listo
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('changePasswordForm');
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      clearFormErrors(e.target);
      
      const validationRules = {
        currentPassword: {
          required: true,
          requiredMessage: comondTranslations.current_password_required
        },
        newPassword: {
          required: true,
          requiredMessage: comondTranslations.new_password_required
        },
        confirmPassword: {
          required: true,
          requiredMessage: comondTranslations.confirm_password_required
        }
      };

      const validation = validateForm(e.target, validationRules);
      if (!validation.isValid) {
        showFormErrors(e.target, validation.errors);
        return;
      }

      const { currentPassword, newPassword, confirmPassword } = validation.data;

      if (newPassword !== confirmPassword) {
        showFormErrors(e.target, { confirmPassword: comondTranslations.passwords_mismatch });
        return;
      }

      const isStrongPassword =
        newPassword.length >= 8 &&
        /[A-Z]/.test(newPassword) &&
        /[a-z]/.test(newPassword) &&
        /[0-9]/.test(newPassword);

      if (!isStrongPassword) {
        showFormErrors(e.target, { newPassword: comondTranslations.password_strength_error });
        return;
      }

      if (currentPassword === newPassword) {
        showFormErrors(e.target, { newPassword: comondTranslations.password_same_as_current });
        return;
      }

      const msg = document.getElementById('changePasswordMessage');
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalBtnText = submitBtn ? submitBtn.textContent : '';
      
      try {
        const token = localStorage.getItem('token');
        
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = comondTranslations.updating;
          submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
        }

        let captchaResponse = '';
        if (recaptchaSiteKey) {
          if (!window.grecaptcha || typeof window.grecaptcha.getResponse !== 'function') {
            if (msg) {
              msg.textContent = comondTranslations.captcha_not_ready;
              msg.classList.remove('hidden', 'text-green-600');
              msg.classList.add('text-red-500');
            }
            return;
          }
          captchaResponse = window.grecaptcha.getResponse();
          if (!captchaResponse) {
            if (msg) {
              msg.textContent = comondTranslations.captcha_required;
              msg.classList.remove('hidden', 'text-green-600');
              msg.classList.add('text-red-500');
            }
            return;
          }
        }

        const res = await fetch(`${window.apiBase}/api/auth/change-password`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ currentPassword, newPassword, captchaResponse })
        });
        
        const data = await res.json();

        if (!res.ok) {
          if (msg) {
            msg.textContent = data.message || comondTranslations.password_update_error;
            msg.classList.remove('hidden', 'text-green-600');
            msg.classList.add('text-red-500');
          }
          return;
        }

        if (msg) {
          msg.textContent = comondTranslations.password_update_success;
          msg.classList.remove('hidden', 'text-red-500');
          msg.classList.add('text-green-600');
        }

        setTimeout(() => {
          localStorage.removeItem('token');
          localStorage.removeItem('userRole');
          window.location.href = '/authentication/sign-in';
        }, 2000);

      } catch (err) {
        console.error('Error en cambio de contraseña:', err);
        if (msg) {
          msg.textContent = comondTranslations.connection_error;
          msg.classList.remove('hidden', 'text-green-600');
          msg.classList.add('text-red-500');
        }
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = originalBtnText;
          submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        }
      }
    });
  });

  const updatePasswordRules = (value) => {
    const rulesList = document.getElementById('changePasswordRules');
    if (!rulesList) return;
    const rules = {
      length: value.length >= 8,
      upper: /[A-Z]/.test(value),
      lower: /[a-z]/.test(value),
      number: /[0-9]/.test(value)
    };
    rulesList.querySelectorAll('li[data-rule]').forEach((item) => {
      const ruleKey = item.getAttribute('data-rule');
      const passed = !!rules[ruleKey];
      const icon = item.querySelector('.rule-icon');
      if (icon) {
        icon.textContent = passed ? '✓' : '✗';
        icon.classList.toggle('text-green-500', passed);
        icon.classList.toggle('text-red-500', !passed);
      }
      item.classList.toggle('text-green-600', passed);
      item.classList.toggle('text-red-500', !passed);
    });
  };

  const newPasswordInput = document.getElementById('newPassword');
  if (newPasswordInput) {
    updatePasswordRules(newPasswordInput.value || '');
    newPasswordInput.addEventListener('input', (e) => updatePasswordRules(e.target.value || ''));
  }

  if (recaptchaSiteKey) {
    const existingScript = document.querySelector('script[src*="recaptcha/api.js"]');
    if (!existingScript) {
      const script = document.createElement('script');
      script.src = 'https://www.google.com/recaptcha/api.js';
      script.async = true;
      script.defer = true;
      document.head.appendChild(script);
    }
  }
</script> 
