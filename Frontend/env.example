# ===========================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO
# ===========================================
# El sistema detecta automáticamente el entorno según la IP
# También puedes copiar manualmente: cp env.local .env o cp env.server .env

# Configuración del sitio
PUBLIC_LANG=en
SITE=http://localhost:2121              # Para servidor: http://172.20.10.151:2121
BASE_URL=/
REMOTE_ASSETS_BASE_URL=/assets

# URLs de servicios
PUBLIC_API_URL=http://localhost:3000    # Para servidor: http://172.20.10.151:3000
PUBLIC_FILE_SERVER_URL=http://localhost:8080  # Para servidor: http://172.20.10.151:8080
PUBLIC_API_BASE_URL=http://localhost:3000/api  # Para servidor: http://172.20.10.151:3000/api
PUBLIC_FRONTEND_BASE_URL=http://localhost:2121  # Para servidor: http://172.20.10.151:2121
SERVER_API_URL=http://backend:3000

# Build configuration
CI=false
